  {
    "name": "i-qrcode",
    "props": [
      {
        "name": "value",
        "type": "-",
        "defaultValue": "-",
        "desc": "二维码要编码的内容；内容变化时会重新生成二维码，并触发 change。"
      },
      {
        "name": "text",
        "type": "String",
        "defaultValue": "''",
        "desc": "兼容文本内容入口；传入后优先于 value 作为二维码内容。"
      },
      {
        "name": "size",
        "type": "Number",
        "defaultValue": "180",
        "desc": "二维码矩阵区域尺寸，单位 px；组件会按模块数量计算单格尺寸。"
      },
      {
        "name": "background",
        "type": "String",
        "defaultValue": "'#ffffff'",
        "desc": "二维码背景色，用于空白模块和静区背景，默认 #ffffff。"
      },
      {
        "name": "foreground",
        "type": "String",
        "defaultValue": "'#000000'",
        "desc": "二维码前景色，用于普通深色模块，默认 #000000。"
      },
      {
        "name": "pdground",
        "type": "String",
        "defaultValue": "'#000000'",
        "desc": "定位角点颜色，用于左上、右上、左下三个定位图案，默认 #000000。"
      },
      {
        "name": "level",
        "type": "String",
        "defaultValue": "'L'",
        "desc": "容错级别枚举，可选 L | M | Q | H；容错能力从 L 到 H 逐级增强。"
      },
      {
        "name": "logo",
        "type": "String",
        "defaultValue": "''",
        "desc": "二维码中心 logo 图片路径，默认空；仅在正常状态且二维码生成成功后显示。"
      },
      {
        "name": "logoBgColor",
        "type": "String",
        "defaultValue": "'transparent'",
        "desc": "logo 容器背景颜色，默认 transparent；需要白底留白时可传 #ffffff。"
      },
      {
        "name": "logoSize",
        "type": "String",
        "defaultValue": "'50px'",
        "desc": "logo 大小，默认 50px；支持 50、50px 等写法。"
      },
      {
        "name": "icon",
        "type": "String",
        "defaultValue": "''",
        "desc": "兼容旧 API 的二维码中心图标地址；未传 logo 时会作为 logo 使用。"
      },
      {
        "name": "iconSize",
        "type": "Number",
        "defaultValue": "30",
        "desc": "兼容旧 API 的中心图标大小，单位 px；仅在未传 logo 时作为尺寸回退。"
      },
      {
        "name": "status",
        "type": "String",
        "defaultValue": "''",
        "desc": "二维码状态枚举，可选 expired | scanned | loading；空字符串表示正常可扫码状态。"
      },
      {
        "name": "expiredText",
        "type": "String",
        "defaultValue": "'二维码已过期'",
        "desc": "status 为 expired 时的过期提示文字，默认“二维码已过期”。"
      },
      {
        "name": "scannedText",
        "type": "String",
        "defaultValue": "'二维码已扫描'",
        "desc": "status 为 scanned 时的已扫码提示文字，默认“二维码已扫描”。"
      },
      {
        "name": "refreshText",
        "type": "String",
        "defaultValue": "'刷新'",
        "desc": "status 为 expired 时刷新按钮文字，默认“刷新”。"
      }
    ],
    "events": [
      {
        "name": "click",
        "desc": "点击二维码整体时触发，回调参数为当前实际编码内容。"
      },
      {
        "name": "change",
        "desc": "二维码重新生成时触发；value、text 变化或手动 refresh 后都会派发。"
      },
      {
        "name": "refresh",
        "desc": "点击过期状态中的刷新按钮时触发，回调参数为当前实际编码内容。"
      },
      {
        "name": "error",
        "desc": "二维码生成失败时触发；例如内容过长导致当前版本无法容纳。"
      }
    ],
    "slots": [
      {
        "name": "default",
        "desc": "默认内容插槽。"
      }
    ],
    "methods": []
  },
