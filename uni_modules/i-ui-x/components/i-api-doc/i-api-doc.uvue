]

const requestedText = computed(() => {
  if (props.names.length > 0) return props.names
  return props.components.length > 0 ? props.components : props.component
})

const currentDocs = computed(() => {
  const source = requestedText.value
  if (source.length == 0) return []
  const names = source.split(',')
  const result = []
  for (let i = 0; i < names.length; i++) {
    const name = names[i].trim()
    const doc = findDoc(name)
    if (doc != null) result.push(doc)
  }
  return result
})

function findDoc(name) {
  for (let i = 0; i < apiDocs.length; i++) {
    if (apiDocs[i].name == name) return apiDocs[i]
  }
  return null
}
