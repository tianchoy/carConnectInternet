<template>
  <view class="i-card"
    ><text
      :class="expanded ? 'i-content' : 'i-content i-content--collapsed'"
      >{{ text }}</text
    ><view class="i-btn" @click="toggle"
      ><text class="i-btn-text">{{
        expanded ? "收起" : "阅读全文"
      }}</text></view
    ></view
  >
</template>
<script setup lang="uts">
import { ref } from 'vue'

defineOptions({ name: 'i-read-more' })

/**
 * Props 说明：外部传入的配置，用于控制组件展示、状态和行为。
 * - text: 主要展示文本。
 */
const props = defineProps({
  text: {
    type: String,
    default:
      '这是一段较长的内容，用于测试阅读更多组件。组件会在折叠和展开之间切换，并向外派发 change 事件，页面可以拿到当前状态。',
  },
})

/**
 * Emits 说明：组件向外派发的事件，用于页面监听交互结果或同步受控值。
 * - change: 状态或值变化时触发，参数为最新状态或值。
 * - open: 组件打开或展开时触发。
 * - close: 组件关闭或收起时触发。
 */
const emit = defineEmits(['change', 'open', 'close'])

const expanded = ref(false)

function toggle() {
  expanded.value = !expanded.value
  emit('change', expanded.value)
  emit(expanded.value ? 'open' : 'close')
}
</script>
