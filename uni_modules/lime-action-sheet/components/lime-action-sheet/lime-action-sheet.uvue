		{ label: '企业微信', icon: 'https://tdesign.gtimg.com/mobile/demos/wecom.png', radius: '0px'},
		{ label: '收藏', icon: 'share' },
		{ label: '下载', icon: 'download' },
		{ label: '编辑', icon: 'edit', disabled: true},
		{ label: '选项', icon: 'app' },
		{ label: '选项', icon: 'app' },
		{ label: '选项', icon: 'app', disabled: true},
		{ label: '选项', icon: 'app' },
		{ label: '选项', icon: 'app' },
	]
	
	const select = (index:number)=> {
		console.log('index', index)
	}
	const onClick = () => {
		show1.value = true
	}
</script>

