<template>
	<view class="container">
		<custom-navBar title="地理围栏" :show-back="true" backgroundColor="#fff" textColor="#333" :showCapsule="false">
		</custom-navBar>
		<view class="map-container">
			<map id="myMap" :latitude="center.latitude" :longitude="center.longitude" :scale="mapScale"
				style="width:100%;height:100%" :show-location="false" :polygons="polygons" :markers="markers"
				:circles="circles" @tap="handleMapTap" :enable-traffic="true" :enable-overlooking="true" :enable-building="true" :enable-3D="true">
				<sub-navBar :showTime="false" :currentCar="currentCar" :showCar="true"
					:carStatus='connectionStatus'></sub-navBar>
			</map>

			<!-- 绘制提示 -->
			<view v-if="isDrawing" class="drag-hint">
				<text v-if="drawingMode === 'polygon'" class="drag-hint-text">点击地图添加围栏点,至少需要3个点</text>
				<text v-if="drawingMode === 'circle'" class="drag-hint-text">点击地图确定圆心，再点一下地图确定半径</text>
			</view>
		</view>

		<!-- 围栏操作面板 -->
		<i-popup ref="showFenceModal" mode="center" round='10'>
			<view class="fence-operations" v-if="selectedFence">
				<view class="fence-header">
					<text class="fence-name">{{ getSelectedFenceName() }}</text>
					<i-icon name="close" @click="selectedFence = null; showFenceModal?.$callMethod('close')"></i-icon>
				</view>
				<view class="fence-actions">
					<i-button size="small" @click="editSelectedFence">编辑</i-button>
					<i-button size="small" type="error" @click="deleteSelectedFence">删除</i-button>
					<i-button size="small" type="primary" @click="showSelectedFenceDevices">绑定设备</i-button>
				</view>
			</view>
		</i-popup>


		<!-- 绘制控制面板 -->
		<view class="tools-panel">
			<!-- 绘制模式选择 -->
			<view class="drawing-mode-selector" v-if="!isDrawing && !selectedFence">
				<text class="mode-title">选择围栏类型:</text>
				<view class="mode-buttons">
					<i-button :type="drawingMode == 'polygon' ? 'success' : 'default'" size="small"
						customStyle="border:1rpx solid #ebedf0" @click="setDrawingMode('polygon')">
						多边形
					</i-button>
					<i-button class="mode-button-spacing" :type="drawingMode == 'circle' ? 'success' : 'default'" size="small"
						customStyle="border:1rpx solid #ebedf0" @click="setDrawingMode('circle')">
						圆形
					</i-button>
				</view>
			</view>

			<view class="tool-tag-item">
				<i-button @click="startDrawing" :disabled="isDrawing || selectedFence" size="small">
					开始绘制
				</i-button>
				<i-button @click="finishDrawing" :disabled="!isDrawing || !canFinishDrawing" size="small">
					完成绘制
				</i-button>
				<i-button @click="clearDrawing" size="small">
					重置绘制
				</i-button>
				<i-button @click="showFenceList" size="small">
					围栏列表
				</i-button>
			</view>

			<view class="status-info">
				<text class="status-text">围栏类型: {{ drawingMode === 'polygon' ? '多边形' : '圆形' }}</text>
				<text v-if="drawingMode === 'polygon'" class="status-text">顶点数量: {{ points.length }}</text>
				<text v-if="drawingMode === 'circle'" class="status-text">半径: {{ circleRadius.toFixed(2) }}米</text>
			</view>
		</view>

		<!-- 围栏列表弹窗 -->
		<i-popup ref="fencesPopup" mode="bottom" round="10">
			<view class="fence-list">
				<view class="list-header">
					<text class="title">围栏列表</text>
					<i-icon name="/static/close.png" fontSize="15" @click="closeFenceList"></i-icon>
				</view>
				<scroll-view class="list-content" scroll-y>
					<view v-for="fence in fenceList" :key="fence.id" class="fence-item" @click="selectFence(fence)">
						<view class="fence-info">
							<text class="name">{{ fence.name }}</text>
							<text class="type">{{ getFenceType(fence) === 'circle' ? '圆形' : '多边形' }}</text>
							<text class="devices">绑定设备: {{ fence.deviceCount || 0 }}台</text>
						</view>
						<i-icon name="/static/arrow-right.png" fontSize="15"></i-icon>
					</view>
					<view v-if="fenceList.length === 0" class="empty">
						<text class="empty-text">暂无围栏数据</text>
					</view>
				</scroll-view>
			</view>
		</i-popup>

		<!-- 围栏编辑弹窗 -->
		<i-popup ref="editDialogPopup" mode="center" round="10" :contentDraggable="false">
			<view class="edit-dialog">
				<view class="dialog-header">
					<text class="dialog-title">{{ editingFence ? '编辑围栏' : '新增围栏' }}</text>
				</view>
				<view class="dialog-content">
					<i-input v-model="fenceForm.name" placeholder="请输入围栏名称" border="surround"></i-input>
					<view class="radio-group">
						<text class="label">告警类型:</text>
						<view class="radio-options">
							<i-radio v-model="fenceForm.alarmType" name="0" iconPlacement="left">不告警</i-radio>
							<i-radio v-model="fenceForm.alarmType" name="1" iconPlacement="left">出入告警</i-radio>
							<i-radio v-model="fenceForm.alarmType" name="2" iconPlacement="left">出告警</i-radio>
							<i-radio v-model="fenceForm.alarmType" name="3" iconPlacement="left">入告警</i-radio>
						</view>
					</view>
				</view>
				<view class="dialog-actions">
					<i-button @click="closeEditDialog">取消</i-button>
					<i-button type="primary" @click="saveFence">保存</i-button>
				</view>
			</view>
		</i-popup>
		<i-popup ref="deviceDialogPopup" mode="bottom" round="10" :closeOnMask="false">
			<view class="device-dialog">
				<view class="dialog-header">
					<text class="dialog-title">设备绑定 - {{ currentFenceName }}</text>
					<i-icon name="close" @click="closeDeviceDialog"></i-icon>
				</view>
				<view class="dialog-tabs">
					<view :class="['tab', activeTab === 'bind' ? 'active' : '']" @click="switchTab('bind')">
						已绑定设备
					</view>
					<view :class="['tab', activeTab === 'unbind' ? 'active' : '']" @click="switchTab('unbind')">
						未绑定设备
					</view>
				</view>
				<scroll-view 
					class="device-list" 
					scroll-y 
					:scroll-top="scrollTop"
					@scrolltolower="handleLoadMore"
					:lower-threshold="150"
				>
					<view v-for="device in deviceList" :key="getDeviceImei(device)" class="device-item">
						<view class="device-info">
							<text class="name">{{ getDeviceDisplayName(device) }}</text>
							<text class="status" v-if="getDeviceImei(device)">{{ isDeviceOnline(device) ? '在线' : '离线' }}</text>
						</view>
						<i-switch :model-value="isDeviceBound(getDeviceImei(device))"
							@change="handleDeviceBindingChange(getDeviceImei(device), $event as boolean)" :disabled="loading || loadingMore"
							size="20">
						</i-switch>
					</view>
					
					<view v-if="deviceList.length === 0 && !loading" class="empty">
						<text class="empty-text">{{ activeTab === 'bind' ? '暂无绑定设备' : '暂无可用设备' }}</text>
					</view>
					<view v-if="loadingMore" class="loading-tip">
						<text>正在加载更多...</text>
					</view>
					<view v-if="deviceList.length > 0 && !hasMore && !loadingMore" class="no-more">
						暂无更多数据
					</view>
				</scroll-view>
			</view>
		</i-popup>
	</view>
</template>

<script setup>
	import { ref, reactive, onMounted, computed, watch } from 'vue'
	import { getDevicePos, getGeofenceList, addGeofence, updateGeofence, deleteGeofence, getBoundDevices, getUnboundDevices, bindDevices, unbindDevices } from '../../api/request.uts'
	import CoordTransform, { type Coordinate as TencentCoordinate } from '../../utils/coordTransform.uts'
	import { getDeviceIcon } from '../../utils/cars'

	const imei = ref<string | null>(null)
	const connectionStatus = ref<string | null>(null)
	const deptId = ref<string | null>(null)
	const carType = ref<string | null>(null)
	const deviceName = ref<string | null>(null)
	type Coordinate = LocationObject;
	type PaginationState = {
		pageNum : number;
		pageSize : number;
		hasMore : boolean;
		loadingMore : boolean;
	};
	type Pagination = {
		bind : PaginationState;
		unbind : PaginationState;
	};
	type CircleData = {
		latitude : number;
		longitude : number;
		radius : number;
	};
	type ModalResult = {
		confirm : boolean;
	};
	type FenceForm = {
		name : string;
		alarmType : string;
	};
	type FenceResponse = {
		code : number;
		msg : string;
	};
	type SwitchChangeEvent = {
		value : boolean;
	};
	// 地图状态
	const center = reactive({
		latitude: 39.90469,
		longitude: 116.40717
	})
	const mapScale = ref(15)
	const markers = ref<Array<Marker>>([]) // 标记点
	const carMarker = ref<Marker | null>(null) // 车辆标记点
	const circles = ref<Array<Circle>>([]) // 圆形围栏
	const carInFence = ref(false) // 车辆是否在围栏内

	// 电子围栏相关状态
	const isDrawing = ref(false)
	const drawingMode = ref('polygon') // 'polygon' 或 'circle'
	const points = ref<Array<Coordinate>>([])
	const polygons = ref<Array<Polygon>>([]) // 存储地理围栏多边形数据
	const circleCenter = ref<Coordinate | null>(null);
	const circleRadius = ref(0) // 圆形围栏半径（米）
	const currentSpeed = ref(0)
	const currentAddress = ref('获取中...')
	const currentCar = ref<string | null>('京A12345')
	const lastDirection = ref(0)
	const showFenceModal = ref<ComponentPublicInstance | null>(null)

	// 围栏管理状态
	const fenceList = ref<Array<UTSJSONObject>>([])
	const selectedFence = ref<UTSJSONObject | null>(null)
	const fencesPopup = ref<ComponentPublicInstance | null>(null)
	const editDialogPopup = ref<ComponentPublicInstance | null>(null)
	const editingFence = ref<UTSJSONObject | null>(null)
	const alarmTypeOptions = ['0', '1', '2', '3']
	const fenceForm = reactive<FenceForm>({
		name: '',
		alarmType: '1'
	})

	// 设备绑定状态
	const deviceDialogPopup = ref<ComponentPublicInstance | null>(null)
	const activeTab = ref('bind')
	const deviceList = ref<Array<UTSJSONObject>>([]) // 当前显示的设备列表
	const boundDevices = ref<Array<UTSJSONObject>>([]) // 已绑定设备完整列表
	const currentFenceName = ref('')
	const currentFenceId = ref('')
	const loading = ref(false)
	const scrollTop = ref(0) // 滚动位置控制
	let loadMoreTimer = null // 防抖定时器

	// 分页控制变量（已绑定/未绑定设备）
	const pagination = reactive<Pagination>({
		bind: {
			pageNum: 1, // 当前页码
			pageSize: 10, // 每页条数
			hasMore: true, // 是否还有更多数据
			loadingMore: false // 加载更多中状态
		},
		unbind: {
			pageNum: 1,
			pageSize: 10,
			hasMore: true,
			loadingMore: false
		}
	})

	// 计算是否可以完成绘制
	const canFinishDrawing = computed(() => {
		if (drawingMode.value === 'polygon') {
			return points.value.length >= 3
		} else if (drawingMode.value === 'circle') {
			return circleCenter.value !== null && circleRadius.value > 0
		}
		return false
	})

	// 计算当前加载更多状态
	const loadingMore = computed(() => {
		return activeTab.value === 'bind' ? pagination.bind.loadingMore : pagination.unbind.loadingMore
	})

	// 计算是否还有更多数据
	const hasMore = computed(() => {
		return activeTab.value === 'bind' ? pagination.bind.hasMore : pagination.unbind.hasMore
	})




	const loadInitialPosition = async () => {
		uni.showLoading({
			title: '获取车辆位置中...'
		})

		try {
			const data = { deptId: deptId.value, deviceids: imei.value }
			const res = await getDevicePos(data)

			res.data.forEach(item => {
				if (item.getString('imei', '') == imei.value) {
					const deviceData = item
					// 转换坐标到腾讯地图坐标系
					const convertedCoord = CoordTransform.wgs84ToTencent(
						deviceData.getNumber('latitude', 0),
						deviceData.getNumber('longitude', 0)
					)
					center.latitude = convertedCoord.lat
					center.longitude = convertedCoord.lng

					const position : LocationObject = {
						latitude: convertedCoord.lat,
						longitude: convertedCoord.lng
					}

					// 记录初始方向
					lastDirection.value = deviceData.getNumber('direction', 0)

					// 创建车辆标记点
					carMarker.value = {
						id: 0,
						latitude: position.latitude,
						longitude: position.longitude,
						iconPath: getDeviceIcon(connectionStatus.value.toString(), carType.value.toString()),
						width: 25,
						height: 25,
						rotate: lastDirection.value >= 360 ? lastDirection.value - 360 : (lastDirection.value < 0 ? lastDirection.value + 360 : lastDirection.value), // 修正方向
						callout: {
							content: deviceName.value || '爱车位置',
							color: connectionStatus.value == 'online' ? '#fff' : '#666',
							bgColor: connectionStatus.value == 'online' ? '#07C160' : '#ccc',
							padding: 5,
							borderRadius: 4,
							display: 'ALWAYS'
						}
					} as Marker

					// 更新标记点数组，保留车辆标记点
					const marker = carMarker.value
					if (marker != null) {
						markers.value = [marker]
					}

					// 更新车辆信息
					currentSpeed.value = deviceData.speed ? parseFloat(deviceData.speed.toString()) : 0
					currentAddress.value = deviceData.positionUpdateTime
						? `最后定位: ${deviceData.positionUpdateTime}`
						: '未知位置'
					connectionStatus.value = deviceData.connectionStatus ? deviceData.connectionStatus.toString() : 'unknown'
				}
			})

		} catch (err) {
			console.error('获取初始位置失败:', err)
			uni.showToast({
				title: '获取车辆位置失败',
				icon: 'none'
			})
		} finally {
			uni.hideLoading()
		}
	}

	// 计算地图上的旋转角度（修正方向）


	function calculateMapRotation(direction : number) : number {
		let rotation = direction
		if (rotation >= 360) rotation -= 360
		if (rotation < 0) rotation += 360

		return rotation
	}

	function getFenceType(fence : UTSJSONObject) : string {
		const type = fence.getString('type', '')
		if (type && type !== 'null') {
			return type
		}
		const area = fence.getString('area', '')
		if (area.startsWith('CIRCLE')) {
			return 'circle'
		} else if (area.startsWith('POLYGON')) {
			return 'polygon'
		}
		return 'polygon'
	}

	function parsePolygon(polygonStr : string) : Array<Coordinate> {
		if (!polygonStr) return []
		const coordStr = polygonStr.replace(/POLYGON \(\(/, '').replace(/\)\)/, '')
		const coordPoints = coordStr.split(',')
		return coordPoints.map((point : string) : Coordinate => {
			const values = point.trim().split(' ')
			const convertedCoord = CoordTransform.wgs84ToTencent(parseFloat(values[0]), parseFloat(values[1]))
			return {
				latitude: convertedCoord.lat,
				longitude: convertedCoord.lng
			}
		})
	}

	function parseCircle(circleStr : string) : CircleData | null {
		if (!circleStr || !circleStr.startsWith('CIRCLE')) return null
		try {
			const coordStr = circleStr.replace(/CIRCLE \(/, '').replace(/\)/, '')
			const parts = coordStr.split(',')
			if (parts.length != 2) return null
			const centerValues = parts[0].trim().split(' ')
			const lat = parseFloat(centerValues[0])
			const lng = parseFloat(centerValues[1])
			const radius = parseFloat(parts[1].trim())
			if (isNaN(lat) || isNaN(lng) || isNaN(radius) || radius <= 0) {
				console.error('无效的圆形围栏数据:', circleStr)
				return null
			}
			const convertedCoord = CoordTransform.wgs84ToTencent(lat, lng)
			return {
				latitude: convertedCoord.lat,
				longitude: convertedCoord.lng,
				radius: radius
			}
		} catch (error) {
			console.error('解析圆形围栏失败:', error, '数据:', circleStr)
			return null
		}
	}

	function updateMarkers() : void {
		const newMarkers : Array<Marker> = []

		// 首先添加车辆标记点
		if (carMarker.value) {
			newMarkers.push(carMarker.value)
		}

		// 添加围栏顶点标记
		if (isDrawing.value) {
			if (drawingMode.value === 'polygon') {
				// 多边形顶点标记
				points.value.forEach((point, index) => {
					newMarkers.push({
						id: 1000 + index,
						latitude: point.latitude,
						longitude: point.longitude,
						iconPath: '/static/marker.png',
						width: 32,
						height: 32,
						callout: { content: `顶点${index + 1}`, display: 'ALWAYS' },
						anchor: { x: 0.5, y: 0.5 }
					} as Marker)
				})
			} else if (drawingMode.value === 'circle' && circleCenter.value) {
				// 圆形圆心标记
				newMarkers.push({
					id: 1000,
					latitude: circleCenter.value.latitude,
					longitude: circleCenter.value.longitude,
					iconPath: '/static/marker.png',
					width: 32,
					height: 32,
					callout: { content: '圆心', display: 'ALWAYS' },
					anchor: { x: 0.5, y: 0.5 }
				} as Marker)
			}
		} else {
			const selected = selectedFence.value
			if (selected == null) {
				markers.value = newMarkers
				return
			}
			// 选中围栏时显示标记
			const fenceType = getFenceType(selected)
			const area = selected.getString('area', '')
			if (fenceType === 'circle') {
				const circleData = parseCircle(area)
				if (circleData != null) {
					newMarkers.push({
						id: 2000,
						latitude: circleData.latitude,
						longitude: circleData.longitude,
						iconPath: '/static/marker.png',
						width: 32,
						height: 32,
						callout: { content: '圆心', display: 'ALWAYS' },
						anchor: { x: 0.5, y: 0.5 }
					} as Marker)
				}
			} else {
				const fencePoints = parsePolygon(area)
				fencePoints.forEach((point, index) => {
					newMarkers.push({
						id: 2000 + index,
						latitude: point.latitude,
						longitude: point.longitude,
						iconPath: '/static/marker.png',
						width: 32,
						height: 32,
						callout: { content: `顶点${index + 1}`, display: 'ALWAYS' },
						anchor: { x: 0.5, y: 0.5 }
					} as Marker)
				})
			}
		}

		markers.value = newMarkers
	}

	const renderFencesOnMap = () => {
		// 当围栏列表为空时，强制清空地图上所有围栏和标记
		if (!fenceList.value || fenceList.value.length == 0) {
			polygons.value = []; // 清空多边形围栏
			circles.value = [];  // 清空圆形围栏
			updateMarkers();    // 清空围栏相关标记（如顶点、圆心）
			return;
		}

		const fencePolygons : Array<Polygon> = []
		const fenceCircles : Array<Circle> = []
		let colorIndex = 0

		// 为每个围栏创建多边形或圆形
		fenceList.value.forEach((fence : UTSJSONObject) => {
			const fenceType = getFenceType(fence)

			if (fenceType === 'circle') {
				// 处理圆形围栏
				const circleData = parseCircle(fence.getString('area', ''))
				if (circleData != null) {
					// 处理过大半径，避免无法显示
					const displayRadius = circleData.radius > 100000 ? 100000 : circleData.radius;

					fenceCircles.push({
						latitude: circleData.latitude,
						longitude: circleData.longitude,
						radius: displayRadius,
						strokeWidth: 2,
						color: '#FF0000',
						fillColor: `rgba(255,0,0,0.2)`
					} as Circle)
				}
			} else {
				// 处理多边形围栏
				const fencePoints = parsePolygon(fence.getString('area', ''))
				if (fencePoints.length >= 3) {
					fencePolygons.push({
						points: fencePoints,
						strokeWidth: 2,
						strokeColor: '#FF0000',
						fillColor: colorIndex++ == 0 ? 'rgba(255,0,0,0.2)' : `rgba(${Math.floor(Math.random() * 200)},${Math.floor(Math.random() * 200)},${Math.floor(Math.random() * 200)},0.2)`,
						zIndex: 1
					} as Polygon)
				}
			}
		})

		polygons.value = fencePolygons
		circles.value = fenceCircles

		// 确保圆形围栏能显示在地图视野中
		if (fenceCircles.length > 0 && !selectedFence.value) {
			// 自动定位到第一个圆形围栏
			const firstCircle = fenceCircles[0]
			center.latitude = firstCircle.latitude
			center.longitude = firstCircle.longitude
			// 根据半径设置合适的缩放级别
			mapScale.value = firstCircle.radius > 50000 ? 8 : firstCircle.radius > 20000 ? 9 : firstCircle.radius > 10000 ? 10 : firstCircle.radius > 5000 ? 11 : firstCircle.radius > 2000 ? 12 : firstCircle.radius > 1000 ? 13 : firstCircle.radius > 500 ? 14 : firstCircle.radius > 200 ? 15 : 16
		}
	}

	function updateMapDisplay() : void {
		updateMarkers()

		if (isDrawing.value) {
			if (drawingMode.value === 'polygon') {
				polygons.value = points.value.length >= 3 ? [{
					points: points.value,
					strokeWidth: 2,
					strokeColor: '#FF0000',
					fillColor: 'rgba(255,0,0,0.2)',
					zIndex: 1
				} as Polygon] : []
				circles.value = []
			} else if (drawingMode.value === 'circle') {
				const drawingCenter = circleCenter.value
				if (drawingCenter != null && circleRadius.value > 0) {
					const drawingCircle : Circle = {
						latitude: drawingCenter.latitude,
						longitude: drawingCenter.longitude,
						radius: circleRadius.value,
						strokeWidth: 2,
						color: '#FF0000',
						fillColor: 'rgba(255,0,0,0.2)'
					} as Circle
					circles.value = [drawingCircle]
				} else {
					circles.value = []
				}
				polygons.value = []
			}
		} else {
			renderFencesOnMap()
		}
	}

