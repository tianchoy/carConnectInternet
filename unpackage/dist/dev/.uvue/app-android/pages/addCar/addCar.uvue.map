		width: 100%;
		height: 100%;
		background-color: #f5f5f5;

		.content {
			margin: 20rpx;
			padding: 20rpx 40rpx;
			background-color: #fff;
			border-radius: 20rpx;
		}


		.clickable{
			margin-top: 10px;
			color:#999;
			font-size: 28rpx;
		}

		.btn {
			margin: 50rpx 20rpx 0 20rpx;
		}

		.plate-input {
			width: 100%;

			:deep(.input-wrapper) {
				padding: 0;
				border: none;
			}
		}

		// 车牌输入组件样式
		:deep(.car-input-container) {
			display: flex;
			flex-direction: row;
		}

		:deep(.car-number-input) {
			width: 60%;
			text-align: right;
		}

		:deep(.car-number-container .plate-close) {
			height: 40px;
			display: flex;
			text-align: right;
			background-color: #FFF;
			flex-direction: row;
			justify-content: flex-end;
			align-items: center;
		}

		:deep(.car-input-container .car-input-box .car-input-item) {
			position: relative;
			border: 1px solid #E2E2E2;
			height: 40px;
			line-height: 40px;
			text-align: center;
			font-size: 17px;
		}

		:deep(.car-input-container .car-input-box .car-input-item .new-item-img) {
			position: absolute;
			top: -2px;
			left: 50%;
