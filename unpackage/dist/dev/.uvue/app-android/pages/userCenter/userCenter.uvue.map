<template>
	<view class="container">
		<custom-navBar title="个人中心" :show-back="false" backgroundColor="#fff" textColor="#333" :showCapsule="false">
		</custom-navBar>
		<view class="user-info-box" @click="userInfoDetail">
			<view class="userinfo">
				<view>
					<uv-avatar src="/static/avatar.png" shape="circle"></uv-avatar>
				</view>
				<view class="user-info">
					<text v-if="Login">{{userInfo.mobile}}</text>
					<text v-else>点击登录</text>
				</view>
			</view>
			<uv-icon name="arrow-right" size="16"></uv-icon>
		</view>
		<view v-if="Login">
			<view class="list" @click="carList">
				<view class="left">
					<text>我的车辆</text>
					<text class="badge"><uv-badge numberType="overflow" type="error" max="99"  :value="carsnumber"></uv-badge></text>
				</view>
				<uv-icon name="arrow-right" size="16"></uv-icon>
			</view>
			<view class="list" @click="platformRenewal">平台续费</view>
		</view>
		<view class="version" v-if="version">当前版本：{{version}}</view>
	</view>
</template>

<script setup lang="uts">
	import { getUserInfo, getUserDeviceList } from '../../api/request';
	const userInfo = ref({
		avatar: '/static/avatar.png',
		nickname: '',
	})
	const carsnumber = ref(0)
	const Login = ref(false)
	const version = ref('')
	onShow(() => {
		// 如果有 token，加载用户信息
		const token = uni.getStorageSync('token')
		if (token) {
			Login.value = true
			loadData()
		} else {
			Login.value = false
		}
		// 获取小程序版本号
		try {
			const accountInfo = wx.getAccountInfoSync();
			const appVersion = accountInfo.miniProgram.version; 
			version.value = appVersion 
		} catch (error) {
			console.error('获取版本号失败:', error)
		}
	})

	// 加载数据
	const loadData = async () => {
		let params = {}
		const res = await getUserInfo()
		userInfo.value = res.data

		const resCars = await getUserDeviceList(params)
			
			if (resCars?.data?.totalCount) {
				 carsnumber.value = resCars.data.totalCount
			}
	}

	// 用户信息详情
	const userInfoDetail = () => {
		if (Login.value) {
			uni.navigateTo({
				url: '/pages/userCenter/userInfo/userInfo?userInfo=' + encodeURIComponent(JSON.stringify(userInfo.value))
			})
		} else {
			uni.navigateTo({
				url: '/pages/login/login'
			})
		}
	}

	// 我的车辆
	const carList = () => {
		if (Login.value) {
			uni.navigateTo({
				url: '/pages/userCenter/carList/carList'
			})
		} else {
			uni.showToast({
				title: '请先登录',
				icon: 'none',
			})
		}
	}

	// 平台续费
	const platformRenewal = () => {
		if (Login.value) {
			// uni.showToast({
			// 	title: '设备仍在服务期',
			// 	icon: 'none',
			// })
			uni.navigateTo({
				url: '/pages/userCenter/payDeviceList/payDeviceList'
			})
		} else {
			uni.showToast({
				title: '请先登录',
				icon: 'none',
			})
		}
	}
</script>

<style lang="scss">
	.container {
		width: 100%;
		height: 100%;
		background-color: #fff;

		.user-info-box {
			width: 100%;
			padding: 40rpx 60rpx;
			display: flex;
			flex-direction: row;
			justify-content: space-between;
			align-items: center;

			.userinfo {
				display: flex;
				flex-direction: row;
				justify-content: left;
				align-items: center;
				flex: 1;
			}

			.user-info {
				margin-left: 20rpx;
				text-align: center;
				font-size: 30rpx;
				color: #333;
			}
		}

		.list {
			background-color: #f5f5f5;
			padding: 30rpx;
			border-radius: 20rpx;
			margin: 15rpx;
			display: flex;
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
			font-size: 25rpx;

			.left{
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
				.badge {
					margin-left: 20rpx;
				}
			}
		}
		
		.version {
			position: fixed;
			bottom: 50rpx;
			left: 20rpx;
			right: 20rpx;
			text-align: center;
			font-size: 20rpx;
			color: #c3c2c2ff;
			margin: 20rpx 40rpx 0;
		}
	}
</style>