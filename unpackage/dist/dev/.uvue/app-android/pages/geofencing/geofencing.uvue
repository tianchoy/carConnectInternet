                if (res.code == 0) {
                    const dataList = res.data.list != null ? res.data.list : [];
                    if (page.pageNum == 1) {
                        boundDevices.value = dataList;
                        deviceList.value = dataList;
                    }
                    else {
                        deviceList.value = [...deviceList.value, ...dataList];
                    }
                    page.hasMore = dataList.length === page.pageSize;
                    if (page.hasMore)
                        page.pageNum++;
                }
                else {
                    page.hasMore = false;
                }
            }
            catch (error: any) {
                page.hasMore = false;
            }
            finally {
                page.loadingMore = false;
            }
