                    }
                }
                else {
                    showAppToast({ title: isTruthy(result.msg) ? result.msg : '保存失败', icon: 'none' } as ShowToastOptions);
                }
            }
            catch (error: any) {
                uni.hideLoading();
                console.error('保存围栏失败:', error, " at pages/geofencing/geofencing.uvue:940");
                showAppToast({ title: '保存失败，请重试', icon: 'none' } as ShowToastOptions);
