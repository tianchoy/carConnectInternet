import _easycom_custom_navBar from '@/components/custom-navBar/custom-navBar.uvue';
import _easycom_sub_navBar from '@/components/sub-navBar/sub-navBar.uvue';
import _easycom_uv_icon from '@/uni_modules/uv-icon/components/uv-icon/uv-icon.vue';
import _easycom_uv_button from '@/uni_modules/uv-button/components/uv-button/uv-button.vue';
import _easycom_uv_popup from '@/uni_modules/uv-popup/components/uv-popup/uv-popup.vue';
import _easycom_uv_input from '@/uni_modules/uv-input/components/uv-input/uv-input.vue';
import _easycom_uv_radio from '@/uni_modules/uv-radio/components/uv-radio/uv-radio.vue';
import _easycom_uv_grid_item from '@/uni_modules/uv-grid/components/uv-grid-item/uv-grid-item.vue';
import _easycom_uv_radio_group from '@/uni_modules/uv-radio/components/uv-radio-group/uv-radio-group.vue';
import _easycom_uv_grid from '@/uni_modules/uv-grid/components/uv-grid/uv-grid.vue';
import _easycom_uv_switch from '@/uni_modules/uv-switch/components/uv-switch/uv-switch.vue';
import { ref, reactive, onMounted, computed, watch } from 'vue';
import { getDevicePos, getGeofenceList, addGeofence, updateGeofence, deleteGeofence, getBoundDevices, getUnboundDevices, bindDevices, unbindDevices } from '../../api/request.uts';
import CoordTransform from '../../utils/coordTransform.uts';
import { getDeviceIcon } from '../../utils/cars';
type Coordinate = {
    __$originalPosition?: UTSSourceMapPosition<"Coordinate", "pages/geofencing/geofencing.uvue", 187, 7>;
    latitude: number;
    longitude: number;
};
// 地图状态
const __sfc__ = defineComponent({
    __name: 'geofencing',
    setup(__props) {
        const __ins = getCurrentInstance()!;
        const _ctx = __ins.proxy as InstanceType<typeof __sfc__>;
        const _cache = __ins.renderCache;
        const imei = ref(null);
        const connectionStatus = ref(null);
        const deptId = ref(null);
        const carType = ref(null);
        const deviceName = ref(null);
        const center = reactive({
            latitude: 39.90469,
            longitude: 116.40717
        });
        const mapScale = ref(15);
        const markers = ref([]); // 标记点
        const carMarker = ref(null); // 车辆标记点
        const circles = ref([]); // 圆形围栏
        const carInFence = ref(false); // 车辆是否在围栏内
        // 电子围栏相关状态
        const isDrawing = ref(false);
        const drawingMode = ref('polygon'); // 'polygon' 或 'circle'
        const points = ref([]);
        const polygons = ref([]); // 存储地理围栏多边形数据
        const circleCenter = ref(null);
        const circleRadius = ref(0); // 圆形围栏半径（米）
        const currentSpeed = ref(0);
        const currentAddress = ref('获取中...');
        const currentCar = ref('京A12345');
        const lastDirection = ref(0);
        const showFenceModal = ref(null);
        // 围栏管理状态
        const fenceList = ref([]);
        const selectedFence = ref(null);
        const fencesPopup = ref(null);
        const editDialogPopup = ref(null);
        const editingFence = ref(null);
        const fenceForm = reactive({
            name: '',
            alarmType: '1'
        });
        // 设备绑定状态
        const deviceDialogPopup = ref(null);
        const activeTab = ref('bind');
        const deviceList = ref([]); // 当前显示的设备列表
        const boundDevices = ref([]); // 已绑定设备完整列表
        const currentFenceName = ref('');
        const currentFenceId = ref('');
        const loading = ref(false);
        const scrollTop = ref(0); // 滚动位置控制
        let loadMoreTimer = null; // 防抖定时器
        // 分页控制变量（已绑定/未绑定设备）
        const pagination = reactive({
            bind: {
                pageNum: 1,
                pageSize: 10,
                hasMore: true,
                loadingMore: false // 加载更多中状态
            },
            unbind: {
                pageNum: 1,
                pageSize: 10,
                hasMore: true,
                loadingMore: false
            }
        });
        // 计算当前标签页的分页信息
        const currentPagination = computed(() => {
            return pagination[activeTab.value];
        });
        // 计算是否可以完成绘制
        const canFinishDrawing = computed((): boolean => {
            if (drawingMode.value === 'polygon') {
                return points.value.length >= 3;
            }
            else if (drawingMode.value === 'circle') {
                return circleCenter.value != null && circleRadius.value > 0;
            }
            return false;
        });
        // 计算当前加载更多状态
        const loadingMore = computed(() => {
            return currentPagination.value.loadingMore;
        });
        // 计算是否还有更多数据
        const hasMore = computed(() => {
            return currentPagination.value.hasMore;
        });
        onLoad(async (option) => {
            connectionStatus.value = option["connectionStatus"];
            imei.value = option["imei"];
            currentCar.value = option["plateNo"];
            deptId.value = option["deptId"];
            carType.value = option["carType"];
            deviceName.value = option["deviceName"];
            await loadInitialPosition();
            await loadGeofenceList(); // 页面加载时获取围栏列表
        });
        const loadInitialPosition = async (): Promise<void> => {
            uni.showLoading({
                title: '获取车辆位置中...'
            });
            try {
                const data = { __$originalPosition: new UTSSourceMapPosition("data", "pages/geofencing/geofencing.uvue", 296, 10), deptId: deptId.value, deviceids: imei.value } as UTSJSONObject;
                const res = await getDevicePos(data);
                res.data.forEach(async (item): Promise<void> => {
                    if (item.imei == imei.value) {
                        const deviceData = item;
                        // 转换坐标到腾讯地图坐标系
                        const convertedCoord = CoordTransform.wgs84ToTencent(Number(deviceData.latitude), Number(deviceData.longitude));
                        center["latitude"] = convertedCoord.lat;
                        center["longitude"] = convertedCoord.lng;
                        const position = { __$originalPosition: new UTSSourceMapPosition("position", "pages/geofencing/geofencing.uvue", 310, 12),
                            latitude: convertedCoord.lat,
                            longitude: convertedCoord.lng
                        } as UTSJSONObject;
                        // 记录初始方向
                        lastDirection.value = isTruthy(deviceData.direction) ? deviceData.direction : 0;
                        // 创建车辆标记点
                        carMarker.value = {
                            id: 0,
                            latitude: position["latitude"],
                            longitude: position["longitude"],
                            iconPath: getDeviceIcon(connectionStatus.value, carType.value),
                            width: 25,
                            height: 25,
                            rotate: calculateMapRotation(lastDirection.value),
                            callout: {
                                content: deviceName.value || '爱车位置',
                                color: connectionStatus.value == 'online' ? '#fff' : '#666',
                                bgColor: connectionStatus.value == 'online' ? '#07C160' : '#ccc',
                                padding: 5,
                                borderRadius: 4,
                                display: 'ALWAYS'
                            }
                        };
                        // 更新标记点数组，保留车辆标记点
                        updateMarkers();
                        // 更新车辆信息
                        currentSpeed.value = isTruthy(deviceData.speed) ? deviceData.speed : 0;
                        currentAddress.value = isTruthy(deviceData.positionUpdateTime) ? `最后定位: ${deviceData.positionUpdateTime}`
                            : '未知位置';
                        connectionStatus.value = isTruthy(deviceData.connectionStatus) ? deviceData.connectionStatus : 'unknown';
                    }
                });
            }
            catch (err: any) {
                console.error('获取初始位置失败:', err, " at pages/geofencing/geofencing.uvue:350");
                uni.showToast({
                    title: '获取车辆位置失败',
                    icon: 'none'
                });
            }
            finally {
                uni.hideLoading();
            }
        };
        // 计算地图上的旋转角度（修正方向）
        const calculateMapRotation = (direction): any => {
            let rotation = direction;
            if (rotation >= 360)
                rotation -= 360;
            if (rotation < 0)
                rotation += 360;
            return rotation;
        };
        // 加载围栏列表
        const loadGeofenceList = async (): Promise<void> => {
            try {
                const res = await getGeofenceList();
                if (res.code === 0) {
                    fenceList.value = isTruthy(res.data) ? res.data : [];
                }
                else {
                    uni.showToast({ title: '获取围栏列表失败', icon: 'none' });
                    fenceList.value = []; // 失败时也清空列表
                }
                // 无论数据是否为空，都重新渲染
                renderFencesOnMap();
            }
            catch (error: any) {
                console.error('加载围栏列表失败:', error, " at pages/geofencing/geofencing.uvue:382");
                uni.showToast({ title: '获取围栏列表失败', icon: 'none' });
                fenceList.value = []; // 异常时强制清空
                renderFencesOnMap();
            }
        };
        // 获取围栏类型（根据area字段判断）
        const getFenceType = (fence): any => {
            if (isTruthy(fence.type) && fence.type !== 'null') {
                return fence.type;
            }
            // 根据area字段内容判断围栏类型
            if (isTruthy(fence.area) && isTruthy(fence.area.startsWith('CIRCLE'))) {
                return 'circle';
            }
            else if (isTruthy(fence.area) && isTruthy(fence.area.startsWith('POLYGON'))) {
                return 'polygon';
            }
            return 'polygon'; // 默认多边形
        };
        // 将围栏数据渲染到地图上
        const renderFencesOnMap = () => {
            // 当围栏列表为空时，强制清空地图上所有围栏和标记
            if (!(fenceList.value != null) || fenceList.value.length === 0) {
                polygons.value = []; // 清空多边形围栏
                circles.value = []; // 清空圆形围栏
                updateMarkers(); // 清空围栏相关标记（如顶点、圆心）
                return;
            }
            const fencePolygons = [];
            const fenceCircles = [];
            // 为每个围栏创建多边形或圆形
            fenceList.value.forEach((fence, index) => {
                const fenceType = getFenceType(fence);
                if (fenceType === 'circle') {
                    // 处理圆形围栏
                    const circleData = parseCircle(fence.area);
                    if (isTruthy(circleData)) {
                        // 处理过大半径，避免无法显示
                        const displayRadius = circleData.radius > 100000 ? 100000 : circleData.radius;
                        fenceCircles.push({
                            id: fence.id,
                            latitude: circleData.latitude,
                            longitude: circleData.longitude,
                            radius: displayRadius,
                            strokeWidth: 2,
                            strokeColor: '#FF0000',
                            fillColor: `rgba(255,0,0,0.2)`,
                            zIndex: 1,
                            centerMarker: true
                        });
                    }
                }
                else {
                    // 处理多边形围栏
                    const fencePoints = parsePolygon(fence.area);
                    if (fencePoints.length >= 3) {
                        fencePolygons.push({
                            id: fence.id,
                            points: fencePoints,
                            strokeWidth: 2,
                            strokeColor: '#FF0000',
                            fillColor: index === 0 ? 'rgba(255,0,0,0.2)' : `rgba(${Math.floor(Math.random() * 200)},${Math.floor(Math.random() * 200)},${Math.floor(Math.random() * 200)},0.2)`,
                            zIndex: 1
                        });
                    }
                }
            });
            polygons.value = fencePolygons;
            circles.value = fenceCircles;
            // 确保圆形围栏能显示在地图视野中
            if (fenceCircles.length > 0 && !selectedFence.value) {
                // 自动定位到第一个圆形围栏
                const firstCircle = fenceCircles[0];
                center["latitude"] = firstCircle.latitude;
                center["longitude"] = firstCircle.longitude;
                // 根据半径设置合适的缩放级别
                mapScale.value = calculateZoomLevelFromRadius(firstCircle.radius);
            }
        };
        // 解析POLYGON字符串为坐标数组
        const parsePolygon = (polygonStr): any => {
            if (!isTruthy(polygonStr))
                return [];
            // 去除字符串中的"POLYGON
            const coordStr = polygonStr.replace(/POLYGON \(\(/, '').replace(/\)\)/, '');
            // 按逗号分割坐标点
            const coordPoints = coordStr.split(',');
            return coordPoints.map((point): UTSJSONObject => {
                const [lat, lng] = point.trim().split(' ').map(Number);
                // 转换坐标到腾讯地图坐标系
                const convertedCoord = CoordTransform.wgs84ToTencent(lat, lng);
                return {
                    latitude: convertedCoord.lat,
                    longitude: convertedCoord.lng
                };
            });
        };
        // 解析CIRCLE字符串为圆心和半径
        const parseCircle = (circleStr): UTSJSONObject | null => {
            if (!isTruthy(circleStr) || !isTruthy(circleStr.startsWith('CIRCLE')))
                return null;
            try {
                // 去除字符串中的"CIRCLE
                const coordStr = circleStr.replace(/CIRCLE \(/, '').replace(/\)/, '');
                // 按逗号分割坐标点和半径
                const parts = coordStr.split(',');
                if (parts.length !== 2)
                    return null;
                const [centerStr, radiusStr] = parts;
                const [lat, lng] = centerStr.trim().split(' ').map(Number);
                const radius = Number(radiusStr.trim());
                // 验证数据有效性
                if (isNaN(lat) || isNaN(lng) || isNaN(radius) || radius <= 0) {
                    console.error('无效的圆形围栏数据:', circleStr, " at pages/geofencing/geofencing.uvue:507");
                    return null;
                }
                // 转换坐标到腾讯地图坐标系
                const convertedCoord = CoordTransform.wgs84ToTencent(lat, lng);
                return {
                    latitude: convertedCoord.lat,
                    longitude: convertedCoord.lng,
                    radius: radius
                };
            }
            catch (error: any) {
                console.error('解析圆形围栏失败:', error, '数据:', circleStr, " at pages/geofencing/geofencing.uvue:520");
                return null;
            }
        };
        // 生成POLYGON字符串
        const generatePolygonString = (points): string => {
            const coords = points.map((point): string => {
                const originalCoord = CoordTransform.tencentToWgs84(point.latitude, point.longitude);
                return `${originalCoord.lat} ${originalCoord.lng}`;
            }).join(', ');
            return `POLYGON ((${coords}))`;
        };
        // 生成CIRCLE字符串
        const generateCircleString = (center, radius): string => {
            const originalCoord = CoordTransform.tencentToWgs84(center.latitude, center.longitude);
            return `CIRCLE (${originalCoord.lat} ${originalCoord.lng}, ${radius})`;
        };
        // 调整地图中心到围栏中心位置
        const setMapCenterToFence = (fence) => {
            const fenceType = getFenceType(fence);
            if (fenceType === 'circle') {
                const circleData = parseCircle(fence.area);
                if (isTruthy(circleData)) {
                    center["latitude"] = circleData.latitude;
                    center["longitude"] = circleData.longitude;
                    // 处理过大半径，设置合理的缩放级别
                    const displayRadius = circleData.radius > 100000 ? 100000 : circleData.radius;
                    // 根据半径调整缩放级别
                    mapScale.value = calculateZoomLevelFromRadius(displayRadius);
                }
            }
            else {
                const fencePoints = parsePolygon(fence.area);
                if (fencePoints.length === 0)
                    return;
                // 计算中心点
                let totalLat = 0;
                let totalLng = 0;
                fencePoints.forEach(point => {
                    totalLat += point.latitude;
                    totalLng += point.longitude;
                });
                center["latitude"] = totalLat / fencePoints.length;
                center["longitude"] = totalLng / fencePoints.length;
                // 根据围栏大小自动调整缩放级别
                const bounds = calculateBounds(fencePoints);
                const latDiff = bounds["maxLat"] - bounds["minLat"];
                const lngDiff = bounds["maxLng"] - bounds["minLng"];
                const maxDiff = Math.max(latDiff, lngDiff);
                if (maxDiff > 0.1)
                    mapScale.value = 11;
                else if (maxDiff > 0.05)
                    mapScale.value = 12;
                else if (maxDiff > 0.02)
                    mapScale.value = 13;
                else
                    mapScale.value = 14;
            }
        };
        // 根据半径计算合适的缩放级别
        const calculateZoomLevelFromRadius = (radius): number => {
            if (radius > 50000)
                return 8; // 50公里以上
            if (radius > 20000)
                return 9; // 20-50公里
            if (radius > 10000)
                return 10; // 10-20公里
            if (radius > 5000)
                return 11; // 5-10公里
            if (radius > 2000)
                return 12; // 2-5公里
            if (radius > 1000)
                return 13; // 1-2公里
            if (radius > 500)
                return 14; // 500米-1公里
            if (radius > 200)
                return 15; // 200-500米
            return 16; // 200米以下
        };
        // 计算坐标边界
        const calculateBounds = (points): UTSJSONObject => {
            let minLat = points[0].latitude;
            let maxLat = points[0].latitude;
            let minLng = points[0].longitude;
            let maxLng = points[0].longitude;
            points.forEach(point => {
                minLat = Math.min(minLat, point.latitude);
                maxLat = Math.max(maxLat, point.latitude);
                minLng = Math.min(minLng, point.longitude);
                maxLng = Math.max(maxLng, point.longitude);
            });
            return { minLat, maxLat, minLng, maxLng };
        };
        // 显示围栏列表
        const showFenceList = () => {
            fencesPopup.value?.open();
        };
        // 选择围栏
        const selectFence = (fence) => {
            selectedFence.value = fence;
            fencesPopup.value?.close();
            showFenceModal.value?.open();
            // 根据围栏类型显示
            const fenceType = getFenceType(fence);
            if (fenceType === 'circle') {
                const circleData = parseCircle(fence.area);
                if (isTruthy(circleData)) {
                    circleCenter.value = { latitude: circleData.latitude, longitude: circleData.longitude };
                    circleRadius.value = circleData.radius;
                    points.value = [];
                }
            }
            else {
                const fencePoints = parsePolygon(fence.area);
                points.value = fencePoints;
                circleCenter.value = null;
                circleRadius.value = 0;
            }
            setMapCenterToFence(fence);
            updateMapDisplay();
        };
        // 编辑围栏
        const editFence = (fence) => {
            editingFence.value = fence;
            fenceForm["name"] = fence.name;
            fenceForm["alarmType"] = fence.alarmType.toString();
            // 设置当前绘制模式为围栏实际类型
            drawingMode.value = getFenceType(fence);
            editDialogPopup.value?.open();
        };
        // 删除围栏
        const deleteFence = async (id): Promise<void> => {
            uni.showModal({
                title: '确认删除',
                content: '确定要删除这个围栏吗？',
                success: async (res) => {
                    if (res.confirm) {
                        try {
                            const result = await deleteGeofence(id);
                            if (result.code === 0) {
                                uni.showToast({ title: '删除成功' });
                                selectedFence.value = null; // 取消选中围栏
                                points.value = []; // 清空多边形顶点
                                circleCenter.value = null; // 清空圆形圆心
                                circleRadius.value = 0; // 清空圆形半径
                                isDrawing.value = false; // 退出绘制模式
                                polygons.value = [];
                                circles.value = [];
                                updateMarkers();
                                showFenceModal.value?.close(); // 清空围栏标记
                                await loadGeofenceList();
                            }
                            else {
                                uni.showToast({ title: '删除失败', icon: 'none' });
                            }
                        }
                        catch (error: any) {
                            console.error('删除围栏失败:', error, " at pages/geofencing/geofencing.uvue:682");
                            uni.showToast({ title: '删除失败', icon: 'none' });
                        }
                    }
                }
            });
        };
        // 保存围栏
        const saveFence = async (): Promise<void> => {
            if (!(fenceForm["name"] != "")) {
                uni.showToast({ title: '请输入围栏名称', icon: 'none' });
                return;
            }
            let area = '';
            if (drawingMode.value === 'polygon' && points.value.length < 3) {
                uni.showToast({ title: '请绘制有效的围栏区域', icon: 'none' });
                return;
            }
            else if (drawingMode.value === 'circle' && (!circleCenter.value || circleRadius.value <= 0)) {
                uni.showToast({ title: '请绘制有效的圆形围栏', icon: 'none' });
                return;
            }
            // 根据绘制模式生成不同的区域字符串
            if (drawingMode.value === 'polygon') {
                area = generatePolygonString(points.value);
            }
            else if (drawingMode.value === 'circle' && circleCenter.value) {
                area = generateCircleString(circleCenter.value, circleRadius.value);
            }
            const fenceData = { __$originalPosition: new UTSSourceMapPosition("fenceData", "pages/geofencing/geofencing.uvue", 713, 9),
                name: fenceForm["name"],
                area: area,
                alarmType: parseInt(fenceForm["alarmType"]),
                type: drawingMode.value } as UTSJSONObject;
            try {
                let result;
                if (editingFence.value) {
                    result = await updateGeofence({ id: editingFence.value!.id, ...fenceData });
                }
                else {
                    result = await addGeofence(fenceData);
                }
                if (result.code === 0) {
                    uni.showToast({ title: '保存成功' });
                    editDialogPopup.value?.close();
                    editingFence.value = null;
                    isDrawing.value = false;
                    loadGeofenceList(); // 重新加载围栏列表
                }
                else {
                    uni.showToast({ title: '保存失败', icon: 'none' });
                }
            }
            catch (error: any) {
                console.error('保存围栏失败:', error, " at pages/geofencing/geofencing.uvue:738");
                uni.showToast({ title: '保存失败', icon: 'none' });
            }
        };
        // 显示绑定设备对话框
        const showBindDevices = async (fenceId): Promise<void> => {
            currentFenceId.value = fenceId;
            currentFenceName.value = selectedFence.value.name;
            deviceDialogPopup.value?.open();
            activeTab.value = 'bind';
            scrollTop.value = 0;
            // 初始化分页状态并加载第一页
            initPagination('bind');
            await loadBoundDevices(fenceId);
        };
        // 关闭设备绑定弹窗
        const closeDeviceDialog = () => {
            deviceDialogPopup.value?.close();
            scrollTop.value = 0;
        };
        // 切换标签页
        // 切换标签页
        const switchTab = async (tab): Promise<void> => {
            if (activeTab.value === tab)
                return;
            activeTab.value = tab;
            scrollTop.value = 0;
            deviceList.value = []; // 清空列表
            // 重置分页
            initPagination(tab);
            // 加载对应数据
            if (tab === 'bind') {
                await loadBoundDevices(currentFenceId.value);
            }
            else {
                await loadUnboundDevices();
            }
        };
        // 初始化分页状态
        const initPagination = (tabType) => {
            pagination[tabType] = {
                pageNum: 1,
