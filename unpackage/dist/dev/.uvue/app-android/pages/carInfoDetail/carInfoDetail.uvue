            }
            const signalValue = Number(rssi);
            if (isNaN(signalValue)) {
                return {
                    experience: "信号数据无效",
                    quality: "无服务",
                    color: "#999",
                    level: 0
                };
            }
            // 根据图片规则判断信号等级
