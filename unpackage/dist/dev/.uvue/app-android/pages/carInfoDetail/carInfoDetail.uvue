                // 恢复油电
                if (userType.value == '1') {
                    // 需要密码验证
                    psw.value = '';
                    currentOperation.value = 1;
                    modalTitle.value = '验证密码';
                    popupRef.value = true;
                }
                else {
                    // 不需要密码验证，直接执行操作
                    executeOperation(1);
                }
            }
            if (itemTo == '断开油电') {
                // 断开油电
