                const success = await loadData({
                    deptId: deptId.value,
                    deviceids: imei.value
                });
                if (isTruthy(success)) {
                    // 手动刷新后强制更新地图
                    setTimeout(() => {
                        refreshMapView();
                    }, 300);
                    uni.showToast({
                        title: '刷新成功',
                        icon: 'success'
