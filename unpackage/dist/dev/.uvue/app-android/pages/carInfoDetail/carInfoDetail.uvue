                // 恢复油电
                predictCmdId = 2;
                type = 2;
            }
            else if (operationType == 2) {
                // 断开油电
                predictCmdId = 1;
                type = 1;
            }
            else {
                uni.showToast({
                    title: '操作类型错误',
                    icon: 'none'
                });
                return;
            }
            try {
                // 显示加载中
                uni.showLoading({
                    title: '执行中...',
                    mask: true
                });
                // 调用接口
                const res = await sendCommand({
                    imei: imei.value,
                    password: userType.value == '1' ? psw.value : '',
