                    predictCmdId: predictCmdId,
                    type: type
                });
                // 隐藏加载中
                uni.hideLoading();
                // 根据响应处理结果
                if (res.code == 0) {
                    uni.showToast({
                        title: operationType == 1 ? '恢复油电成功' : '断开油电成功',
                        icon: 'success'
                    });
                    // 清空密码
                    psw.value = '';
