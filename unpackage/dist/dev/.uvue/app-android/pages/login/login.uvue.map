<template>
	<view class="container">
		<custom-navBar title="зҷ»йҷҶ" :show-back="false" backgroundColor="#fff" textColor="#333" :showCapsule="false">
		</custom-navBar>
		<view class="banner">
			<image src="/static/car_location.png" mode="aspectFill"></image>
			<text class="title">иҪҰиҒ”зҪ‘</text>
		</view>

		<view class="content">
			<view v-if="pswLogin">
				<i-form 
					ref="formRef" 
					:modelValue="form" 
					:rules="pswrules" 
					labelDirection="horizontal"
					watchValidStatus
					@update:modelValid="formValid = $event"
				>
					<i-form-item name="username" label="" required labelDirection="horizontal" labelWidth="0">
						<i-input 
							v-model="form.username" 
							placeholder="иҜ·иҫ“е…ҘиҙҰеҸ·" 
							clearable
							prefixIcon="account-fill"
						/>
					</i-form-item>
					
					<i-form-item name="password" label="" required labelDirection="horizontal" labelWidth="0">
						<i-input 
							v-model="form.password" 
							@input="filterNonLatin" 
							placeholder="иҜ·иҫ“е…ҘеҜҶз Ғ"
							:password="true"
						>
						</i-input>
					</i-form-item>

					<!-- и®°дҪҸеҜҶз Ғ -->
					<view class="remember-password">
						<i-checkbox 
							:checked="rememberPassword" 
							@change="toggleRememberPassword"
							label="и®°дҪҸеҜҶз Ғ"
						>
							
						</i-checkbox>
					</view>
					
					<!-- жҸҗдәӨжҢүй’® -->
					<i-button type="primary" @click="submit" :loading="loading">жҸҗдәӨ</i-button>
				</i-form>
			</view>

			<!-- дёӘдәәз”ЁжҲ·зҷ»еҪ•пјҲеҫ®дҝЎзҷ»еҪ•пјү -->
			<view v-else>
				<button v-if="!docState" type="primary" plain="true" @click="loginBt">
					дёӘдәәз”ЁжҲ·зҷ»еҪ•
				</button>
				<button open-type="getPhoneNumber" v-if="docState" type="primary" plain="true"
					@getphonenumber="handleGetPhoneNumber">
					дёӘдәәз”ЁжҲ·зҷ»еҪ•
				</button>
			</view>

			<!-- з”ЁжҲ·еҚҸи®® -->
			<view class="documents">
				<i-checkbox :checked="docState" @change="isDocState">
					<view class="doc-info-box">
						е·Ійҳ…иҜ»е№¶еҗҢж„Ҹ<text class="doc-link" @click="gotoAgreement">гҖҠз”ЁжҲ·еҚҸи®®гҖӢ</text>е’Ң<text class="doc-link" @click="gotoPrivacy">гҖҠйҡҗз§Ғж”ҝзӯ–гҖӢ</text>
					</view>
				</i-checkbox>
			</view>
		</view>
		
		<view class="other-way">
			<view class="noLogin" @click="gotoIndex">жҡӮдёҚзҷ»еҪ•</view>
			<view class="BLogin" @click="isPswLogin">{{pswLogin ? 'дёӘдәәз”ЁжҲ·зҷ»еҪ•' : 'дјҒдёҡз”ЁжҲ·зҷ»еҪ•'}}</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref, onMounted, nextTick } from 'vue'
	import { login, PostWechatlogin } from '../../api/request.uts'

	const docState = ref(false)
	const pswLogin = ref(false) // true: дјҒдёҡз”ЁжҲ·зҷ»еҪ•(иҙҰеҸ·еҜҶз Ғ), false: дёӘдәәз”ЁжҲ·зҷ»еҪ•(еҫ®дҝЎ)
	const rememberPassword = ref(false)
	const formValid = ref(false)
	const loading = ref(false)

	// ===== иЎЁеҚ•ж•°жҚ® =====
	type FormData = {
		username: string
		password: string
	}

	const form = ref<FormData>({
		username: '',
		password: ''
	})

	// ===== иЎЁеҚ•еј•з”Ё =====
	// дҪҝз”Ё any зұ»еһӢйҒҝе…Қзұ»еһӢеҶІзӘҒ
	const formRef = ref<any>(null)
	const deviceModel = ref('')

	// ===== иЎЁеҚ•йӘҢиҜҒи§„еҲҷ =====
	const pswrules = {
		username: [
			{
				required: true,
				message: 'иҜ·иҫ“е…ҘиҙҰеҸ·',
				trigger: ['blur', 'change']
			}
		],
		password: [
			{
				required: true,
				message: 'иҜ·иҫ“е…ҘеҜҶз Ғ',
				trigger: ['blur', 'change']
			}
		]
	}

	// ===== ж ёеҝғеҠҹиғҪеҮҪж•° =====

	// еҲҮжҚўдјҒдёҡ/дёӘдәәзҷ»еҪ•
	const isPswLogin = () => {
		pswLogin.value = !pswLogin.value
		if (pswLogin.value) {
			// еҲҮжҚўеҲ°дјҒдёҡзҷ»еҪ•ж—¶пјҢеҠ иҪҪдҝқеӯҳзҡ„иҙҰеҸ·
			setTimeout(() => {
				loadSavedAccount()
			}, 100)
		}
	}

	// и®°дҪҸеҜҶз ҒеҲҮжҚў
	const toggleRememberPassword = () => {
		rememberPassword.value = !rememberPassword.value
		if (!rememberPassword.value) {
			uni.removeStorageSync('savedEnterpriseAccount')
		}
	}

	// дҝқеӯҳиҙҰеҸ·еҜҶз Ғ
	const saveAccountPassword = () => {
		if (rememberPassword.value && form.value.username && form.value.password) {
			const accountInfo = {
				username: form.value.username,
				password: form.value.password,
			}
			uni.setStorageSync('savedEnterpriseAccount', accountInfo)
		} else if (!rememberPassword.value) {
			uni.removeStorageSync('savedEnterpriseAccount')
		}
	}

	// еҠ иҪҪдҝқеӯҳзҡ„иҙҰеҸ·еҜҶз Ғ
	const loadSavedAccount = () => {
		try {
			const savedAccount = uni.getStorageSync('savedEnterpriseAccount')
			if (savedAccount) {
				form.value.username = savedAccount.username || ''
				form.value.password = savedAccount.password || ''
				rememberPassword.value = true
			}
		} catch (error) {
			console.error('еҠ иҪҪдҝқеӯҳзҡ„иҙҰеҸ·еҜҶз ҒеӨұиҙҘ:', error)
		}
	}

	// еҜҶз ҒиҝҮж»ӨпјҲеҸӘе…Ғи®ёASCIIеӯ—з¬Ұпјү
	const filterNonLatin = (e: any) => {
		form.value.password = e.replace(/[^\x00-\x7F]/g, '')
	}

	// з”ЁжҲ·еҚҸи®®еӢҫйҖү
	const isDocState = () => {
		docState.value = !docState.value
	}

	// иҺ·еҸ–зі»з»ҹдҝЎжҒҜ
	const getSystemInfo = () => {
		const res = uni.getSystemInfoSync()
		deviceModel.value = res.deviceModel
		console.log('и®ҫеӨҮеһӢеҸ·:', deviceModel.value)
	}

	// ===== иЎЁеҚ•йӘҢиҜҒ - зӣҙжҺҘдҪҝз”Ё i-form зҡ„ validate ж–№жі• =====
	const validateForm = (): Promise<boolean> => {
		return new Promise((resolve, reject) => {
			console.log('ејҖе§ӢйӘҢиҜҒиЎЁеҚ•, formRef.value:', formRef.value)
			
			if (!formRef.value) {
				console.error('иЎЁеҚ•е®һдҫӢдёәз©ә')
				reject(new Error('иЎЁеҚ•е®һдҫӢдёҚеӯҳеңЁ'))
				return
			}
			
			// жЈҖжҹҘжҳҜеҗҰжңү validate ж–№жі•
			if (typeof formRef.value.validate !== 'function') {
				console.error('validate ж–№жі•дёҚеӯҳеңЁпјҢе°қиҜ•дҪҝз”Ёе…¶д»–ж–№жі•')
				// жңүдәӣзүҲжң¬еҸҜиғҪдҪҝз”ЁдёҚеҗҢж–№жі•еҗҚ
				if (typeof formRef.value.validateForm === 'function') {
					formRef.value.validateForm((valid: boolean) => {
						console.log('validateForm йӘҢиҜҒз»“жһң:', valid)
						if (valid) {
							resolve(true)
						} else {
							reject(new Error('иЎЁеҚ•йӘҢиҜҒеӨұиҙҘ'))
						}
					})
					return
				}
				reject(new Error('иЎЁеҚ•йӘҢиҜҒж–№жі•дёҚеӯҳеңЁ'))
				return
			}
			
			// и°ғз”Ё validate ж–№жі•
			try {
				const result = formRef.value.validate()
				console.log('validate еҗҢжӯҘиҝ”еӣһ:', result)
				
				// еҰӮжһңиҝ”еӣһзҡ„жҳҜ Promise
				if (result && typeof result.then === 'function') {
					result.then((valid: boolean) => {
						console.log('validate Promise з»“жһң:', valid)
						if (valid) {
							resolve(true)
						} else {
							reject(new Error('иЎЁеҚ•йӘҢиҜҒеӨұиҙҘ'))
						}
					}).catch((err: any) => {
						console.error('validate Promise й”ҷиҜҜ:', err)
						reject(err)
					})
					return
				}
				
				// еҰӮжһңиҝ”еӣһзҡ„жҳҜ boolean
				if (typeof result === 'boolean') {
					if (result) {
						resolve(true)
					} else {
						reject(new Error('иЎЁеҚ•йӘҢиҜҒеӨұиҙҘ'))
					}
					return
				}
				
				// еҰӮжһңдҪҝз”Ёеӣһи°ғж–№ејҸ
				formRef.value.validate((valid: boolean, errors?: any[]) => {
					console.log('validate еӣһи°ғз»“жһң:', valid, errors)
					if (valid) {
						resolve(true)
					} else {
						reject(errors || new Error('иЎЁеҚ•йӘҢиҜҒеӨұиҙҘ'))
					}
				})
				
			} catch (error) {
				console.error('йӘҢиҜҒжү§иЎҢејӮеёё:', error)
				reject(error)
			}
		})
	}

	// ===== зҷ»еҪ•зӣёе…іеҮҪж•° =====

	// дёӘдәәз”ЁжҲ·зҷ»еҪ•пјҲеҫ®дҝЎпјү
	const loginBt = () => {
		if (!docState.value) {
			uni.showToast({
				title: 'иҜ·е…Ҳйҳ…иҜ»е№¶еҗҢж„Ҹз”ЁжҲ·еҚҸи®®',
				icon: 'error'
			})
			return
		}
	}

	// еҫ®дҝЎзҷ»еҪ•еӨ„зҗҶ
	const handleGetPhoneNumber = async (e: any) => {
		if (!docState.value) {
			uni.showToast({
				title: 'иҜ·е…Ҳйҳ…иҜ»е№¶еҗҢж„Ҹз”ЁжҲ·еҚҸи®®',
				icon: 'error'
			})
			return
		}

		if (e.detail.errMsg === 'getPhoneNumber:fail user deny') {
			uni.showToast({
				title: 'жӮЁжӢ’з»қдәҶжҺҲжқғ',
				icon: 'none'
			})
			return
		}

		if (e.detail.errMsg !== 'getPhoneNumber:ok') {
			uni.showToast({
				title: 'иҺ·еҸ–жүӢжңәеҸ·еӨұиҙҘ',
				icon: 'none'
			})
			return
		}

		try {
			uni.showLoading({ title: 'зҷ»еҪ•дёӯ...' })

			const loginRes = await new Promise<UniApp.LoginRes>((resolve, reject) => {
				uni.login({
					provider: 'weixin',
					success: resolve,
					fail: reject
				})
			})

			const res = await PostWechatlogin({
				code: loginRes.code,
				encryptedData: e.detail.encryptedData,
				iv: e.detail.iv
			})

			if (!res || !res.data) {
				uni.showToast({
					title: res?.msg || 'зҷ»еҪ•еӨұиҙҘ',
					icon: 'none'
				})
				return
			}

			if (!res.data.token) {
				uni.showToast({
					title: 'зҷ»еҪ•еӨұиҙҘ: жңӘиҺ·еҸ–еҲ°token',
					icon: 'none'
				})
				return
			}

			uni.setStorageSync('token', res.data.token)
			uni.showToast({
				title: 'зҷ»еҪ•жҲҗеҠҹ',
				icon: 'success'
			})
			setTimeout(() => {
				uni.reLaunch({
					url: '/pages/index/index'
				})
			}, 500)

		} catch (error) {
			console.error('еҫ®дҝЎзҷ»еҪ•еӨұиҙҘ:', error)
			uni.showToast({
				title: 'еҫ®дҝЎзҷ»еҪ•еӨұиҙҘ',
				icon: 'none'
			})
		} finally {
			uni.hideLoading()
		}
	}

	// жҸҗдәӨзҷ»еҪ•пјҲиҙҰеҸ·еҜҶз Ғпјү
	const submit = async () => {
		
		if (!docState.value) {
			uni.showToast({
				title: 'иҜ·е…Ҳйҳ…иҜ»е№¶еҗҢж„Ҹз”ЁжҲ·еҚҸи®®',
				icon: 'error'
			})
			return
		}
		
		try {
			// иЎЁеҚ•йӘҢиҜҒ
			console.log('еҮҶеӨҮйӘҢиҜҒиЎЁеҚ•...')
			await validateForm()
			console.log('вң… иЎЁеҚ•йӘҢиҜҒйҖҡиҝҮ')
			
			// жһ„е»әиҜ·жұӮеҸӮж•°
			const newFormData = {
				username: form.value.username,
				password: form.value.password,
				from: deviceModel.value,
				type: "USER"
			}
			console.log('рҹ“Ө иҜ·жұӮеҸӮж•°:', newFormData)
			
			// жҳҫзӨәеҠ иҪҪзҠ¶жҖҒ
			loading.value = true
			uni.showLoading({
				title: 'зҷ»еҪ•дёӯ...',
				mask: true
			})
			
			// и°ғз”Ёзҷ»еҪ•жҺҘеҸЈ
			console.log('рҹҡҖ ејҖе§Ӣи°ғз”Ё login жҺҘеҸЈ...')
			const res = await login(newFormData)
			console.log('вң… зҷ»еҪ•жҺҘеҸЈиҝ”еӣһ:', res)
			
			// йҡҗи—ҸеҠ иҪҪзҠ¶жҖҒ
			loading.value = false
			uni.hideLoading()
			
			// еӨ„зҗҶзҷ»еҪ•жҲҗеҠҹ
			if (res && res.data && res.data.token) {
				saveAccountPassword()
				uni.setStorageSync('token', res.data.token)
				uni.showToast({
					title: 'зҷ»еҪ•жҲҗеҠҹ',
					icon: 'success'
				})
				setTimeout(() => {
					uni.reLaunch({
						url: '/pages/index/index'
					})
				}, 500)
			} else {
				uni.showToast({
					title: res?.msg || 'зҷ»еҪ•еӨұиҙҘпјҢиҜ·йҮҚиҜ•',
					icon: 'error'
				})
			}
			
		} catch (error: any) {
			console.error('вқҢ зҷ»еҪ•еӨұиҙҘ:', error)
			loading.value = false
			uni.hideLoading()
			
			// еҲӨж–ӯжҳҜйӘҢиҜҒй”ҷиҜҜиҝҳжҳҜжҺҘеҸЈй”ҷиҜҜ
			if (error && error.message) {
				uni.showToast({
					icon: 'error',
					title: error.message || 'иҜ·еЎ«еҶҷжӯЈзЎ®зҡ„иҙҰеҸ·еҜҶз Ғ'
				})
			} else {
				uni.showToast({
					icon: 'error',
					title: 'зҷ»еҪ•еӨұиҙҘпјҢиҜ·жЈҖжҹҘзҪ‘з»ңеҗҺйҮҚиҜ•'
				})
			}
		}
	}

	// и·іиҪ¬еҲ°йҰ–йЎө
	const gotoIndex = () => {
		uni.reLaunch({
			url: '/pages/index/index'
		})
	}

	// ===== еҚҸи®®еј№зӘ— =====
	const gotoAgreement = () => {
		uni.showModal({
			title: 'з”ЁжҲ·еҚҸи®®',
			content: userAgreement,
			showCancel: false,
		})
	}

	const gotoPrivacy = () => {
		uni.showModal({
			title: 'йҡҗз§Ғж”ҝзӯ–',
			content: privacyPolicy,
			showCancel: false,
		})
	}

	// ===== з”ҹе‘Ҫе‘Ёжңҹ =====
	onMounted(() => {
		getSystemInfo()
		loadSavedAccount()
		console.log('pswLogin еҲқе§ӢеҖј:', pswLogin.value)
		console.log('formRef еҲқе§ӢеҖј:', formRef.value)
		
		// е»¶иҝҹжЈҖжҹҘ formRef
		setTimeout(() => {
			console.log('е»¶иҝҹжЈҖжҹҘ formRef.value:', formRef.value)
			if (formRef.value) {
				console.log('formRef зҡ„ж–№жі•:', Object.keys(formRef.value))
			}
		}, 500)
	})

	// ===== еҚҸи®®еҶ…е®№ =====
	const userAgreement = `
ж¬ўиҝҺдҪҝз”ЁиҪҰиҒ”зҪ‘е№іеҸ°пјҒ

дёҖгҖҒжңҚеҠЎжқЎж¬ҫзҡ„зЎ®и®Өе’ҢжҺҘзәі
жң¬еҚҸи®®жҳҜжӮЁдёҺиҪҰиҒ”зҪ‘е№іеҸ°д№Ӣй—ҙе…ідәҺдҪҝз”Ёе№іеҸ°жңҚеҠЎзҡ„еҚҸи®®гҖӮжӮЁдҪҝз”Ёе№іеҸ°жңҚеҠЎеҚіиЎЁзӨәжӮЁе·Ійҳ…иҜ»е№¶еҗҢж„Ҹжң¬еҚҸи®®зҡ„е…ЁйғЁжқЎж¬ҫгҖӮ

дәҢгҖҒжңҚеҠЎеҶ…е®№
1. иҪҰиҒ”зҪ‘е№іеҸ°жҸҗдҫӣиҪҰиҫҶз®ЎзҗҶгҖҒиҝңзЁӢжҺ§еҲ¶гҖҒж•°жҚ®еҲҶжһҗзӯүжңҚеҠЎгҖӮ
2. е№іеҸ°дҝқз•ҷйҡҸж—¶еҸҳжӣҙгҖҒдёӯж–ӯжҲ–з»ҲжӯўйғЁеҲҶжҲ–е…ЁйғЁзҪ‘з»ңжңҚеҠЎзҡ„жқғеҲ©гҖӮ

дёүгҖҒз”ЁжҲ·иҙҰеҸ·
з”ЁжҲ·еә”еҜ№е…¶иҙҰеҸ·зҡ„е…ЁйғЁиЎҢдёәиҙҹиҙЈпјҢдёҚеҫ—е°ҶиҙҰеҸ·иҪ¬и®©жҲ–еҮәеҖҹз»ҷд»–дәәдҪҝз”ЁгҖӮ

еӣӣгҖҒз”ЁжҲ·йҡҗз§ҒдҝқжҠӨ
дҝқжҠӨз”ЁжҲ·йҡҗз§ҒжҳҜе№іеҸ°зҡ„дёҖйЎ№еҹәжң¬ж”ҝзӯ–пјҢиҜҰжғ…иҜ·еҸӮйҳ…гҖҠйҡҗз§Ғж”ҝзӯ–гҖӢгҖӮ

дә”гҖҒе…ҚиҙЈеЈ°жҳҺ
1. е№іеҸ°дёҚдҝқиҜҒжңҚеҠЎдёҖе®ҡиғҪж»Ўи¶із”ЁжҲ·зҡ„иҰҒжұӮпјҢд№ҹдёҚдҝқиҜҒжңҚеҠЎдёҚдјҡдёӯж–ӯгҖӮ
2. еҜ№дәҺеӣ дёҚеҸҜжҠ—еҠӣйҖ жҲҗзҡ„жңҚеҠЎдёӯж–ӯпјҢе№іеҸ°дёҚжүҝжӢ…иҙЈд»»гҖӮ

е…ӯгҖҒжі•еҫӢйҖӮз”Ё
