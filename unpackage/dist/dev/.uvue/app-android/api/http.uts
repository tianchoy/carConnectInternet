// 错误处理
function errorHandler(error: HttpError, config: RequestOptions): void {
    // 隐藏加载中
    if (config.showLoading !== false) {
        uni.hideLoading();
    }
    __f__('log', 'at api/http.uts:107', '请求错误详情:', error);
    // 处理错误状态码
    if (error.statusCode) {
        switch (error.statusCode) {
            case 401:
                handleTokenExpired();
                break;
            case 403:
                uni.showToast({
                    title: '没有权限访问',
                    icon: 'none'
                });
                break;
            case 404:
                uni.showToast({
                    title: '请求资源不存在',
                    icon: 'none'
                });
                break;
            case 500:
                uni.showToast({
                    title: '服务器错误',
                    icon: 'none'
                });
                break;
            default:
                uni.showToast({
                    title: error.message || `请求错误: ${error.statusCode}`,
                    icon: 'none'
                });
        }
    }
    else {
        // 网络错误等
        uni.showToast({
            title: '网络错误，请检查网络连接',
            icon: 'none'
        });
    }
}
