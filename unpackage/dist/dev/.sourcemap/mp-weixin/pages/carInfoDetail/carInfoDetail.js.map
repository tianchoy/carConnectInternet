<template>
	<view class="container">
		<custom-navBar title="иҜҰжғ…" :show-back="true" backgroundColor="#fff" textColor="#333" :showCapsule="false">
		</custom-navBar>
		<view class="map-container">
			<map id="myMap" :latitude="center.latitude" :longitude="center.longitude" :markers="markers"
				:scale="mapScale" style="width:100%;height:100%" :show-location="true">
				<sub-navBar :currentTime="currentTime" :showTime="true"
					@update:current-time="(val) => (currentTime = val)" :currentCar="currentCarInfo.plateNo"
					:times="times" :carStatus="datainfo.connectionStatus" :showPicker="false"
					:showCar="true"></sub-navBar>
			</map>
		</view>

		<view class="tools-panel">
			<view class="Imei-box" @click="carDetail">
				<view class="imei-info">
					<view class="imeis">
						<text>IMEI {{imei}}</text>
						<text class="pos-time">е®ҡдҪҚж—¶й—ҙ {{datainfo.positionUpdateTime}}</text>
					</view>
					<uv-icon name="arrow-right" :bold="true" :size="16"></uv-icon>
				</view>
				<view class="addree-box" v-if="address">еҪ“еүҚең°еқҖпјҡ{{address}}</view>
				<!-- дҝЎеҸ·ејәеәҰжҳҫзӨәеҢәеҹҹ -->
				<view class="signal-container" v-if="currentCarInfo.attribute?.rssi || currentCarInfo.attribute?.sat">
					<view v-if="currentCarInfo.attribute?.rssi" class="signal-item">
						<view class="mobile-signal">
							<view class="signal-bars-horizontal"
								:style="{ '--signal-color': getSignalDetail(currentCarInfo.attribute?.rssi).color }">
								<view class="signal-bar-h"
									:class="getMobileSignalBarClass(0, currentCarInfo.attribute?.rssi)"></view>
								<view class="signal-bar-h"
									:class="getMobileSignalBarClass(1, currentCarInfo.attribute?.rssi)"></view>
								<view class="signal-bar-h"
									:class="getMobileSignalBarClass(2, currentCarInfo.attribute?.rssi)"></view>
								<view class="signal-bar-h"
									:class="getMobileSignalBarClass(3, currentCarInfo.attribute?.rssi)"></view>
								<view class="signal-bar-h"
									:class="getMobileSignalBarClass(4, currentCarInfo.attribute?.rssi)"></view>
							</view>
							<view class="signal-info-h">
								<text class="experience"
									:style="{ color: getSignalDetail(currentCarInfo.attribute?.rssi).color }">
									{{getSignalDetail(currentCarInfo.attribute?.rssi).experience}}
								</text>
								<text class="signal-value" :style="{ color: getSignalDetail(currentCarInfo.attribute?.rssi).color }">{{currentCarInfo.attribute?.rssi}} CSQ</text>
							</view>
						</view>
					</view>
					<view v-if="currentCarInfo.attribute?.sat" class="satellite-item-h">
						<image class="satellite-icon" src="/static/sate.png"></image>
						<text class="satellite-text">{{currentCarInfo.attribute?.sat}}</text>
					</view>
					<view class="power" v-if="currentCarInfo.voltage">
						<image src="/static/v.png" />
						<text>{{currentCarInfo.voltage}}V</text>
					</view>
					<view class="battery" v-if="datainfo.batteryPercent"
						:style="{ color: getBatteryColor(datainfo.batteryPercent) }">
						<image src="/static/pow.png" alt="" />
						<text>{{datainfo.batteryPercent}}%</text>
					</view>
				</view>
			</view>
			<uv-grid :col="5">
				<uv-grid-item v-for="(item,index) in baseList" :key="index"  @click="click(item)">
					<uv-icon :customStyle="{paddingTop:20+'rpx'}" :name="item.name" :size="45"></uv-icon>
					<text class="grid-text">{{item.title}}</text>
				</uv-grid-item>
			</uv-grid>
		</view>

		<view>
			<uv-modal ref="popupRef" :title="modalTitle" @confirm="confirm">
				<view>
					<uv-input placeholder="иҜ·иҫ“е…ҘиҙҰжҲ·еҜҶз Ғ" prefixIcon="lock" border="surround" clearable :password="true"
						v-model="psw"></uv-input>
				</view>
			</uv-modal>
		</view>
	</view>
</template>
<script setup lang="uts">
	import { getDevicePos, getUserDeviceList, getDeviceDetail, sendCommand } from '../../api/request.uts'
	import { getAddress } from '../../utils/getAdress.uts'
	import { getOnlineDeviceIcon, getOfflineDeviceIcon } from '../../utils/cars'
	// еҜје…Ҙеқҗж ҮиҪ¬жҚўжҸ’д»¶
	import CoordTransform from '../../utils/coordTransform.uts'

	const deptId = ref<string | null>('')
	const imei = ref<string | null>('')
	const deviceId = ref<string | null>('')
	// ең°еӣҫзҠ¶жҖҒ
	const center = reactive({
		latitude: 39.90469,
		longitude: 116.40717
	})
	const mapScale = ref(15)
	const datainfo = ref<object>({})
	const address = ref('')
	const currentTime = ref('5s')
	const times = ref([
		[
			{ label: '5s', value: '5' },
			{ label: '10s', value: '10' },
			{ label: '20s', value: '20' },
			{ label: '30s', value: '30' },
			{ label: 'еҒңжӯўеҲ·ж–°', value: '0' }
		]
	])
	const refreshTimer = ref<number | null>(null)
	const isRefreshing = ref(false)

	const popupRef = ref(null);
	const psw = ref('')
	const currentOperation = ref(0) // 0:ж— ж“ҚдҪң 1:жҒўеӨҚжІ№з”ө 2:ж–ӯејҖжІ№з”ө
	const modalTitle = ref('йӘҢиҜҒеҜҶз Ғ')
	const userType = ref('')

	// ж Үи®°зӮ№йӣҶеҗҲ
	const markers = ref<Array<any>>([])

	// жҺ§еҲ¶еј№зӘ—жҳҫзӨә
	const showDevicePopup = ref(false)
	const currentDeviceInfo = ref({
		deviceName: '',
		carNumber: '',
		deviceSerial: '',
		locationType: '',
		lngLat: '',
		updateTime: '',
		locationTime: '',
		speed: '',
		totalMileage: '',
		address: ''
	})
	const currentCarInfo = ref<UTSJSONObject>({})

	// иҺ·еҸ–з”өжұ йўңиүІ
	const getBatteryColor = (batteryPercent) => {
		if (!batteryPercent) return '#c9c9c9'

		const batteryValue = parseInt(batteryPercent)

		if (batteryValue >= 70) {
			return '#07C160' // з»ҝиүІпјҢз”өйҮҸе……и¶і
		} else if (batteryValue >= 30) {
			return '#FF9C19' // ж©ҷиүІпјҢз”өйҮҸдёӯзӯү
		} else if (batteryValue >= 10) {
			return '#FF6B00' // ж·ұж©ҷиүІпјҢз”өйҮҸдҪҺ
		} else {
			return '#FF0000' // зәўиүІпјҢз”өйҮҸдёҘйҮҚдёҚи¶і
		}
	}

	// дҝЎеҸ·ејәеәҰеӨ„зҗҶж–№жі•
	function getSignalDetail(rssi) {
		// еӨ„зҗҶ nullгҖҒundefined жҲ–з©әеӯ—з¬ҰдёІзҡ„жғ…еҶө
		if (rssi === null || rssi === undefined || rssi === '') {
			return {
				experience: "ж— дҝЎеҸ·",
				quality: "ж— жңҚеҠЎ",
				color: "#999",
				level: 0
			};
		}

		const signalValue = Number(rssi);

		if (isNaN(signalValue)) {
			return {
				experience: "дҝЎеҸ·ж•°жҚ®ж— ж•Ҳ",
				quality: "ж— жңҚеҠЎ",
				color: "#999",
				level: 0
			};
		}

		// ж №жҚ®еӣҫзүҮи§„еҲҷеҲӨж–ӯдҝЎеҸ·зӯүзә§
		if (signalValue >= 26) {
			return {
				experience: "жһҒеҘҪ",
				quality: "жһҒејә",
				color: "#07C160",
				level: 5
			};
		} else if (signalValue >= 20) {
			return {
				experience: "иүҜеҘҪ",
				quality: "ејә",
				color: "#52c41a",
				level: 4
			};
		} else if (signalValue >= 15) {
			return {
				experience: "дёҖиҲ¬",
				quality: "дёӯзӯү",
				color: "#faad14",
				level: 3
			};
		} else if (signalValue >= 10) {
			return {
				experience: "е·®",
				quality: "иҫғејұ",
				color: "#fa8c16",
				level: 2
			};
		} else if (signalValue >= 1) {
			return {
				experience: "йқһеёёе·®",
				quality: "еҫ®ејұ",
				color: "#f5222d",
				level: 1
			};
		} else {
			return {
				experience: "ж— дҝЎеҸ·",
				quality: "ж— жңҚеҠЎ",
				color: "#999",
				level: 0
			};
		}
	}

	// ж ·ејҸи®Ўз®—ж–№жі•
	const getMobileSignalBarClass = (barIndex, rssi) => {
		if (rssi === null || rssi === undefined || rssi === '') {
			return 'bar-off';
		}

		const signalValue = Number(rssi);
		if (isNaN(signalValue)) return 'bar-off';

		const signalDetail = getSignalDetail(signalValue);
		const level = signalDetail.level;

		// ж №жҚ®дҝЎеҸ·зӯүзә§еҶіе®ҡе“ӘдәӣдҝЎеҸ·жқЎдә®иө·
		// 5ж јдҝЎеҸ·жқЎеҜ№еә”5дёӘзӯүзә§
		return barIndex < level ? 'bar-active' : 'bar-off';
	}

	// жүӢеҠЁеҲ·ж–°ж–№жі•
	const manualRefresh = () => {
		loadData({
			deptId: deptId.value,
			deviceids: imei.value
		})
		uni.showToast({
			title: 'еҲ·ж–°жҲҗеҠҹ',
			icon: 'success'
		})
	}

	watch(currentTime, (newVal) => {
		setupAutoRefresh(newVal); // еҪ“ж—¶й—ҙй—ҙйҡ”еҸҳеҢ–ж—¶пјҢйҮҚж–°и®ҫзҪ®иҮӘеҠЁеҲ·ж–°
	});

	const setupAutoRefresh = (intervalValue : string) => {
		// жё…йҷӨзҺ°жңүзҡ„е®ҡж—¶еҷЁ
		if (refreshTimer.value !== null) {
			clearInterval(refreshTimer.value)
			refreshTimer.value = null
			isRefreshing.value = false
		}

		// еҰӮжһңйҖүжӢ©"еҒңжӯўеҲ·ж–°"(еҖјдёә'0')пјҢеҲҷзӣҙжҺҘиҝ”еӣһ
		if (intervalValue == '0') {
			isRefreshing.value = false
			return
		}

		// еҸӘжңүеҪ“и®ҫеӨҮеңЁзәҝж—¶жүҚеҗҜеҠЁе®ҡж—¶еҷЁ
		if (datainfo.value.connectionStatus != 'online') {
			isRefreshing.value = false
			return
		}

		// е°Ҷеӯ—з¬ҰдёІеҖјиҪ¬жҚўдёәж•°еӯ—(з§’)
		const intervalSeconds = parseInt(intervalValue)

		if (intervalSeconds > 0) {

			isRefreshing.value = true
			// е°Ҷз§’иҪ¬жҚўдёәжҜ«з§’
			const intervalMs = intervalSeconds * 1000

			// з«ӢеҚіеҠ иҪҪдёҖж¬Ўж•°жҚ®
			loadData({
				deptId: deptId.value,
				deviceids: imei.value
			})

			// и®ҫзҪ®е®ҡж—¶еҷЁ
			refreshTimer.value = setInterval(() => {
				loadData({
					deptId: deptId.value,
					deviceids: imei.value
				})
			}, intervalMs) as unknown as number
		}
	}

	const baseList = ref([{
		name: '/static/gjhf.png',
		title: 'иҪЁиҝ№еӣһж”ҫ'
	}, {
		name: '/static/clgz.png',
		title: 'иҪҰиҫҶи·ҹиёӘ'
	}, {
		name: '/static/lcjl.png',
		title: 'йҮҢзЁӢи®°еҪ•'
	}, {
		name: '/static/tcjl.png',
		title: 'еҒңиҪҰи®°еҪ•'
	},
	{
		name: '/static/dzwl.png',
		title: 'з”өеӯҗеӣҙж Ҹ'
	},
	{
		name: '/static/navto.png',
		title: 'дёҖй”®еҜ»иҪҰ'
	},
	{
		name: '/static/power.png',
		title: 'жҒўеӨҚжІ№з”ө'
	},
	{
		name: '/static/offpower.png',
		title: 'ж–ӯејҖжІ№з”ө'
	},
	])

	const click = (name) => {
		const itemTo = name.title
		if (itemTo == 'иҪЁиҝ№еӣһж”ҫ') {
			uni.navigateTo({
				url: '/pages/playBack/playBack?imei=' + imei.value + '&connectionStatus=' + datainfo.value.connectionStatus + '&plateNo=' + currentCarInfo.value.plateNo + '&carType=' + currentCarInfo.value.carType
			})
		}
		if (itemTo == 'иҪҰиҫҶи·ҹиёӘ') {
			uni.navigateTo({
				url: '/pages/vehicleTracking/vehicleTracking?imei=' + imei.value + '&deptId=' + deptId.value + '&connectionStatus=' + datainfo.value.connectionStatus + '&plateNo=' + currentCarInfo.value.plateNo + '&carType=' + currentCarInfo.value.carType
			})
		}
		if (itemTo == 'йҮҢзЁӢи®°еҪ•') {
			uni.navigateTo({
				url: '/pages/mileageRecord/mileageRecord?imei=' + imei.value
			})
		}
		if (itemTo == 'еҒңиҪҰи®°еҪ•') {
			uni.navigateTo({
				url: '/pages/stopRecord/stopRecord?imei=' + imei.value + '&deptId=' + deptId.value
			})
		}
		if (itemTo == 'жҒўеӨҚжІ№з”ө') {
			// жҒўеӨҚжІ№з”ө
			if (userType.value == '1') {
				// йңҖиҰҒеҜҶз ҒйӘҢиҜҒ
				psw.value = ''
				currentOperation.value = 1
				modalTitle.value = 'йӘҢиҜҒеҜҶз Ғ'
				popupRef.value.open();
			} else {
				// дёҚйңҖиҰҒеҜҶз ҒйӘҢиҜҒпјҢзӣҙжҺҘжү§иЎҢж“ҚдҪң
				executeOperation(1);
			}
		}
		if (itemTo == 'ж–ӯејҖжІ№з”ө') {
			// ж–ӯејҖжІ№з”ө
			if (userType.value == '1') {
				// йңҖиҰҒеҜҶз ҒйӘҢиҜҒ
				psw.value = ''
				currentOperation.value = 2
				modalTitle.value = 'йӘҢиҜҒеҜҶз Ғ'
				popupRef.value.open();
			} else {
				// дёҚйңҖиҰҒеҜҶз ҒйӘҢиҜҒпјҢзӣҙжҺҘжү§иЎҢж“ҚдҪң
				executeOperation(2);
			}
		}
		if (itemTo == 'з”өеӯҗеӣҙж Ҹ') {
			uni.navigateTo({
				url: '/pages/geofencing/geofencing?imei=' + imei.value + '&connectionStatus=' + datainfo.value.connectionStatus + '&plateNo=' + currentCarInfo.value.plateNo + '&carType=' + currentCarInfo.value.carType
			})
		}
		if (itemTo == 'дёҖй”®еҜ»иҪҰ') {
			navTo()
		}
	
	}

	// жү§иЎҢж“ҚдҪңзҡ„з»ҹдёҖж–№жі•
	const executeOperation = async (operationType) => {
		let predictCmdId = 0
		let type = 0

		if (operationType == 1) {
			// жҒўеӨҚжІ№з”ө
			predictCmdId = 2
			type = 2
		} else if (operationType == 2) {
			// ж–ӯејҖжІ№з”ө
			predictCmdId = 1
			type = 1
		} else {
			uni.showToast({
				title: 'ж“ҚдҪңзұ»еһӢй”ҷиҜҜ',
				icon: 'none'
			})
			return
		}

		try {
			// жҳҫзӨәеҠ иҪҪдёӯ
			uni.showLoading({
				title: 'жү§иЎҢдёӯ...',
				mask: true
			})

			// и°ғз”ЁжҺҘеҸЈ
			const res = await sendCommand({
				imei: imei.value,
				password: userType.value == '1' ? psw.value : '', // ж №жҚ®з”ЁжҲ·зұ»еһӢеҶіе®ҡжҳҜеҗҰдј еҜҶз Ғ
				params: ['1111'],
				predictCmdId: predictCmdId,
				type: type
			})

			// йҡҗи—ҸеҠ иҪҪдёӯ
			uni.hideLoading()

			// ж №жҚ®е“Қеә”еӨ„зҗҶз»“жһң
			if (res.code == 0) {
				uni.showToast({
					title: operationType == 1 ? 'жҒўеӨҚжІ№з”өжҲҗеҠҹ' : 'ж–ӯејҖжІ№з”өжҲҗеҠҹ',
					icon: 'success'
				})

				// жё…з©әеҜҶз Ғ
				psw.value = ''
			} else {
				uni.showToast({
					title: res.msg || 'ж“ҚдҪңеӨұиҙҘ',
					icon: 'none'
				})
			}
		} catch (error) {
			// йҡҗи—ҸеҠ иҪҪдёӯ
			uni.hideLoading()

			uni.__f__('error','at pages/carInfoDetail/carInfoDetail.uvue:453','ж“ҚдҪңеӨұиҙҘ:', error)
			uni.showToast({
				title: 'ж“ҚдҪңеӨұиҙҘпјҢиҜ·йҮҚиҜ•',
				icon: 'none'
			})
		}
	}

	const confirm = async () => {
		if (userType.value == '1' && psw.value == '') {
			uni.showToast({
				title: 'иҜ·иҫ“е…ҘеҜҶз Ғ',
				icon: 'none'
			})
			return
		}

		// жү§иЎҢеҪ“еүҚж“ҚдҪң
		executeOperation(currentOperation.value);
	}

	const carDetail = () => {
		uni.navigateTo({
			url: '/pages/userCenter/carDetail/carDetail?deviceId=' + deviceId.value
		})
	}

	const navTo = () => {
		uni.__f__('log','at pages/carInfoDetail/carInfoDetail.uvue:481',address.value)
		//еҜјиҲӘеҺ»жӯӨдҪҚзҪ®
		uni.openLocation({
			latitude: center.latitude,
			longitude: center.longitude,
			name: address.value,
			scale: 18,
			success: () => {
				uni.showToast({
					title: 'жҲҗеҠҹи°ғиө·ең°еӣҫ',
					icon: 'none'
				});
			},
			fail: (err) => {
				uni.showToast({
					title: 'и°ғиө·ең°еӣҫеӨұиҙҘ',
					icon: 'none'
				});
				uni.__f__('error','at pages/carInfoDetail/carInfoDetail.uvue:499','и°ғиө·ең°еӣҫеӨұиҙҘ:', err);
			}
		});
	}

	const loadData = async (data : object) => {
		try {
			const res = await getDevicePos(data)

			res.data.forEach(async item => {
				if (item.imei == imei.value) {
					datainfo.value = item

					if( !item.latitude || !item.longitude){
						uni.showToast({
							title: 'дҪҚзҪ®дҝЎжҒҜзјәеӨұ',
							icon: 'none'
						})
						return
					}

					// иҪ¬жҚўеқҗж ҮеҲ°и…ҫи®Ҝең°еӣҫеқҗж Үзі»
					const convertedCoord = CoordTransform.wgs84ToTencent(item.latitude, item.longitude)
					center.latitude = convertedCoord.lat
					center.longitude = convertedCoord.lng

					// иҺ·еҸ–ең°еқҖдҝЎжҒҜ
					const addr = await getAddress(convertedCoord.lat, convertedCoord.lng);
					address.value = addr.result.formatted_address;

					// жӣҙж–°и®ҫеӨҮж Үи®°
					const deviceMarker = createMarker(
						1,
						convertedCoord.lat,
						convertedCoord.lng,
						'device',
						currentCarInfo.value.deviceName
					)

					markers.value = [deviceMarker]

					// жЈҖжҹҘи®ҫеӨҮзҠ¶жҖҒпјҢеҰӮжһңеҸҳдёәзҰ»зәҝзҠ¶жҖҒеҲҷеҒңжӯўе®ҡж—¶еҷЁ
					if (item.connectionStatus != 'online' && refreshTimer.value !== null) {
						clearInterval(refreshTimer.value)
						refreshTimer.value = null
						isRefreshing.value = false
						uni.showToast({
							title: 'и®ҫеӨҮе·ІзҰ»зәҝпјҢеҒңжӯўиҮӘеҠЁеҲ·ж–°',
							icon: 'none'
						})
					}

					// дҝЎеҸ·ејәеәҰзӣ‘жҺ§жҸҗйҶ’
					if (item.attribute?.rssi) {
						const signalExp = getSignalDetail(item.attribute.rssi).experience;
						if (signalExp === 'е·®' || signalExp === 'йқһеёёе·®' || signalExp === 'ж— дҝЎеҸ·') {
							uni.__f__('warn','at pages/carInfoDetail/carInfoDetail.uvue:555',`и®ҫеӨҮ ${imei.value} дҝЎеҸ·иҫғејұ: ${item.attribute.rssi}dBm`);
						}
					}
				}
			})
		} catch (error) {
			uni.__f__('error','at pages/carInfoDetail/carInfoDetail.uvue:561','еҠ иҪҪи®ҫеӨҮж•°жҚ®еӨұиҙҘ:', error);
			uni.showToast({
				title: 'ж•°жҚ®еҠ иҪҪеӨұиҙҘ',
				icon: 'none'
			})
		}
	}

	onLoad((option) => {
		deptId.value = option.deptId
		imei.value = option.imei
		deviceId.value = option.deviceId
		userType.value = uni.getStorageSync('userType')

		const data = {
			deptId: deptId.value,
			deviceids: imei.value
		}
		loadData(data).then(() => {
			// ж•°жҚ®еҠ иҪҪе®ҢжҲҗеҗҺпјҢж №жҚ®и®ҫеӨҮзҠ¶жҖҒеҗҜеҠЁе®ҡж—¶еҷЁ
			if (datainfo.value.connectionStatus == 'online') {
				setupAutoRefresh(currentTime.value)
			}
		})
		loadDeviceDetail()
	})

	const loadDeviceDetail = async () => {
		if (deviceId.value !== null) {
			const res = await getDeviceDetail(deviceId.value)
			currentCarInfo.value = res.data
		} else {
			uni.__f__('error','at pages/carInfoDetail/carInfoDetail.uvue:593',"и®ҫеӨҮidиҺ·еҸ–еӨұиҙҘ")
		}
	}

	//е°ҒиЈ…markers
	const createMarker = (id : number, lat : number, lng : number, type : string, title ?: string) => {
		const marker = {
			id,
			latitude: lat,
			longitude: lng,
			width: 25,
			height: 25,
			iconPath: datainfo.value.connectionStatus == 'online' ? getOnlineDeviceIcon(currentCarInfo.value.carType) : getOfflineDeviceIcon(currentCarInfo.value.carType),
			callout: {
				content: title || 'зҲұиҪҰдҪҚзҪ®',
				color: datainfo.value.connectionStatus == 'online' ? '#fff' : '#666',
				fontSize: 14,
				borderRadius: 10,
				bgColor: datainfo.value.connectionStatus == 'online' ? '#07C160' : '#ccc',
				padding: 5,
				display: 'ALWAYS'
			}
		}

		return marker
	}

	// ж–°еўһйЎөйқўйҡҗи—Ҹж—¶зҡ„еӨ„зҗҶ
	onHide(() => {
		clearInterval(refreshTimer.value)
		refreshTimer.value = null
		isRefreshing.value = false
	})

	onUnmounted(() => {
		clearInterval(refreshTimer.value)
		refreshTimer.value = null
	})
</script>
