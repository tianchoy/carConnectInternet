			.h-line{
				width: 90%;
				height: 2rpx;
				background-color: #f1f1f1;
				margin: 50rpx auto 0;
			}

			.tool-tag-item {
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
				padding: 50rpx 20rpx;
			}

			.speed-control {
				padding: 20rpx;
				.slider{
					width: 90%;
					margin: 0 auto;
				}
			}

			.grid-text {
				padding: 20rpx 0 0;

				box-sizing: border-box;

				font-size: 30rpx;
			}
		}
	}
</style>