<template>
	<view class="container">
		<custom-navBar title="地理围栏" :show-back="true" backgroundColor="#fff" textColor="#333" :showCapsule="false">
		</custom-navBar>
		<view class="map-container">
			<map id="myMap" :latitude="center.latitude" :longitude="center.longitude" :scale="mapScale"
				style="width:100%;height:100%" :show-location="true" :polygons="polygons" :markers="markers"
				:circles="circles" @click="handleMapTap">
				<sub-navBar :showTime="false" :currentCar="currentCar" :showCar="true"
					:carStatus='connectionStatus'></sub-navBar>
			</map>
			
			<!-- 绘制提示 -->
			<view v-if="isDrawing" class="drag-hint">
				<text v-if="drawingMode === 'polygon'">点击地图添加围栏顶点，至少需要3个点</text>
				<text v-if="drawingMode === 'circle'">点击地图确定圆心，拖动调整半径</text>
			</view>
			
			<!-- 围栏操作面板 -->
			<view class="fence-operations" v-if="selectedFence">
				<view class="fence-header">
					<text class="fence-name">{{ selectedFence.name }}</text>
					<uv-icon name="close" @click="selectedFence = null; "></uv-icon>
				</view>
				<view class="fence-actions">
					<uv-button size="small" @click="editFence(selectedFence)">编辑</uv-button>
					<uv-button size="small" type="error" @click="deleteFence(selectedFence.id)">删除</uv-button>
					<uv-button size="small" type="primary" @click="showBindDevices(selectedFence.id)">绑定设备</uv-button>
				</view>
			</view>
		</view>
		
		<!-- 绘制控制面板 -->
		<view class="tools-panel">
			<!-- 绘制模式选择 -->
			<view class="drawing-mode-selector" v-if="!isDrawing && !selectedFence">
				<view class="mode-title">选择围栏类型:</view>
				<view class="mode-buttons">
					<uv-button 
						:type="drawingMode == 'polygon' ? 'primary' : 'default'" 
						size="small" 
						@click="setDrawingMode('polygon')">
						多边形
					</uv-button>
					<uv-button 
						:type="drawingMode == 'circle' ? 'primary' : 'default'" 
						size="small" 
						@click="setDrawingMode('circle')">
						圆形
					</uv-button>
				</view>
			</view>
			
			<view class="tool-tag-item">
				<uv-button @click="startDrawing" :disabled="isDrawing || selectedFence">
					开始绘制
				</uv-button>
				<uv-button @click="finishDrawing" :disabled="!isDrawing || !canFinishDrawing">
					完成绘制
				</uv-button>
				<uv-button @click="clearDrawing">
					重置绘制
				</uv-button>
				<uv-button @click="showFenceList">
					围栏列表
				</uv-button>
			</view>
			
			<view class="status-info">
				<text>围栏类型: {{ drawingMode === 'polygon' ? '多边形' : '圆形' }}</text>
				<text v-if="drawingMode === 'polygon'">顶点数量: {{ points.length }}</text>
				<text v-if="drawingMode === 'circle' && circleRadius > 0">半径: {{ circleRadius.toFixed(2) }}米</text>
			</view>
		</view>
		
		<!-- 围栏列表弹窗 -->
		<uv-popup ref="fencesPopup" mode="bottom" round="10">
			<view class="fence-list">
				<view class="list-header">
					<text class="title">围栏列表</text>
					<uv-icon name="close" @click="fencesPopup.close()"></uv-icon>
				</view>
				<scroll-view class="list-content" scroll-y>
					<view v-for="fence in fenceList" :key="fence.id" class="fence-item" @click="selectFence(fence)">
						<view class="fence-info">
							<text class="name">{{ fence.name }}</text>
							<text class="type">{{ getFenceType(fence) === 'circle' ? '圆形' : '多边形' }}</text>
							<text class="devices">绑定设备: {{ fence.deviceCount || 0 }}台</text>
						</view>
						<uv-icon name="arrow-right"></uv-icon>
					</view>
					<view v-if="fenceList.length === 0" class="empty">
						暂无围栏数据
					</view>
				</scroll-view>
			</view>
		</uv-popup>
		
		<!-- 围栏编辑弹窗 -->
		<uv-popup ref="editDialogPopup" mode="center" round="10">
			<view class="edit-dialog">
				<view class="dialog-header">
					<text>{{ editingFence ? '编辑围栏' : '新增围栏' }}</text>
				</view>
				<view class="dialog-content">
					<uv-input v-model="fenceForm.name" placeholder="请输入围栏名称" border="surround"></uv-input>
					<view class="radio-group">
						<text class="label">告警类型:</text>
						<uv-radio-group v-model="fenceForm.alarmType" iconPlacement="left" customStyle="display:flex;flex-direction:row;align-items: center;justify-content: left;">
							<uv-radio style="padding: 0 10px;" name="0">不告警</uv-radio>
							<uv-radio style="padding: 0 10px;" name="1">出入告警</uv-radio>
							<uv-radio style="padding: 0 10px;" name="2">出告警</uv-radio>
							<uv-radio style="padding: 0 10px;" name="3">入告警</uv-radio>
						</uv-radio-group>
					</view>
				</view>
				<view class="dialog-actions">
					<uv-button @click="editDialogPopup.close()">取消</uv-button>
					<uv-button type="primary" @click="saveFence">保存</uv-button>
				</view>
			</view>
		</uv-popup>
		
		<!-- 设备绑定弹窗 -->
		<uv-popup ref="deviceDialogPopup" mode="bottom" round="10">
			<view class="device-dialog">
				<view class="dialog-header">
					<text>设备绑定 - {{ currentFenceName }}</text>
					<uv-icon name="close" @click="deviceDialogPopup.close()"></uv-icon>
				</view>
				<view class="dialog-tabs">
					<view :class="['tab', activeTab === 'bind' ? 'active' : '']" @click="activeTab = 'bind'">
						已绑定设备
					</view>
					<view :class="['tab', activeTab === 'unbind' ? 'active' : '']" @click="activeTab = 'unbind'">
						未绑定设备
					</view>
				</view>
				<scroll-view class="device-list" scroll-y>
					<view v-for="device in deviceList" :key="device.imei" class="device-item">
						<view class="device-info">
							<text class="name">{{ device.plateNo || device.imei }}</text>
							<text class="status">{{ device.connectionStatus === 'online' ? '在线' : '离线' }}</text>
						</view>
						<uv-switch 
							:model-value="isDeviceBound(device.imei)" 
							@change="toggleDeviceBinding(device.imei, $event)"
							:disabled="loading">
						</uv-switch>
					</view>
					<view v-if="deviceList.length === 0" class="empty">
						{{ activeTab === 'bind' ? '暂无绑定设备' : '暂无可用设备' }}
					</view>
				</scroll-view>
				<view class="dialog-actions">
					<uv-button @click="deviceDialogPopup.close()">完成</uv-button>
				</view>
			</view>
		</uv-popup>
	</view>
</template>

<script setup lang="uts">
	import { ref, reactive, onMounted, computed, watch } from 'vue'
	import { getDevicePos, getGeofenceList, addGeofence, updateGeofence, deleteGeofence, getBoundDevices, getUnboundDevices, bindDevices, unbindDevices } from '../../api/request.uts'
	import CoordTransform from '../../utils/coordTransform.uts'

	const imei = ref<string | null>('')
	const connectionStatus = ref<string | null>('')
	const deptId = ref<string | null>('')
	
	// 地图状态
	const center = reactive({
		latitude: 39.90469,
		longitude: 116.40717
	})
	const mapScale = ref(15)
	const markers = ref<any[]>([]) // 标记点
	const carMarker = ref<any>(null) // 车辆标记点
	const circles = ref<any[]>([]) // 圆形围栏
	const carInFence = ref(false) // 车辆是否在围栏内
	
	// 电子围栏相关状态
	const isDrawing = ref(false)
	const drawingMode = ref('polygon') // 'polygon' 或 'circle'
	const points = ref<Array<{ latitude : number, longitude : number }>>([])
	const polygons = ref<any[]>([]) // 存储地理围栏多边形数据
	const circleCenter = ref<{ latitude : number, longitude : number } | null>(null)
	const circleRadius = ref(0) // 圆形围栏半径（米）
	const currentSpeed = ref(0)
	const currentAddress = ref('获取中...')
	const currentCar = ref<string | null>('京A12345')
	const lastDirection = ref(0)
	
	// 围栏管理状态
	const fenceList = ref<any[]>([])
	const selectedFence = ref<any>(null)
	const fencesPopup = ref<any>(null)
	const editDialogPopup = ref<any>(null)
	const editingFence = ref<any>(null)
	const fenceForm = reactive({
		name: '',
		alarmType: '1'
	})
	
	// 设备绑定状态
	const deviceDialogPopup = ref<any>(null)
	const activeTab = ref('bind')
	const deviceList = ref<any[]>([])
	const boundDevices = ref<any[]>([])
	const currentFenceName = ref('')
	const currentFenceId = ref('')
	const loading = ref(false)
	
	// 计算是否可以完成绘制
	const canFinishDrawing = computed(() => {
		if (drawingMode.value === 'polygon') {
			return points.value.length >= 3
		} else if (drawingMode.value === 'circle') {
			return circleCenter.value !== null && circleRadius.value > 0
		}
		return false
	})

	onLoad((option) => {
		connectionStatus.value = option.connectionStatus
		imei.value = option.imei
		currentCar.value = option.plateNo
		deptId.value = option.deptId
		loadInitialPosition()
		loadGeofenceList() // 页面加载时获取围栏列表
	})
	
	const loadInitialPosition = async () => {
		uni.showLoading({
			title: '获取车辆位置中...'
		})
	
		try {
			const data = { deptId: deptId.value, deviceids: imei.value }
			const res = await getDevicePos(data)
	
			res.data.forEach(async item => {
				if (item.imei == imei.value) {
					const deviceData = item
					// 转换坐标到腾讯地图坐标系
					const convertedCoord = CoordTransform.wgs84ToTencent(
						Number(deviceData.latitude),
						Number(deviceData.longitude)
					)
					center.latitude = convertedCoord.lat
					center.longitude = convertedCoord.lng
	
					const position = {
						latitude: convertedCoord.lat,
						longitude: convertedCoord.lng
					}
	
					// 记录初始方向
					lastDirection.value = deviceData.direction || 0
					
					// 创建车辆标记点
					carMarker.value = {
						id: 0,
						latitude: position.latitude,
						longitude: position.longitude,
						iconPath: connectionStatus.value == 'online' ? '/static/car.png' : '/static/offline.png',
						width: 40,
						height: 40,
						rotate: calculateMapRotation(lastDirection.value), // 修正方向
						callout: {
							content: connectionStatus.value == 'online' ? `车辆位置 | 速度: ${deviceData.speed || 0}km/h` : '车辆已离线',
							color: connectionStatus.value == 'online' ? '#fff' : '#666',
							bgColor: connectionStatus.value == 'online' ? '#1296db' : '#ccc',
							padding: 5,
							borderRadius: 4,
							display: 'ALWAYS'
						}
					}
					
					// 更新标记点数组，保留车辆标记点
					updateMarkers()

					// 更新车辆信息
					currentSpeed.value = deviceData.speed || 0
					currentAddress.value = deviceData.positionUpdateTime
						? `最后定位: ${deviceData.positionUpdateTime}`
						: '未知位置'
					connectionStatus.value = deviceData.connectionStatus || 'unknown'
				}
			})
	
		} catch (err) {
			uni.__f__('error','at pages/geofencing/geofencing.uvue:294','获取初始位置失败:', err)
			uni.showToast({
				title: '获取车辆位置失败',
				icon: 'none'
			})
		} finally {
			uni.hideLoading()
		}
	}
	
	// 计算地图上的旋转角度（修正方向）
	const calculateMapRotation = (direction : number) : number => {
		let rotation = direction
		if (rotation >= 360) rotation -= 360
		if (rotation < 0) rotation += 360
		
		return rotation
	}

	// 加载围栏列表
	const loadGeofenceList = async () => {
		try {
			const res = await getGeofenceList()
			if (res.code === 0) {
				fenceList.value = res.data
				// 将围栏渲染到地图上
				renderFencesOnMap()
			} else {
				uni.showToast({ title: '获取围栏列表失败', icon: 'none' })
			}
		} catch (error) {
			uni.__f__('error','at pages/geofencing/geofencing.uvue:325','加载围栏列表失败:', error)
			uni.showToast({ title: '获取围栏列表失败', icon: 'none' })
		}
	}
	
	// 获取围栏类型（根据area字段判断）
	const getFenceType = (fence: any) => {
		if (fence.type && fence.type !== 'null') {
			return fence.type
		}
		// 根据area字段内容判断围栏类型
		if (fence.area && fence.area.startsWith('CIRCLE')) {
			return 'circle'
		} else if (fence.area && fence.area.startsWith('POLYGON')) {
			return 'polygon'
		}
		return 'polygon' // 默认多边形
	}
	
	// 将围栏数据渲染到地图上
	const renderFencesOnMap = () => {
		if (!fenceList.value || fenceList.value.length === 0) return
		
		const fencePolygons = []
		const fenceCircles = []
		
		// 为每个围栏创建多边形或圆形
		fenceList.value.forEach((fence, index) => {
			const fenceType = getFenceType(fence)
			
			if (fenceType === 'circle') {
				// 处理圆形围栏
				const circleData = parseCircle(fence.area)
				if (circleData) {
					// 处理过大半径，避免无法显示
					const displayRadius = circleData.radius > 100000 ? 100000 : circleData.radius;
					
					fenceCircles.push({
						id: fence.id,
						latitude: circleData.latitude,
						longitude: circleData.longitude,
						radius: displayRadius,
						strokeWidth: 2,
						strokeColor: '#FF0000',
						fillColor: `rgba(255,0,0,0.2)`,
						zIndex: 1,
						centerMarker: true
					})
				}
			} else {
				// 处理多边形围栏
				const fencePoints = parsePolygon(fence.area)
				if (fencePoints.length >= 3) {
					fencePolygons.push({
						id: fence.id,
						points: fencePoints,
						strokeWidth: 2,
						strokeColor: '#FF0000',
						fillColor: index === 0 ? 'rgba(255,0,0,0.2)' : `rgba(${Math.floor(Math.random() * 200)},${Math.floor(Math.random() * 200)},${Math.floor(Math.random() * 200)},0.2)`,
						zIndex: 1
					})
				}
			}
		})
		
		polygons.value = fencePolygons
		circles.value = fenceCircles
		
		// 确保圆形围栏能显示在地图视野中
		if (fenceCircles.length > 0 && !selectedFence.value) {
			// 自动定位到第一个圆形围栏
			const firstCircle = fenceCircles[0]
			center.latitude = firstCircle.latitude
			center.longitude = firstCircle.longitude
			// 根据半径设置合适的缩放级别
			mapScale.value = calculateZoomLevelFromRadius(firstCircle.radius)
		}
	}

	// 解析POLYGON字符串为坐标数组
	// 格式: "POLYGON ((lat1 lng1, lat2 lng2, ...))"
	const parsePolygon = (polygonStr : string) => {
		if (!polygonStr) return []
		
		// 去除字符串中的"POLYGON (("和"))"
		const coordStr = polygonStr.replace(/POLYGON \(\(/, '').replace(/\)\)/, '')
		// 按逗号分割坐标点
		const coordPoints = coordStr.split(',')

		return coordPoints.map(point => {
			// 注意：格式是纬度在前，经度在后
			const [lat, lng] = point.trim().split(' ').map(Number)
			// 转换坐标到腾讯地图坐标系
			const convertedCoord = CoordTransform.wgs84ToTencent(lat, lng)
			return {
				latitude: convertedCoord.lat,
				longitude: convertedCoord.lng
			}
		})
	}
	
	// 解析CIRCLE字符串为圆心和半径
	// 格式: "CIRCLE (lat lng, radius)"
	const parseCircle = (circleStr : string) => {
		if (!circleStr || !circleStr.startsWith('CIRCLE')) return null
		
		try {
			// 去除字符串中的"CIRCLE ("和")"
			const coordStr = circleStr.replace(/CIRCLE \(/, '').replace(/\)/, '')
			// 按逗号分割坐标点和半径
			const parts = coordStr.split(',')
			
			if (parts.length !== 2) return null
			
			const [centerStr, radiusStr] = parts
			// 解析经纬度（注意：格式是纬度在前，经度在后）
			const [lat, lng] = centerStr.trim().split(' ').map(Number)
			const radius = Number(radiusStr.trim())
			
			// 验证数据有效性
			if (isNaN(lat) || isNaN(lng) || isNaN(radius) || radius <= 0) {
				uni.__f__('error','at pages/geofencing/geofencing.uvue:446','无效的圆形围栏数据:', circleStr)
				return null
			}
			
			// 转换坐标到腾讯地图坐标系
			const convertedCoord = CoordTransform.wgs84ToTencent(lat, lng)
			
			return {
				latitude: convertedCoord.lat,
				longitude: convertedCoord.lng,
				radius: radius
			}
		} catch (error) {
			uni.__f__('error','at pages/geofencing/geofencing.uvue:459','解析圆形围栏失败:', error, '数据:', circleStr)
			return null
		}
	}
	
	// 生成POLYGON字符串
	// 格式: "POLYGON ((lat1 lng1, lat2 lng2, ...))"
	const generatePolygonString = (points : Array<{ latitude : number, longitude : number }>) => {
		const coords = points.map(point => {
			// 转换回WGS84坐标系存储
			const originalCoord = CoordTransform.tencentToWgs84(point.latitude, point.longitude)
			return `${originalCoord.lat} ${originalCoord.lng}`
		}).join(', ')
		return `POLYGON ((${coords}))`
	}
	
	// 生成CIRCLE字符串
	// 格式: "CIRCLE (lat lng, radius)"
	const generateCircleString = (center : { latitude : number, longitude : number }, radius : number) => {
		// 转换回WGS84坐标系存储
		const originalCoord = CoordTransform.tencentToWgs84(center.latitude, center.longitude)
		return `CIRCLE (${originalCoord.lat} ${originalCoord.lng}, ${radius})`
	}

	// 调整地图中心到围栏中心位置
	const setMapCenterToFence = (fence : any) => {
		const fenceType = getFenceType(fence)
		
		if (fenceType === 'circle') {
			const circleData = parseCircle(fence.area)
			if (circleData) {
				center.latitude = circleData.latitude
				center.longitude = circleData.longitude
				// 处理过大半径，设置合理的缩放级别
				const displayRadius = circleData.radius > 100000 ? 100000 : circleData.radius;
				// 根据半径调整缩放级别
				mapScale.value = calculateZoomLevelFromRadius(displayRadius)
			}
		} else {
			const fencePoints = parsePolygon(fence.area)
			if (fencePoints.length === 0) return

			// 计算中心点
			let totalLat = 0
			let totalLng = 0

			fencePoints.forEach(point => {
				totalLat += point.latitude
				totalLng += point.longitude
			})

			center.latitude = totalLat / fencePoints.length
			center.longitude = totalLng / fencePoints.length
			
			// 根据围栏大小自动调整缩放级别
			const bounds = calculateBounds(fencePoints)
			const latDiff = bounds.maxLat - bounds.minLat
			const lngDiff = bounds.maxLng - bounds.minLng
			const maxDiff = Math.max(latDiff, lngDiff)
			
			if (maxDiff > 0.1) mapScale.value = 11
			else if (maxDiff > 0.05) mapScale.value = 12
			else if (maxDiff > 0.02) mapScale.value = 13
			else mapScale.value = 14
		}
	}
	
	// 根据半径计算合适的缩放级别
	const calculateZoomLevelFromRadius = (radius : number) => {
		if (radius > 50000) return 8   // 50公里以上
		if (radius > 20000) return 9    // 20-50公里
		if (radius > 10000) return 10    // 10-20公里
		if (radius > 5000) return 11     // 5-10公里
		if (radius > 2000) return 12     // 2-5公里
		if (radius > 1000) return 13    // 1-2公里
		if (radius > 500) return 14      // 500米-1公里
		if (radius > 200) return 15      // 200-500米
		return 16                       // 200米以下
	}
	
	// 计算坐标边界
	const calculateBounds = (points : any[]) => {
		let minLat = points[0].latitude
		let maxLat = points[0].latitude
		let minLng = points[0].longitude
		let maxLng = points[0].longitude
		
		points.forEach(point => {
			minLat = Math.min(minLat, point.latitude)
			maxLat = Math.max(maxLat, point.latitude)
			minLng = Math.min(minLng, point.longitude)
			maxLng = Math.max(maxLng, point.longitude)
		})
		
		return { minLat, maxLat, minLng, maxLng }
	}

	// 显示围栏列表
	const showFenceList = () => {
		fencesPopup.value?.open()
	}
	
	// 选择围栏
	const selectFence = (fence : any) => {
		selectedFence.value = fence
		fencesPopup.value?.close()
		
		// 根据围栏类型显示
		const fenceType = getFenceType(fence)
		if (fenceType === 'circle') {
			const circleData = parseCircle(fence.area)
			if (circleData) {
				circleCenter.value = { latitude: circleData.latitude, longitude: circleData.longitude }
				circleRadius.value = circleData.radius
				points.value = []
			}
		} else {
			const fencePoints = parsePolygon(fence.area)
			points.value = fencePoints
			circleCenter.value = null
			circleRadius.value = 0
		}
		
		setMapCenterToFence(fence)
		updateMapDisplay()
	}
	
	// 编辑围栏
	const editFence = (fence : any) => {
		editingFence.value = fence
		fenceForm.name = fence.name
		fenceForm.alarmType = fence.alarmType.toString()
		// 设置当前绘制模式为围栏实际类型
		drawingMode.value = getFenceType(fence)
		editDialogPopup.value?.open()
	}
	
	// 删除围栏
	const deleteFence = async (id : string) => {
		uni.showModal({
			title: '确认删除',
			content: '确定要删除这个围栏吗？',
			success: async (res) => {
				if (res.confirm) {
					try {
						const result = await deleteGeofence(id)
						if (result.code === 0) {
							uni.showToast({ title: '删除成功' })
							selectedFence.value = null
							clearDrawing()
							loadGeofenceList() // 重新加载围栏列表
						} else {
							uni.showToast({ title: '删除失败', icon: 'none' })
						}
					} catch (error) {
						uni.__f__('error','at pages/geofencing/geofencing.uvue:614','删除围栏失败:', error)
						uni.showToast({ title: '删除失败', icon: 'none' })
					}
				}
			}
		})
	}
	
	// 保存围栏
	const saveFence = async () => {
		if (!fenceForm.name) {
			uni.showToast({ title: '请输入围栏名称', icon: 'none' })
			return
		}
		
		let area = ''
		if (drawingMode.value === 'polygon' && points.value.length < 3) {
			uni.showToast({ title: '请绘制有效的围栏区域', icon: 'none' })
			return
		} else if (drawingMode.value === 'circle' && (!circleCenter.value || circleRadius.value <= 0)) {
			uni.showToast({ title: '请绘制有效的圆形围栏', icon: 'none' })
			return
		}
		
		// 根据绘制模式生成不同的区域字符串
		if (drawingMode.value === 'polygon') {
			area = generatePolygonString(points.value)
		} else if (drawingMode.value === 'circle' && circleCenter.value) {
			area = generateCircleString(circleCenter.value, circleRadius.value)
		}
		
		const fenceData = {
			name: fenceForm.name,
			area: area,
			alarmType: parseInt(fenceForm.alarmType),
			type: drawingMode.value // 确保保存时设置正确的类型
		}
		
		try {
			let result
			if (editingFence.value) {
				result = await updateGeofence({ id: editingFence.value.id, ...fenceData })
			} else {
				result = await addGeofence(fenceData)
			}
			
			if (result.code === 0) {
				uni.showToast({ title: '保存成功' })
				editDialogPopup.value?.close()
				editingFence.value = null
				isDrawing.value = false
				loadGeofenceList() // 重新加载围栏列表
			} else {
				uni.showToast({ title: '保存失败', icon: 'none' })
			}
		} catch (error) {
			uni.__f__('error','at pages/geofencing/geofencing.uvue:670','保存围栏失败:', error)
			uni.showToast({ title: '保存失败', icon: 'none' })
		}
	}
	
	// 显示绑定设备对话框
	const showBindDevices = async (fenceId : string) => {
		currentFenceId.value = fenceId
		currentFenceName.value = selectedFence.value.name
		deviceDialogPopup.value?.open()
		activeTab.value = 'bind'
		await loadBoundDevices(fenceId)
	}
	
	// 加载已绑定设备
	const loadBoundDevices = async (fenceId : string) => {
		try {
			const res = await getBoundDevices({
				pageNum: 1,
				pageSize: 100,
				geoId: fenceId
			})
			
			if (res.code === 0) {
				boundDevices.value = res.data.list || []
				deviceList.value = boundDevices.value
			}
		} catch (error) {
			uni.__f__('error','at pages/geofencing/geofencing.uvue:698','加载已绑定设备失败:', error)
		}
	}
	
	// 加载未绑定设备
	const loadUnboundDevices = async () => {
		try {
			const res = await getUnboundDevices({
				pageNum: 1,
				pageSize: 100
			})
			
			if (res.code === 0) {
				deviceList.value = res.data.list || []
			}
		} catch (error) {
			uni.__f__('error','at pages/geofencing/geofencing.uvue:714','加载未绑定设备失败:', error)
		}
	}
	
	// 切换设备绑定状态
	const toggleDeviceBinding = async (deviceImei : string, bound : boolean) => {
		loading.value = true
		try {
			const params = {
				geofenceId: currentFenceId.value,
				imeis: [deviceImei]
			}
			
			let result
			if (bound) {
				result = await bindDevices(params)
			} else {
				result = await unbindDevices(params)
			}
			
			if (result.code === 0) {
				uni.showToast({ title: bound ? '绑定成功' : '解绑成功' })
				// 刷新设备列表
				if (activeTab.value === 'bind') {
					await loadBoundDevices(currentFenceId.value)
				} else {
					await loadUnboundDevices()
				}
			} else {
				uni.showToast({ title: '操作失败', icon: 'none' })
			}
		} catch (error) {
			uni.__f__('error','at pages/geofencing/geofencing.uvue:746','设备绑定操作失败:', error)
			uni.showToast({ title: '操作失败', icon: 'none' })
		} finally {
			loading.value = false
		}
	}
	
	// 检查设备是否已绑定
	const isDeviceBound = (deviceImei : string) => {
		return boundDevices.value.some(device => device.imei === deviceImei)
	}
	
	// 监听标签页切换
	watch(activeTab, (newVal) => {
		if (newVal === 'bind') {
			loadBoundDevices(currentFenceId.value)
		} else {
			loadUnboundDevices()
		}
	})

	/* 电子围栏绘制功能 */
	// 设置绘制模式
	const setDrawingMode = (mode : string) => {
		drawingMode.value = mode
		// 切换模式时清空当前绘制
		if (isDrawing.value) {
			points.value = []
			circleCenter.value = null
			circleRadius.value = 0
			updateMapDisplay()
		}
	}
	
	// 开始绘制
	const startDrawing = () => {
		isDrawing.value = true
		points.value = []
		circleCenter.value = null
		circleRadius.value = 0
		selectedFence.value = null
		updateMapDisplay()
	}

	// 处理地图点击事件
	const handleMapTap = (e : any) => {
		if (isDrawing.value) {
			if (drawingMode.value === 'polygon') {
				addNewPoint(e.detail.latitude, e.detail.longitude)
			} else if (drawingMode.value === 'circle') {
				if (!circleCenter.value) {
					// 第一次点击设置圆心
					circleCenter.value = {
						latitude: e.detail.latitude,
						longitude: e.detail.longitude
					}
					// 添加圆心标记
					updateMapDisplay()
				} else {
					// 第二次点击确定半径
					const radius = calculateDistance(
						circleCenter.value.latitude,
						circleCenter.value.longitude,
						e.detail.latitude,
						e.detail.longitude
					)
					// 限制最小半径为10米
					circleRadius.value = radius < 10 ? 10 : radius
					updateMapDisplay()
				}
			}
		}
	}

	// 计算两点之间的距离（米）
	const calculateDistance = (lat1 : number, lng1 : number, lat2 : number, lng2 : number) => {
		const R = 6371000 // 地球半径（米）
		const dLat = (lat2 - lat1) * Math.PI / 180
		const dLng = (lng2 - lng1) * Math.PI / 180
		const a = 
			Math.sin(dLat/2) * Math.sin(dLat/2) +
			Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * 
			Math.sin(dLng/2) * Math.sin(dLng/2)
		const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a))
		const distance = R * c
		return distance
	}

	// 添加新点（多边形模式）
	const addNewPoint = (lat : number, lng : number) => {
		points.value.push({ latitude: lat, longitude: lng })
		updateMapDisplay()
	}

	// 完成绘制
	const finishDrawing = () => {
		if (drawingMode.value === 'polygon' && points.value.length < 3) {
			uni.showToast({ title: '至少需要3个顶点', icon: 'none' })
			return
		} else if (drawingMode.value === 'circle' && (!circleCenter.value || circleRadius.value <= 0)) {
			uni.showToast({ title: '请设置有效的圆形围栏', icon: 'none' })
			return
		}
		
		isDrawing.value = false
		
		// 弹出编辑对话框
		fenceForm.name = `${drawingMode.value === 'circle' ? '圆形' : '多边形'}围栏${fenceList.value.length + 1}`
		editDialogPopup.value?.open()
	}

	// 更新标记点数组，保留车辆标记点
	const updateMarkers = () => {
		const newMarkers = []
		
		// 首先添加车辆标记点（如果存在）
		if (carMarker.value) {
			newMarkers.push(carMarker.value)
		}
		
		// 添加围栏顶点标记（仅在绘制模式下）
		if (isDrawing.value) {
			if (drawingMode.value === 'polygon') {
				// 多边形顶点标记
				points.value.forEach((point, index) => {
					newMarkers.push({
						id: 1000 + index,
						latitude: point.latitude,
						longitude: point.longitude,
						iconPath: '/static/marker.png',
						width: 32,
						height: 32,
						callout: { content: `顶点${index + 1}`, display: 'ALWAYS' },
						anchor: { x: 0.5, y: 0.5 }
					})
				})
			} else if (drawingMode.value === 'circle' && circleCenter.value) {
				// 圆形圆心标记
				newMarkers.push({
					id: 1000,
					latitude: circleCenter.value.latitude,
					longitude: circleCenter.value.longitude,
					iconPath: '/static/marker.png',
					width: 32,
					height: 32,
					callout: { content: '圆心', display: 'ALWAYS' },
					anchor: { x: 0.5, y: 0.5 }
				})
			}
		} else if (selectedFence.value) {
			// 选中围栏时显示标记
			const fenceType = getFenceType(selectedFence.value)
			if (fenceType === 'circle') {
				const circleData = parseCircle(selectedFence.value.area)
				if (circleData) {
					newMarkers.push({
						id: 2000,
						latitude: circleData.latitude,
						longitude: circleData.longitude,
						iconPath: '/static/marker.png',
						width: 32,
						height: 32,
						callout: { content: '圆心', display: 'ALWAYS' },
						anchor: { x: 0.5, y: 0.5 }
					})
				}
			} else {
				const fencePoints = parsePolygon(selectedFence.value.area)
				fencePoints.forEach((point, index) => {
					newMarkers.push({
						id: 2000 + index,
						latitude: point.latitude,
						longitude: point.longitude,
						iconPath: '/static/marker.png',
						width: 32,
						height: 32,
						callout: { content: `顶点${index + 1}`, display: 'ALWAYS' },
						anchor: { x: 0.5, y: 0.5 }
					})
				})
			}
		}
		
		markers.value = newMarkers
	}

	// 更新围栏多边形显示
	const updateFencePolygon = () => {
		if (drawingMode.value === 'polygon') {
			polygons.value = points.value.length >= 3 ? [{
				points: points.value,
				strokeWidth: 2,
				strokeColor: '#FF0000',
				fillColor: 'rgba(255,0,0,0.2)',
				zIndex: 1
			}] : []
		} else {
			polygons.value = []
		}
	}
	
	// 更新圆形围栏显示
	const updateFenceCircle = () => {
		if (drawingMode.value === 'circle' && circleCenter.value && circleRadius.value > 0) {
			circles.value = [{
				latitude: circleCenter.value.latitude,
				longitude: circleCenter.value.longitude,
				radius: circleRadius.value,
				strokeWidth: 2,
				strokeColor: '#FF0000',
				fillColor: 'rgba(255,0,0,0.2)',
				zIndex: 1
			}]
		} else {
			circles.value = []
		}
	}

	// 更新地图显示
	const updateMapDisplay = () => {
		// 更新标记点（保留车辆标记点）
		updateMarkers()

		// 更新围栏显示
		if (isDrawing.value) {
			if (drawingMode.value === 'polygon') {
				updateFencePolygon()
				circles.value = []
			} else if (drawingMode.value === 'circle') {
				updateFenceCircle()
				polygons.value = []
			}
		} else {
			// 如果不是绘制模式，重新渲染所有围栏
			renderFencesOnMap()
		}
	}
	
	// 重置绘制（只清除围栏，保留车辆位置）
	const clearDrawing = () => {
		isDrawing.value = false
		points.value = []
		circleCenter.value = null
		circleRadius.value = 0
		selectedFence.value = null
		// 重新渲染所有围栏
		renderFencesOnMap()
		updateMapDisplay()
	}
</script>

