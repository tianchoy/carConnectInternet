				justify-content: space-between;
				align-items: center;
				margin-bottom: 20rpx;
				
				uv-button {
					flex: 1;
					margin: 0 10rpx;
				}
			}
			
			.status-info {
				display: flex;
				flex-direction: column;
				padding: 20rpx 0;
