<template>
	<view></view>
</template>

<script setup lang="uts">
	import { ref } from 'vue'

	const scanFunctionIsUseable = ref(true)

	const goBack = () => {
		uni.navigateBack({ delta: 1 })
	}

	const handleScanResult = (scanResult : string) => {
		if (!scanFunctionIsUseable.value || scanResult.length == 0) return
		scanFunctionIsUseable.value = false
		uni.__f__('log','at pages/scancode/scancode.uvue:17','扫码结果:', scanResult)
		uni.setStorageSync('scanCodeResult', scanResult)
		uni.$emit('scanCodeResult', { result: scanResult })
		uni.showToast({
			title: '扫码成功',
			icon: 'success',
			duration: 1000
		})
		setTimeout(() => {
			uni.navigateBack({ delta: 1 })
		}, 1000)
	}

	const startScan = () => {
		if (!scanFunctionIsUseable.value) return
		uni.scanCode({
			onlyFromCamera: true,
			success: (res) => {
				uni.__f__('log','at pages/scancode/scancode.uvue:35','扫码成功res:', res)
				const result = res.result
				if (result != null) handleScanResult(result)
			},
			fail: (err) => {
				uni.__f__('log','at pages/scancode/scancode.uvue:40','扫码失败:', err)
				uni.showToast({ title: '扫码失败', icon: 'none' })
				goBack()
			}
		})
	}

	onLoad(() => {
		startScan()
	})
</script>

