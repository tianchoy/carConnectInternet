<template>
	<view class="container">
		<custom-navBar title="йҰ–йЎө" :show-back="false" backgroundColor="#fff" textColor="#333" :showCapsule="false">
		</custom-navBar>
		<view class="map-container" v-if="showMap">
			<map id="myMap" :markers="markers"
				:scale="mapScale" style="width:100%;height:100%" :show-location="true" @markertap="handleTap">
			</map>
		</view>
		<view v-else>
			<indexListMode :lists="filteredDevices" @unbindDevice="unbindDevice"/>
		</view>
		<view class="tool-nav">
			<view class="refresh" @click="refresh">еҲ·ж–°</view>
			<view class="addCar" @click="addCar">ж·»еҠ иҪҰиҫҶ</view>
			<view class="btn-map-list" @click="toggleMapMode">
				{{showMap ? 'иҪҰиҫҶеҲ—иЎЁ' : 'ең°еӣҫз•Ңйқў'}}
			</view>
		</view>
		<view class="right-bar" v-if="showMap">
			<view class="allCar" @click="goToList('all')">е…ЁйғЁ {{totalCount}}</view>
			<view class="onlineCar" @click="goToList('online')">еңЁзәҝ {{onlineCount}}</view>
			<view class="offlineCar" @click="goToList('offline')">зҰ»зәҝ {{offlineCount}}</view>
		</view>
		<view class="left-bar" @click="handStatePicker">
			<text>{{pickerStateTitle}}</text>
			<uv-icon name="arrow-down" color="#fff"></uv-icon>
		</view>
		<view class="left-bar-state" @click="handGroupPicker" v-if="!showMap">
			<text>{{pickerGroupTitle}}</text>
			<uv-icon name="arrow-down" color="#fff"></uv-icon>
		</view>
		<uv-picker ref="picker" :columns="columns" keyName="name" @confirm="confirm"></uv-picker>
	</view>
</template>

<script setup lang="uts">
	import { ref, reactive, onMounted, computed, watch } from 'vue'
	import { getCustomList, getCustomDeviceList, getUserInfo, getUserDeviceList, getUserGroupList, delDevice } from '../../api/request.uts'
	// еҜје…Ҙеқҗж ҮиҪ¬жҚўжҸ’д»¶
	import CoordTransform from '../../utils/coordTransform.uts'
	import { getOnlineDeviceIcon, getOfflineDeviceIcon } from '../../utils/cars'

	const Login = ref<boolean>(false)
	const mapScale = ref(4)
	const showMap = ref(true)
	const markers = ref<Array<any>>([])
	let mapCtx = undefined
	const currentPickerType = ref('')
	const picker = ref(null)

	// зҠ¶жҖҒйҖүйЎ№
	const carState = ref([
		[{
			name: 'е…ЁйғЁзҠ¶жҖҒ',
			value: '0'
		},
		{
			name: 'еңЁзәҝ',
			value: '1'
		},
		{
			name: 'зҰ»зәҝ',
			value: '2'
		}]
	])

	// еҲҶз»„йҖүйЎ№
	const carGroup = ref<any>([])
	const columns = ref<Array<{ name : string, value : string }>>([[]])
	const pickerStateTitle = ref('е…ЁйғЁзҠ¶жҖҒ')
	const pickerGroupTitle = ref('е…ЁйғЁеҲҶз»„')

	// еҺҹе§Ӣи®ҫеӨҮеҲ—иЎЁ
	const originalDeviceList = ref<Array<any>>([])
	// еҪ“еүҚйҖүдёӯзҡ„еҲҶз»„ID
	const currentGroupId = ref<string>('')

	// и®Ўз®—еұһжҖ§ зӯӣйҖүйҖ»иҫ‘
	const filteredDevices = computed(() => {
		if (!Array.isArray(originalDeviceList.value)) return []

		let result = [...originalDeviceList.value]

		// зҠ¶жҖҒзӯӣйҖү
		if (pickerStateTitle.value == 'еңЁзәҝ') {
			result = result.filter(device => device?.connectionStatus == 'online')
		} else if (pickerStateTitle.value === 'зҰ»зәҝ') {
			result = result.filter(device => device?.connectionStatus == 'offline')
		}

		return result
	})

	// и®Ўз®—и®ҫеӨҮж•°йҮҸз»ҹи®Ў
	const totalCount = computed(() => originalDeviceList.value.length)
	const onlineCount = computed(() => originalDeviceList.value.filter(d => d?.connectionStatus == 'online').length)
	const offlineCount = computed(() => totalCount.value - onlineCount.value)

	// иҮӘеҠЁжӣҙж–°ең°еӣҫж Үи®°
	watch([filteredDevices, showMap], ([devices, isMapVisible]) => {
		if (isMapVisible) {
			updateMarkers(devices)
		}
	})
	
	// и·іиҪ¬еҲ°еҲ—иЎЁйЎөйқў
	const goToList = (status : string) => {
		// е…ҲеҲҮжҚўеҲ°еҲ—иЎЁжЁЎејҸ
		showMap.value = false
		
		// ж №жҚ®зҠ¶жҖҒи®ҫзҪ®зӯӣйҖүжқЎд»¶
		switch(status) {
			case 'all':
				pickerStateTitle.value = 'е…ЁйғЁзҠ¶жҖҒ'
				break
			case 'online':
				pickerStateTitle.value = 'еңЁзәҝ'
				break
			case 'offline':
				pickerStateTitle.value = 'зҰ»зәҝ'
				break
		}
	}

		// и§Јз»‘и®ҫеӨҮ
		const unbindDevice = async (imei : string) => {
			const res = await delDevice(imei)
			if (res.code == 0) {
				uni.showToast({
					title: 'и§Јз»‘жҲҗеҠҹ',
					icon: 'success'
				})
			} else {
				uni.showToast({
					title: 'и§Јз»‘еӨұиҙҘ',
					icon: 'error'
				})
			}
			// и§Јз»‘жҲҗеҠҹеҗҺеҲ·ж–°и®ҫеӨҮеҲ—иЎЁ
			await loadUserDeviceList(currentGroupId.value)
		}

	const handStatePicker = () => {
		columns.value = carState.value
		currentPickerType.value = 'state'
		picker.value?.open()
	}

	const handGroupPicker = () => {
		columns.value = carGroup.value
		currentPickerType.value = 'group'
		picker.value?.open()
	}

	const confirm = async (e : { value : Array<{ name : string, value : string, id : string }> }) => {
		const selected = e.value[0]
		if (currentPickerType.value == 'state') {
			pickerStateTitle.value = selected.name
		} else if (currentPickerType.value == 'group') {
			pickerGroupTitle.value = selected.name
			currentGroupId.value = selected.id
			// ж №жҚ®йҖүжӢ©зҡ„еҲҶз»„йҮҚж–°еҠ иҪҪи®ҫеӨҮеҲ—иЎЁ
			await loadUserDeviceList(selected.id)
		}
		currentPickerType.value = ''
	}

	const addCar = () => {
		uni.navigateTo({
			url: '/pages/addCar/addCar'
		})
	}

	const toggleMapMode = () => {
		showMap.value = !showMap.value
	}

	const handleTap = (e) => {
	  const markerId = e.detail.markerId
	  const selectedDevice = originalDeviceList.value.find(device => device.deviceId == markerId)
	  
	  if (selectedDevice) {
	    uni.navigateTo({
	      url: `/pages/carInfoDetail/carInfoDetail?imei=${selectedDevice.imei}&deptId=${selectedDevice.companyId}&deviceId=${selectedDevice.deviceId}`,
	    })
	  } else {
	    uni.__f__('warn','at pages/index/index.uvue:188','жңӘжүҫеҲ°еҜ№еә”зҡ„и®ҫеӨҮдҝЎжҒҜ', markerId)
	  }
	}

	const updateMarkers = (devices) => {
		if (!Array.isArray(devices)) {
			devices = []
		}

		markers.value = devices.map((device, index) => {
			if (!device || typeof device !== 'object') {
				uni.__f__('warn','at pages/index/index.uvue:199','ж— ж•Ҳзҡ„и®ҫеӨҮж•°жҚ®', device)
				return null
			}
			
			const lat = Number(device.latitude)
			const lng = Number(device.longitude)

			if (isNaN(lat) || isNaN(lng)) {
				uni.__f__('warn','at pages/index/index.uvue:207','и®ҫеӨҮз»Ҹзә¬еәҰж— ж•Ҳ', device)
				return null
			}

			return {
				id: Number(device.deviceId),
				latitude: lat,
				longitude: lng,
				iconPath: device.connectionStatus == 'online' ? getOnlineDeviceIcon(device.carType) : getOfflineDeviceIcon(device.carType),
				width: 25,
				height: 25,
				callout: {
					padding: 5,
					borderWidth: 1,
					borderRadius: 10,
					bgColor: '#ffffff',
					content: device.deviceName || device.plateNo || 'жңӘе‘ҪеҗҚи®ҫеӨҮ',
					display: 'ALWAYS'
				},
				joinCluster: true, // е…Ғи®ёиҒҡеҗҲ
				clusterId: `${lat.toFixed(2)}_${lng.toFixed(2)}`,
				
			}
		}).filter(marker => marker !== null)
	}


	const loadGroupData = async () => {
		try {
			// дҪҝз”Ёж–°зҡ„ getUserGroupList жҺҘеҸЈ
			const groupRes = await getUserGroupList()
			if (groupRes?.code !== 0 || !Array.isArray(groupRes.data)) {
				throw new Error('иҺ·еҸ–еҲҶз»„ж•°жҚ®еӨұиҙҘ')
			}

			// ж јејҸеҢ–еҲҶз»„ж•°жҚ®пјҢж·»еҠ е…ЁйғЁеҲҶз»„йҖүйЎ№
			const allGroupOption = {
				name: 'е…ЁйғЁеҲҶз»„',
				value: 'all',
				id: 'all'
			}

			const formattedData = groupRes.data.map(item => ({
				name: item.name || 'жңӘе‘ҪеҗҚеҲҶз»„',
				value: item.id || '',
				id: item.id || ''
			}))

			// е°Ҷе…ЁйғЁеҲҶз»„йҖүйЎ№ж·»еҠ еҲ°жңҖеүҚйқў
			formattedData.unshift(allGroupOption)

			carGroup.value = [formattedData]
			pickerGroupTitle.value = 'е…ЁйғЁеҲҶз»„'
			currentGroupId.value = 'all'
			
		} catch (err) {
			uni.__f__('error','at pages/index/index.uvue:263','еҠ иҪҪеҲҶз»„ж•°жҚ®еӨұиҙҘ:', err)
			uni.showToast({
				title: 'еҠ иҪҪеҲҶз»„еӨұиҙҘ',
				icon: 'none'
			})
		}
	}
	
	const refresh = async () => {
		await loadUserDeviceList()
	}

	const loadUserDeviceList = async (groupId : string = '') => {
		try {
			let params = {
				pageSize: 1000
			}
			// еҰӮжһңдёҚжҳҜе…ЁйғЁеҲҶз»„пјҢж·»еҠ еҲҶз»„IDеҸӮж•°
			if (groupId && groupId !== 'all') {
				params = { groupId: groupId }
			}

			const res = await getUserDeviceList(params)
			uni.__f__('log','at pages/index/index.uvue:286','APIе“Қеә”ж•°жҚ®:', res)

			let deviceList = []
			if (res?.data) {
				if (Array.isArray(res.data)) {
					deviceList = res.data
				} else if (Array.isArray(res.data.list)) {
					deviceList = res.data.list
				} else if (Array.isArray(res.data.devices)) {
					deviceList = res.data.devices
				} else if (Array.isArray(res.data.items)) {
					deviceList = res.data.items
				} else if (res.data.totalCount !== undefined) {
					deviceList = []
				}
			}

			uni.__f__('log','at pages/index/index.uvue:303','и§ЈжһҗеҗҺзҡ„и®ҫеӨҮеҲ—иЎЁ:', deviceList)
			
			// дҪҝз”ЁжҸ’д»¶иҪ¬жҚўеқҗж Ү
			originalDeviceList.value = CoordTransform.batchConvertCoordinates(deviceList, 'tencent')
			
		} catch (err) {
			uni.__f__('error','at pages/index/index.uvue:309','иҺ·еҸ–и®ҫеӨҮеҲ—иЎЁеӨұиҙҘ:', err)
			uni.showToast({
				title: 'иҺ·еҸ–и®ҫеӨҮеҲ—иЎЁеӨұиҙҘ',
				icon: 'none'
			})
		}
	}
	
	// ж·»еҠ е…ЁеұҖдәӢд»¶зӣ‘еҗ¬пјҢз”ЁдәҺд»Һж·»еҠ йЎөйқўиҝ”еӣһж—¶еҲ·ж–°
	const refreshDeviceList = () => {
		uni.__f__('log','at pages/index/index.uvue:319','ж”¶еҲ°еҲ·ж–°дәӢд»¶пјҢйҮҚж–°еҠ иҪҪи®ҫеӨҮеҲ—иЎЁ')
		loadUserDeviceList()
	}

	const getUserIn = async () => {
		try {
			const res = await getUserInfo()
			if (res?.code === 0) {
				uni.setStorageSync('userType', res.data.type)
			}
		} catch (err) {
			uni.__f__('error','at pages/index/index.uvue:330','иҺ·еҸ–з”ЁжҲ·дҝЎжҒҜеӨұиҙҘ:', err)
		}
	}

	onShow(async () => {
		const token = uni.getStorageSync('token')
		if(token){
			// зӣ‘еҗ¬е…ЁеұҖеҲ·ж–°дәӢд»¶
			// refreshDeviceList()
			uni.$on('refreshDeviceList', refreshDeviceList)
			
			const needRefresh = uni.getStorageSync('needRefreshHome')
			if (needRefresh) {
				await loadUserDeviceList(currentGroupId.value)
				uni.removeStorageSync('needRefreshHome')
			}
		}
	})
	
	onHide(() => {
		// з§»йҷӨдәӢд»¶зӣ‘еҗ¬
		uni.$off('refreshDeviceList', refreshDeviceList)
	})

	onLoad(async () => {
		const token = uni.getStorageSync('token')
		uni.__f__('log','at pages/index/index.uvue:356',token)
		if (!token) {
			uni.redirectTo({ url: '/pages/login/login' })
			Login.value = false
		} else {
			Login.value = true
			await loadGroupData()
			await loadUserDeviceList()
			await getUserIn()

			// еҲқе§ӢеҢ–ең°еӣҫдёҠдёӢж–Ү
			mapCtx = uni.createMapContext('myMap', this)

			// еҗҜз”ЁзӮ№иҒҡеҗҲ
			if (mapCtx && mapCtx.initMarkerCluster) {
				mapCtx.initMarkerCluster({
					enableDefaultStyle: true,
					zoomOnClick: true,
					gridSize: 60,
					complete: () => {
						uni.__f__('log','at pages/index/index.uvue:376','иҒҡеҗҲеҲқе§ӢеҢ–е®ҢжҲҗ')
					}
				})
			}
		}
	})
	
	onUnload(() => {
		// жё…зҗҶдәӢд»¶зӣ‘еҗ¬
		uni.$off('refreshDeviceList', refreshDeviceList)
	})

</script>

<style lang="scss">
	.container {
		position: relative;
		width: 100%;
		height: 100vh;
		display: flex;
		flex-direction: column;
		background-color: #f5f7fa;

		.map-container {
			flex: 1;
			width: 100%;
			position: relative;
		}

		.tool-nav {
			position: absolute;
			top: 200rpx;
			right: 20rpx;
			z-index: 100;
			display: flex;
			flex-direction: row;
			justify-content: center;
			align-items: center;
			font-size: 25rpx;

			.btn-map-list {
				padding: 7rpx 10rpx;
				background-color: #1296db;
				color: #fff;
				border-radius: 10rpx;
			}

			.addCar {
				padding: 7rpx 10rpx;
				background-color: #1296db;
				color: #fff;
				border-radius: 10rpx;
				margin-right: 10rpx;
			}
			.refresh{
				padding: 7rpx 10rpx;
				background-color: #1296db;
				color: #fff;
				border-radius: 10rpx;
				margin-right: 10rpx;
			}
		}

		.right-bar {
			position: absolute;
			top: 300rpx;
			right: 20rpx;
			z-index: 100;
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;

			view {
				padding: 5rpx 15rpx;
				font-size: 25rpx;
				margin-bottom: 20rpx;
				border-radius: 10rpx;
				color: #fff;
				/* ж·»еҠ зӮ№еҮ»ж•Ҳжһң */
				transition: all 0.2s;
			}
			
			view:active {
				transform: scale(0.95);
				opacity: 0.8;
			}

			.allCar {
				background-color: #1296db;
			}

			.onlineCar {
				background-color: #0da117;
			}

			.offlineCar {
				background-color: #d81e06;
			}
		}

		.left-bar,
		.left-bar-state {
			position: absolute;
			top: 200rpx;
			z-index: 100;
			display: flex;
			align-items: center;
			padding: 10rpx;
			border-radius: 10rpx;
			background-color: rgba(3, 109, 246, 0.71);
			color: #fff;
			font-size: 25rpx;
			display: flex;
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}

		.left-bar {
			left: 20rpx;
		}

		.left-bar-state {
			left: 180rpx;
		}
	}
</style>