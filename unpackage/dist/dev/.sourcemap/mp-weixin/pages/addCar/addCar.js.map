<template>
	<view class="container">
		<custom-navBar title="жЈїеК†иљ¶иЊЖ" :show-back="true" backgroundColor="#fff" textColor="#333" :showCapsule="false">
		</custom-navBar>
		<view class="content">
			<uv-form labelPosition="left" :model="carInfo" :rules="rules" ref="formRef">
				<uv-form-item label="иЃЊе§ЗеРНзІ∞" labelWidth="150rpx" prop="deviceName" borderBottom>
					<uv-input border="none" v-model="carInfo.deviceName" placeholder="иѓЈиЊУеЕ•иЃЊе§ЗеРНзІ∞">
					</uv-input>
				</uv-form-item>
				<uv-form-item label="*иЃЊе§ЗIMEI" labelWidth="150rpx" prop="imei" borderBottom>
					<uv-input border="none" v-model="carInfo.imei" placeholder="иѓЈиЊУеЕ•иЃЊе§ЗIMEI(ењЕе°Ђ)">
					</uv-input>
				</uv-form-item>
				<uv-form-item label="*иЃЊе§Зз±їеЮЛ" labelWidth="150rpx" prop="deviceType" borderBottom
					@click="deviceTypeSelectFun">
					<uv-input border="none" v-model="carInfo.deviceType" disabled disabledColor="#fff"
						placeholder="иѓЈйАЙжЛ©иЃЊе§Зз±їеЮЛ(ењЕйАЙ)" suffixIcon="arrow-down">
					</uv-input>
				</uv-form-item>
				<uv-form-item label="иљ¶зЙМеПЈ" labelWidth="150rpx" prop="plateNo" borderBottom>
					<car-number-input @numberInputResult="handlePlateNumberChange" :defaultStr="'дЇђA'" />
				</uv-form-item>
				<uv-action-sheet ref="deviceTypeSelect" :actions="actions" title="иѓЈйАЙжЛ©иЃЊе§Зз±їеЮЛ"
					@select="deviceTypeSelectsFun" :loading="actions.length === 0">
				</uv-action-sheet>
			</uv-form>
		</view>
		<uv-button class="btn" type="primary" @click="submit" :loading="loading">жПРдЇ§</uv-button>
	</view>
</template>

<script setup lang="uts">
	import { ref } from 'vue'
	import { addDevice, getCarType } from '../../api/request'

	interface FormData {
		deviceName : string
		imei : string
		deviceType : string
		deviceTypeValue : string
		plateNo : string
	}

	const formRef = ref(null)
	const deviceTypeSelect = ref(null)
	const loading = ref(false)
	const carInfo = ref<FormData>({
		deviceName: '',
		imei: '',
		deviceType: '',
		deviceTypeValue: '',
		plateNo: ''
	})

	const actions = ref([])

	// иљ¶зЙМеПЈ
	const handlePlateNumberChange = (e : string) => {
		uni.__f__('log','at pages/addCar/addCar.uvue:60',e)
		carInfo.value.plateNo = e
	}

	const rules = {
		imei: [
			{
				required: true,
				message: 'иѓЈиЊУеЕ•иЃЊе§ЗIMEI',
				trigger: ['blur', 'change']
			},
			{
				min: 8,
				max: 15,
				message: 'IMEIйХњеЇ¶еЇФеЬ®8-15дљНдєЛйЧі',
				trigger: ['blur', 'change']
			}
		],
		deviceType: [
			{
				required: true,
				message: 'иѓЈйАЙжЛ©иЃЊе§Зз±їеЮЛ',
				trigger: ['blur', 'change']
			}
		]
	}

	const deviceTypeSelectFun = async () => {
		// е¶ВжЮЬињШж≤°жЬЙеК†иљљињЗжХ∞жНЃ
		if (actions.value.length === 0) {
			uni.showLoading({
				title: 'еК†иљљдЄ≠...'
			})
			try {
				await loadCarTypeData()
			} finally {
				uni.hideLoading()
			}
		}
		// з°ЃдњЭжЬЙжХ∞жНЃеРОеЖНжЙУеЉАйАЙжЛ©еЩ®
		if (actions.value.length > 0) {
			deviceTypeSelect.value?.open()
		}
	}

	const deviceTypeSelectsFun = (e) => {
		carInfo.value.deviceType = e.name
		carInfo.value.deviceTypeValue = e.value
	}

	const submit = () => {
		formRef.value?.validate().then(async () => {
			loading.value = true
			try {
				const submitData = {
					deviceName: carInfo.value.deviceName,
					imei: carInfo.value.imei,
					deviceType: carInfo.value.deviceTypeValue,
					plateNo: carInfo.value.plateNo
				}

				const res = await addDevice(submitData)

				if (res.code == 200) {
					uni.showToast({
						title: 'жЈїеК†жИРеКЯ',
						icon: 'success'
					})
					setTimeout(() => {
						uni.navigateBack()
					}, 1500)
				} else {
					uni.showToast({
						title: res.msg || 'жЈїеК†е§±иі•',
						icon: 'none',
						duration:2000
					})
				}
			} catch (error) {
				uni.__f__('error','at pages/addCar/addCar.uvue:139','жЈїеК†иЃЊе§ЗйФЩиѓѓ:', error)
				uni.showToast({
					title: 'иѓЈж±Ве§±иі•пЉМиѓЈз®НеРОйЗНиѓХ',
					icon: 'none'
				})
			} finally {
				loading.value = false
			}
		}).catch((errors) => {
			uni.__f__('error','at pages/addCar/addCar.uvue:148','й™МиѓБйФЩиѓѓ:', errors)
			uni.showToast({
				title: 'иѓЈж£АжЯ•и°®еНХ',
				icon: 'none'
			})
		})
	}

	onLoad(() => {
		loadCarTypeData()
	})

	const loadCarTypeData = async () => {
		try {
			const res = await getCarType()
			if (res.msg == 'success') {
				// иљђжНҐжХ∞жНЃзїУжЮДпЉМеМєйЕНзїДдїґйЬАи¶БзЪДж†ЉеЉП
				actions.value = res.data.map(item => ({
					name: item.typeName,  // жШЊз§ЇзЪДеРНзІ∞
					value: item.id.toString()  // еЃЮйЩЕеАЉ
				}))
			} else {
				uni.showToast({
					title: 'иОЈеПЦиљ¶иЊЖеУБзЙМе§±иі•',
					icon: 'none'
				})
			}
		} catch (error) {
			uni.showToast({
				title: 'иѓЈж±Ве§±иі•пЉМиѓЈйЗНиѓХ',
				icon: 'none'
			})
		}
	}
</script>

<style lang="scss" scoped>
	.container {
		width: 100%;
		height: 100vh;
		background-color: #f5f5f5;

		.content {
			margin: 20rpx;
			padding: 20rpx 40rpx;
			background-color: #fff;
			border-radius: 20rpx;
		}

		.btn {
			margin: 50rpx 20rpx 0 20rpx;
		}

		.plate-input {
			width: 100%;

			:deep(.input-wrapper) {
				padding: 0;
				border: none;
			}
		}

		// иљ¶зЙМиЊУеЕ•зїДдїґж†ЈеЉП
		:deep(.car-input-container) {
			display: flex;
			flex-direction: row;
		}

		:deep(.car-number-input) {
			width: 60%;
			text-align: right;
		}

		:deep(.car-number-container .plate-close) {
			height: 40px;
			display: flex;
			text-align: right;
			background-color: #FFF;
			flex-direction: row;
			justify-content: flex-end;
			align-items: center;
		}

		:deep(.car-input-container .car-input-box .car-input-item) {
			position: relative;
			border: 1px solid #E2E2E2;
			height: 40px;
			line-height: 40px;
			text-align: center;
			font-size: 17px;
		}

		:deep(.car-input-container .car-input-box .car-input-item .new-item-img) {
			position: absolute;
			top: -2px;
			left: 50%;
			margin-left: -15px;
			height: 13px;
			width: 30px;
			z-index: 9;
		}
	}
</style>