<template>
	<view class="container">
		<custom-navBar title="зҷ»йҷҶ" :show-back="false" backgroundColor="#fff" textColor="#333" :showCapsule="false">
		</custom-navBar>
		<view class="banner">
			<image src="/static/car_location.png" mode="aspectFill"></image>
			<text class="title">иҪҰиҒ”зҪ‘</text>
		</view>

		<view class="content">
			<uv-form :model="form" :rules="rules" ref="formRef">
				<uv-form-item label="" prop="username" labelWidth="0">
					<uv-input prefixIcon="account-fill" v-model="form.username" placeholder="иҜ·иҫ“е…ҘиҙҰеҸ·" />
				</uv-form-item>
				<uv-form-item label="" prop="password" labelWidth="0">
					<uv-input prefixIcon="lock-fill" v-model="form.password" placeholder="иҜ·иҫ“е…ҘеҜҶз Ғ" :password="showpw"  customStyle="border:1rpx solid red;height:80rpx">
						<template v-slot:suffix>
							<uv-icon :name="showpw?'eye-off-outline':'eye'" @click="showpwfun" />
						</template>
					</uv-input>
				</uv-form-item>
			</uv-form>
			<view class="regisiter_box">
				<!-- <text @click="toSignUp">з«ӢеҚіжіЁеҶҢ</text> -->
			</view>
			<uv-button type="primary" @click="submit">жҸҗдәӨ</uv-button>
		</view>
		<view class=""></view>
	</view>
</template>

<script setup lang="uts">
	import { ref, onMounted } from 'vue'
	import { login } from '../../api/request.uts'
	const showpw = ref(true)

	// е®ҡд№үиЎЁеҚ•зұ»еһӢ
	type FormData = {
		username : string
		password : string
	}

	type UvFormInstance = {
		setRules : (rules : Record<string, any>) => void
		validate : () => Promise<boolean>
	}

	const form = ref<FormData>({
		username: '',
		password: ''
	})

	const formRef = ref<UvFormInstance | null>(null)
	const deviceModel= ref('')

	const rules = {
		username: [
			{
				required: true,
				message: 'иҜ·иҫ“е…ҘиҙҰеҸ·',
				trigger: ['blur', 'change']
			}
		],
		password: [
			{
				required: true,
				message: 'иҜ·иҫ“е…ҘеҜҶз Ғ',
				trigger: ['blur', 'change']
			}
		]
	}

	const showpwfun = () => {
		showpw.value = !showpw.value
	}


	//иҺ·еҸ–зі»з»ҹдҝЎжҒҜ
	const getSystemInfo = () => {
		const res = uni.getSystemInfoSync()
		uni.__f__('log','at pages/login/login.uvue:81',res)
		deviceModel.value = res.deviceModel
	}

	//жіЁеҶҢжҢүй’®
	const toSignUp = () => {
		uni.reLaunch({
			url:'/pages/signUp/signUp'
		})
	}

	onMounted(() => {
		getSystemInfo()
		if (formRef.value) {
			formRef.value.setRules(rules)
		}
	})

	const submit = () => {
		formRef.value?.validate().then(res => {
			const newFormData = {
				...form.value,
				from:deviceModel.value,
				type:"USER"
			}
			// иҜ·жұӮзҷ»йҷҶжҺҘеҸЈ
			login('POST',newFormData).then(res=>{
				uni.__f__('log','at pages/login/login.uvue:108','1111:',res.data.token)
				uni.setStorageSync('token',res.data.token)
				uni.reLaunch({
					url:'/pages/index/index'
				})
			})
			
		}).catch(errors => {
			uni.showToast({
				icon: 'error',
				title: 'ж ЎйӘҢеӨұиҙҘ'
			})
		})
	}
</script>

<style lang="scss" scoped>
	.container {
		height: 100vh;
		background-color: #fff;

		.banner {
			background-color: #fff;
			display: flex;
			flex-direction: row;
			justify-content: center;
			align-items: center;
			height: 20%;
			image {
				height: 120rpx;
				width: 120rpx;
				margin-right: 20rpx;
			}
			.title{
				font-size: 40rpx;
				font-weight: bold;
				color: #333;

			}
		}


		.content {
			background-color: #fff;
			padding: 20rpx 100rpx;

			.regisiter_box {
				font-size: 25rpx;
				margin: 10rpx 0 30rpx;
			}
		}
	}
</style>