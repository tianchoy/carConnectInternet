<script lang="uts">
	let firstBackTime = 0
	// 添加热更新相关变量
	let updateManager: any = null
	let hasUpdate = false
	function checkForUpdates() {
		// 仅在小程序平台生效

		// 检查是否支持 getUpdateManager API
		if (uni.canIUse('getUpdateManager')) {
			updateManager = uni.getUpdateManager()
			
			if (updateManager) {
				// 监听检查更新结果事件
				updateManager.onCheckForUpdate((res: any) => {
					uni.__f__('log','at App.uvue:16','检查更新结果:', res)
					if (res.hasUpdate) {
						hasUpdate = true
						uni.__f__('log','at App.uvue:19','发现新版本，正在后台下载...')
						uni.showLoading({
							title: '下载新版本中'
						})
					}
				})
				
				// 监听更新包下载完成事件
				updateManager.onUpdateReady(() => {
					uni.__f__('log','at App.uvue:28','新版本下载完成')
					uni.hideLoading()
					
					// 弹窗提示用户重启应用
					uni.showModal({
						title: '更新提示',
						content: '新版本已经准备好，是否重启应用？',
						confirmText: '立即重启',
						cancelText: '稍后再说',
						success: (res: any) => {
							if (res.confirm) {
								// 应用新版本并强制当前页面重启
								updateManager.applyUpdate()
							}
						}
					})
				})
				
				// 监听更新包下载失败事件
				updateManager.onUpdateFailed(() => {
					uni.__f__('error','at App.uvue:48','新版本下载失败')
					uni.hideLoading()
					
					// 给出失败提示
					uni.showModal({
						title: '更新失败',
						content: '新版本下载失败，请检查网络设置或稍后再试',
						showCancel: false,
						confirmText: '知道了'
					})
				})
			}
		} else {
			// 不支持更新API的提示
			uni.showModal({
				title: '提示',
				content: '当前微信版本过低，无法使用自动更新功能，请升级到最新微信版本后重试。',
				showCancel: false
			})
		}

	}
	
	export default {
		onLaunch: function () {
			uni.__f__('log','at App.uvue:73','App onLaunch')
			checkForUpdates()
		},
		onShow: function () {
			uni.__f__('log','at App.uvue:77','App Show')
		},
		onHide: function () {
			uni.__f__('log','at App.uvue:80','App Hide')
		},


















		onExit: function () {
			uni.__f__('log','at App.uvue:101','App Exit')
		}
	}
</script>

