<template>
	<view class="container">
		<custom-navBar title="添加设备" :show-back="true" backgroundColor="#fff" textColor="#333" :showCapsule="false">
		</custom-navBar>
		<view class="content">
			<uv-form labelPosition="left" :model="carInfo" :rules="rules" ref="formRef">
				<uv-form-item label="设备名称" labelWidth="150rpx" prop="deviceName" borderBottom>
					<uv-input border="none" v-model="carInfo.deviceName" placeholder="请输入设备名称">
					</uv-input>
				</uv-form-item>
				<uv-form-item label="*设备ID" labelWidth="150rpx" prop="imei" borderBottom>
					<uv-input border="none" v-model="carInfo.imei" placeholder="请输入设备ID(必填)">
						<template v-slot:suffix>
							<uv-icon name="scan" size="25" @click="scanCode"></uv-icon>
						</template>
					</uv-input>
				</uv-form-item>
				<uv-form-item label="车标" labelWidth="150rpx" prop="deviceType" borderBottom
					@click="deviceTypeSelectFun">
					<uv-input border="none" v-model="carInfo.deviceTypeValue" disabled disabledColor="#fff"
						placeholder="请选择设备图标(必选)" suffixIcon="arrow-down">
					</uv-input>
				</uv-form-item>
				<!-- <uv-form-item label="*设备类型" labelWidth="150rpx" prop="deviceType" borderBottom
					@click="deviceTypeSelectFun">
					<uv-input border="none" v-model="carInfo.deviceType" disabled disabledColor="#fff"
						placeholder="请选择设备类型(必选)" suffixIcon="arrow-down">
					</uv-input>
				</uv-form-item>
				<uv-form-item label="车牌号" labelWidth="150rpx" prop="plateNo" borderBottom>
					<car-number-input @numberInputResult="handlePlateNumberChange" :defaultStr="'京A'" />
				</uv-form-item> -->
				<!-- <uv-action-sheet ref="deviceTypeSelect" :actions="actions" title="请选择设备类型"
					@select="deviceTypeSelectsFun" :loading="actions.length === 0">
				</uv-action-sheet> -->
				<!-- <uv-popup ref="deviceTypeSelect" title="请选择图标" mode="bottom">
					<uv-grid :col="5">
						<uv-grid-item v-for="(item,index) in IconList" :key="index" @click="selectIcon(item)">
							<uv-icon :customStyle="{paddingTop:20+'rpx'}" :name="item.img" :size="50"></uv-icon>
							<text class="grid-text">{{item.title}}</text>
						</uv-grid-item>
					</uv-grid>
				</uv-popup> -->
				<carIcons ref="deviceTypeSelect"  @select="selectIcon"></carIcons>
			</uv-form>
		</view>
		<uv-button class="btn" type="primary" @click="submit" :loading="loading">提交</uv-button>
	</view>
</template>

<script setup lang="uts">
	import { ref, onUnmount } from 'vue'
	import { addDevice, getCarType } from '../../api/request'
	import carIcons from '../../components/car-icons/car-icons.uvue'


	interface FormData {
		deviceName : string
		imei : string
		deviceType : string
		deviceTypeValue : string
		plateNo : string
		carType : string
	}

	const formRef = ref(null)
	const deviceTypeSelect = ref(null)
	const loading = ref(false)
	const carInfo = ref<FormData>({
		deviceName: '',
		imei: '',
		deviceType: '',
		deviceTypeValue: '',
		plateNo: '',
		carType : ''
	})

	const actions = ref([])

	// 车牌号
	const handlePlateNumberChange = (e : string) => {
		uni.__log__('log','at pages/addCar/addCar.uvue:82',e)
		carInfo.value.plateNo = e
	}
	
	// 扫码功能
	const scanCode = () => {
		uni.navigateTo({
			url:'/pages/scancode/scancode'
		})
	}

	// 扫码结果事件处理
	const handleScanResult = (data: { result: string }) => {
		uni.__log__('log','at pages/addCar/addCar.uvue:95','接收到扫码结果:', data.result)
		//检查长度是15位，取后11位，并在前面 补零0 ，若为 11 位，则直接补 0
		if (data.result.length === 15) {
			carInfo.value.imei = '0' + data.result.slice(4,15)
		} else if (data.result.length === 11) {
			carInfo.value.imei = '0' + data.result
		} else {
			uni.showToast({
				title: '请输入正确的设备ID',
				icon: 'none'
			})
		}
	}

	const rules = {
		imei: [
			{
				required: true,
				message: '请输入设备ID',
				trigger: ['blur', 'change']
			},
			{
				min: 8,
				max: 18,
				message: 'ID长度应在8-18位之间',
				trigger: ['blur', 'change']
			}
		],
		deviceType: [
			{
				required: true,
				message: '请选择设备图标',
				trigger: ['blur', 'change']
			}
		]
	}

	const selectIcon = (item) => {
		uni.__log__('log','at pages/addCar/addCar.uvue:133',item.name);
		carInfo.value.deviceType = item.name
		carInfo.value.deviceTypeValue = item.title
		deviceTypeSelect.value?.close()
	}

	const deviceTypeSelectFun = async () => {
		// 如果还没有加载过数据
		// if (actions.value.length === 0) {
		// 	uni.showLoading({
		// 		title: '加载中...'
		// 	})
		// 	try {
		// 		await loadCarTypeData()
		// 	} finally {
		// 		uni.hideLoading()
		// 	}
		// }
		// // 确保有数据后再打开选择器
		// if (actions.value.length > 0) {
		// 	deviceTypeSelect.value?.open()
		// }
		deviceTypeSelect.value?.open()
	}

	const deviceTypeSelectsFun = (e) => {
		carInfo.value.deviceType = e.name
		carInfo.value.deviceTypeValue = e.value
	}

	// 刷新首页设备列表的方法
	const refreshDeviceList = () => {
		uni.$emit('refreshDeviceList')
		uni.__log__('log','at pages/addCar/addCar.uvue:166','已触发首页设备列表刷新')
	}

	const submit = () => {
		formRef.value?.validate().then(async () => {
			loading.value = true
			try {
				const submitData = {
					deviceName: carInfo.value.deviceName,
					imei: carInfo.value.imei,
					carType: carInfo.value.deviceType,
					// plateNo: carInfo.value.plateNo
				}

				uni.__log__('log','at pages/addCar/addCar.uvue:180',submitData)

				const res = await addDevice(submitData)

				if (res.code == 0) {
					uni.showToast({
						title: '添加成功',
						icon: 'success'
					})

					uni.setStorageSync('needRefreshHome', true)

					// 添加成功后触发首页刷新
					refreshDeviceList()

					setTimeout(() => {
						uni.navigateBack()
					}, 1500)
				} else {
					uni.showToast({
						title: res.msg || '添加失败',
						icon: 'none',
						duration: 2000
					})
				}
			} catch (error) {
				uni.__log__('error','at pages/addCar/addCar.uvue:206','添加设备错误:', error)
				uni.showToast({
					title: '请求失败，请稍后重试',
					icon: 'none'
				})
			} finally {
				loading.value = false
			}
		}).catch((errors) => {
			uni.__log__('error','at pages/addCar/addCar.uvue:215','验证错误:', errors)
			uni.showToast({
				title: '请检查表单',
				icon: 'none'
			})
		})
	}

	onLoad(() => {
		// loadCarTypeData()
		// 注册扫码结果事件监听
		uni.$on('scanCodeResult', handleScanResult)
	})

	onUnload(() => {
		// 移除事件监听，防止内存泄漏
		uni.$off('scanCodeResult', handleScanResult)
	})

	// const loadCarTypeData = async () => {
	// 	try {
	// 		const res = await getCarType()
	// 		if (res.msg == 'success') {
	// 			// 转换数据结构，匹配组件需要的格式
	// 			actions.value = res.data.map(item => ({
	// 				name: item.typeName,  // 显示的名称
	// 				value: item.id.toString()  // 实际值
	// 			}))
	// 		} else {
	// 			uni.showToast({
	// 				title: '获取车辆品牌失败',
	// 				icon: 'none'
	// 			})
	// 		}
	// 	} catch (error) {
	// 		uni.showToast({
	// 			title: '请求失败，请重试',
	// 			icon: 'none'
	// 		})
	// 	}
	// }
</script>

