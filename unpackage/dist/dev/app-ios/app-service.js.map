// 定义类型
interface RequestOptions {
    url: string
    method?: 'GET' | 'POST' | 'PUT' | 'DELETE' | 'OPTIONS' | 'HEAD'
    data?: any
    header?: Record<string, string>
    showLoading?: boolean
    [key: string]: any
}

interface HttpResponse<T = any> {
    code: number
    message: string
    data: T
}

interface HttpError {
    statusCode: number
    message: string
    data?: any
}

const BASE_URL = 'https://car.zdiot.cn:18443/api'

// 处理token过期的函数
function handleTokenExpired(): void {
    console.log('检测到token过期，执行跳转登录页逻辑')
    
    // 清除本地token
    uni.removeStorageSync('token')
    
    // 显示提示
    uni.showToast({
        title: '登录已过期，请重新登录',
        icon: 'none',
        duration: 2000
    })
    
    // 使用定时器确保Toast显示完成后再跳转
    setTimeout(() => {
        console.log('正在跳转到登录页...')
        uni.redirectTo({
            url: '/pages/login/login',
            success: () => {
                console.log('跳转登录页成功')
            },
            fail: (err) => {
                console.log('跳转登录页失败:', err)
                // 如果跳转失败，尝试使用 reLaunch
                uni.reLaunch({
                    url: '/pages/login/login'
                })
            }
        })
    }, 1500)
}

// 请求拦截器
function requestInterceptor(config: RequestOptions): RequestOptions {
    const token = uni.getStorageSync('token')
    if (token) {
        config.header = config.header || {}
        config.header['token'] = `${token}`
    }
    
    // 显示加载中
    // if (config.showLoading !== false) {
    //     uni.showLoading({
    //         title: '加载中...',
    //         mask: true
    //     })
    // }
    
    return config
}

// 响应拦截器
function responseInterceptor(response: any, config: RequestOptions): any {
    // 隐藏加载中
    // if (config.showLoading !== false) {
    //     uni.hideLoading()
    // }
    
    // 处理 HTTP 状态码
    const statusCode = response.statusCode
    
    if (statusCode === 200) {
        return response.data
    } else {
        // 创建统一的错误对象
        const error: HttpError = {
            statusCode: statusCode,
            message: response.errMsg || `请求失败: ${statusCode}`,
            data: response.data
        }
        throw error
    }
}

// 错误处理
function errorHandler(error: HttpError, config: RequestOptions): void {
    // 隐藏加载中
    if (config.showLoading !== false) {
        uni.hideLoading()
    }
    
    console.log('请求错误详情:', error)
    
    // 处理错误状态码
    if (error.statusCode) {
        switch (error.statusCode) {
            case 401:
                handleTokenExpired()
                break
            case 403:
                uni.showToast({
                    title: '没有权限访问',
                    icon: 'none'
                })
                break
            case 404:
                uni.showToast({
                    title: '请求资源不存在',
                    icon: 'none'
                })
                break
            case 500:
                uni.showToast({
                    title: '服务器错误',
                    icon: 'none'
                })
                break
            default:
                uni.showToast({
                    title: error.message || `请求错误: ${error.statusCode}`,
                    icon: 'none'
                })
        }
    } else {
        // 网络错误等
        uni.showToast({
            title: '网络错误，请检查网络连接',
            icon: 'none'
        })
    }
}

// 封装uni.request
function request<T = any>(options: RequestOptions): Promise<T> {
    // 合并配置
    const config: RequestOptions = {
        url: options.url,
        method: options.method || 'GET',
        data: options.data || {},
        header: options.header || {},
        showLoading: options.showLoading !== false,
        ...options
    }
    
    // 处理完整URL
    if (!config.url.startsWith('http')) {
        config.url = BASE_URL + config.url
    }
    
    // 请求拦截
    const processedConfig = requestInterceptor(config)
    
    return new Promise<T>((resolve, reject) => {
        uni.request({
            ...processedConfig,
            success: (res: any) => {
                try {
                    const data = responseInterceptor(res, processedConfig)
                    resolve(data as T)
                } catch (error) {
                    // 确保错误被正确捕获和处理
                    errorHandler(error as HttpError, processedConfig)
                    reject(error)
                }
            },
            fail: (error: any) => {
                const httpError: HttpError = {
                    statusCode: 0,
                    message: error.errMsg || '网络请求失败',
                    data: error
                }
                errorHandler(httpError, processedConfig)
                reject(httpError)
            }
        })
    })
}

// 封装常用方法
const http = {
    get<T = any>(url: string, data: any = {}, options: RequestOptions = {}): Promise<T> {
        return request<T>({
            url,
            data,
            method: 'GET',
            ...options
        })
    },
    
    post<T = any>(url: string, data: any = {}, options: RequestOptions = {}): Promise<T> {
        return request<T>({
            url,
            data,
            method: 'POST',
            ...options
        })
    },
    
    put<T = any>(url: string, data: any = {}, options: RequestOptions = {}): Promise<T> {
        return request<T>({
            url,
            data,
            method: 'PUT',
            ...options
        })
    },
    
    delete<T = any>(url: string, data: any = {}, options: RequestOptions = {}): Promise<T> {
        return request<T>({
            url,
            data,
            method: 'DELETE',
            ...options
        })
    },
    
    upload<T = any>(url: string, filePath: string, name: string = 'file', formData: any = {}, options: RequestOptions = {}): Promise<T> {
        return new Promise<T>((resolve, reject) => {
            // 处理完整URL
            const fullUrl = url.startsWith('http') ? url : BASE_URL + url
            
            // 添加token到header
            const token = uni.getStorageSync('token')
            const header = options.header || {}
            if (token) {
                header['token'] = `${token}`
            }
            
            // 显示加载中
            if (options.showLoading !== false) {
                uni.showLoading({
                    title: '上传中...',
                    mask: true
                })
            }
            
            uni.uploadFile({
                url: fullUrl,
                filePath,
                name,
                formData,
                header,
                success: (res: any) => {
                    // 隐藏加载中
                    if (options.showLoading !== false) {
                        uni.hideLoading()
                    }
                    
                    if (res.statusCode === 200) {
                        try {
                            // 尝试解析返回的数据
                            const data = JSON.parse(res.data)
                            resolve(data as T)
                        } catch (e) {
                            resolve(res.data as T)
                        }
                    } else {
                        const error: HttpError = {
                            statusCode: res.statusCode,
                            message: '文件上传失败',
                            data: res.data
                        }
                        errorHandler(error, options)
                        reject(error)
                    }
                },
                fail: (error: any) => {
                    // 隐藏加载中
                    if (options.showLoading !== false) {
                        uni.hideLoading()
                    }
                    
                    const httpError: HttpError = {
                        statusCode: 0,
                        message: error.errMsg || '文件上传失败',
                        data: error
                    }
                    errorHandler(httpError, options)
                    reject(httpError)
                }
            })
        })
    }
}

export default http