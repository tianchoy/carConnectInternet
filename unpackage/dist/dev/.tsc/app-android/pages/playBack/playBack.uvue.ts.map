			flex: 1;
			width: 100%;
			position: relative;
		}

		.tools-panel {
			width: 100%;
			background-color: #fff;
			padding: 50rpx 20rpx;
			box-shadow: 0 -10rpx 20rpx rgba(0, 0, 0, 0.1);

			.Datetime-box {
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 30rpx;

				.date-box {
					display: flex;
					flex-direction: row;
					justify-content: center;
					align-items: center;

					.Date {
						font-size: 25rpx;
						border-radius: 5rpx;
						background-color: #f5f5f5;
						padding: 0 10rpx;
					}
				}

				.playbackdetail {
					font-size: 25rpx;
					color: #1890FF;
				}
			}

			.tool-tag-item {
				padding: 40rpx 20rpx;
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;

				.speed-label {
					border: 2rpx solid #1890FF;
					font-size: 25rpx;
					color: #1890FF;
					
					padding: 5rpx 15rpx;
					border-radius: 30rpx;
					margin-left: 20rpx;
				}

				.slider {
					flex: 1;
					padding: 0 20rpx 0 30rpx;
					overflow: visible;
				}

				.play-btn {
					font-size: 25rpx;
					color: #fff;
					
					padding: 10rpx 25rpx;
					border-radius: 10rpx;
					margin-left: 20rpx;
					background-color: #1890FF;
				}
			}

			.play-back-info {
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
				padding: 20rpx;
				margin-top: 20rpx;
				background-color: #f9f9f9;
				border-radius: 15rpx;

				.item-info {
					display: flex;
