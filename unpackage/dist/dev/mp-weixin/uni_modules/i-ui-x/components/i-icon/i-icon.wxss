:host{display:flex;flex-direction:column}

@font-face {
  font-family: "remixicon";

  src: url("https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.woff2")
    format("woff2");
}
.i-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
.i-icon--badge {
  width: 34px;
  height: 34px;
  border-radius: 34px;
}
.i-icon--mini {
  width: 26px;
  height: 26px;
  border-radius: 26px;
}
.i-icon--large {
  width: 44px;
  height: 44px;
  border-radius: 44px;
}
.i-icon--primary {
  background-color: #2979ff;
}
.i-icon--success {
  background-color: #19be6b;
}
.i-icon--warning {
  background-color: #ff9900;
}
.i-icon--danger {
  background-color: #fa3534;
}
.i-icon--plain {
  background-color: #ffffff;
  border-color: #dcdfe6;
  border-style: solid;
  border-width: 1px;
}
.i-icon__text {
  color: #303133;
  font-size: 16px;
  line-height: 1;
}
.i-icon__text--badge {
  color: #ffffff;
  font-weight: 700;
}
.i-icon__text--primary {
  color: #2979ff;
}
.i-icon__text--success {
  color: #19be6b;
}
.i-icon__text--warning {
  color: #ff9900;
}
.i-icon__text--danger {
  color: #fa3534;
}
.i-icon__image {
  width: 16px;
  height: 16px;
}