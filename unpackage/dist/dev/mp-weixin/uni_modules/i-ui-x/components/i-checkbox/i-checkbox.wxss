:host{display:flex;flex-direction:column}

.i-checkbox {
  min-height: 32px;
  flex-direction: row;
  align-items: center;
}
.i-checkbox--right {
  flex-direction: row-reverse;
  justify-content: space-between;
}
.i-checkbox--button {
  min-width: 64px;
  min-height: 34px;
  padding: 7px 12px;
  border-radius: 6px;
  border-width: 1px;
  border-style: solid;
  border-color: #dcdfe6;
  align-items: center;
  justify-content: center;
}
.i-checkbox--button-checked {
  border-color: #2979ff;
  background-color: #ecf5ff;
}
.i-checkbox--button-plain-checked {
  background-color: #ffffff;
}
.i-checkbox--disabled {
  opacity: 0.5;
}
.i-checkbox--border {
  border-bottom-width: 1px;
  border-bottom-style: solid;
  border-bottom-color: #eef0f4;
}
.i-checkbox__box {
  border-width: 1px;
  border-style: solid;
  align-items: center;
  justify-content: center;
}
.i-checkbox__mark {
  line-height: 18px;
}
.i-checkbox__label {
  margin-left: 8px;
  line-height: 22px;
}
.i-checkbox__label--button {
  margin-left: 0;
  text-align: center;
}