:host{display:flex;flex-direction:column}

.i-radio {
  min-height: 32px;
  flex-direction: row;
  align-items: center;
}
.i-radio--right {
  flex-direction: row-reverse;
  justify-content: space-between;
}
.i-radio--column {
  flex-direction: column;
  align-items: flex-start;
}
.i-radio__label--column {
  margin-left: 0;
  margin-top: 6px;
}
.i-radio--button {
  min-width: 64px;
  min-height: 34px;
  padding: 7px 12px;
  border-radius: 6px;
  border-width: 1px;
  border-style: solid;
  border-color: #dcdfe6;
  align-items: center;
  justify-content: center;
}
.i-radio--button-checked {
  border-color: #2979ff;
  background-color: #ecf5ff;
}
.i-radio--disabled {
  opacity: 0.5;
}
.i-radio--border {
  border-bottom-width: 1px;
  border-bottom-style: solid;
  border-bottom-color: #eef0f4;
}
.i-radio__box {
  border-width: 1px;
  border-style: solid;
  align-items: center;
  justify-content: center;
}
.i-radio__dot {
  width: 10px;
  height: 10px;
  border-radius: 5px;
}
.i-radio__check {
  line-height: 20px;
  font-weight: 700;
}
.i-radio__label {
  margin-left: 8px;
  line-height: 22px;
}
.i-radio__label--button {
  margin-left: 0;
  text-align: center;
}