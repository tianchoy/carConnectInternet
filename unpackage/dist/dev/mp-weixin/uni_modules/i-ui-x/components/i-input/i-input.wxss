:host{display:flex;flex-direction:column}

.i-input {
  padding: 0 12px;
  flex-direction: row;
  align-items: center;
}
.i-input--disabled {
  opacity: 0.76;
}
.i-input--focus {
  border-color: #3c9cff;
}
.i-input__prefix,
.i-input__suffix {
  color: #606266;
  font-size: 14px;
  line-height: 22px;
}
.i-input__prefix {
  margin-right: 8px;
}
.i-input__suffix,
.i-input__clear,
.i-input__eye,
.i-input__count {
  margin-left: 8px;
}
.i-input__field {
  flex: 1;
  min-width: 0;
}
.i-input__clear,
.i-input__eye {
  color: #c0c4cc;
  font-size: 16px;
  line-height: 22px;
}
.i-input__count {
  color: #c0c4cc;
  font-size: 12px;
  line-height: 18px;
}