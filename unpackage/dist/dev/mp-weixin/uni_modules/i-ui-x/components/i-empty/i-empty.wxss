:host{display:flex;flex-direction:column}

.i-empty {
  border-radius: 8px;
  align-items: center;
}
.i-empty__image {
  width: 110px;
  height: 110px;
}
.i-empty__icon {
  line-height: 52px;
}
.i-empty__text {
  margin-top: 8px;
  font-size: 15px;
  font-weight: 600;
  line-height: 22px;
}
.i-empty__desc {
  margin-top: 4px;
  font-size: 12px;
  line-height: 18px;
  text-align: center;
}
.i-empty__button {
  min-width: 96px;
  height: 36px;
  margin-top: 14px;
  padding: 0 14px;
  border-radius: 18px;
  align-items: center;
  justify-content: center;
}
.i-empty__button-text {
  font-size: 13px;
  line-height: 18px;
}