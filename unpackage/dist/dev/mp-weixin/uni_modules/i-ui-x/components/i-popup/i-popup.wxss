:host{display:flex;flex-direction:column}

.i-popup__trigger {
  flex-direction: column;
}
.i-popup {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
}
.i-popup__overlay {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  transition-property: opacity;
  transition-timing-function: ease;
}
.i-popup__panel {
  position: absolute;
  overflow: hidden;
  flex-direction: column;
  box-shadow: 0 12px 34px rgba(15, 23, 42, 0.18);
  transition-property: transform, opacity;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}
.i-popup__panel--bottom {
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 160px;
}
.i-popup__panel--top {
  left: 0;
  right: 0;
  top: 0;
  min-height: 160px;
}
.i-popup__panel--left {
  left: 0;
  top: 0;
  bottom: 0;
  width: 280px;
}
.i-popup__panel--right {
  right: 0;
  top: 0;
  bottom: 0;
  width: 280px;
}
.i-popup__panel--center {
  left: 50%;
  top: 50%;
  width: 300px;
}
.i-popup__panel--cover-center {
  left: 50%;
  right: auto;
  width: 375px;
  width: 100%;
  transform-origin: center center;
}
.i-popup__swipe-handle {
  height: 24px;
  align-items: center;
  justify-content: center;
}
.i-popup__swipe-bar {
  width: 38px;
  height: 4px;
  border-radius: 99px;
  background-color: #d9dee8;
}
.i-popup__header {
  min-height: 54px;
  padding: 0 52px 0 18px;
  border-bottom-width: 1px;
  border-bottom-style: solid;
  border-bottom-color: #f2f3f5;
  align-items: center;
  justify-content: center;
}
.i-popup__title {
  color: #303133;
  font-size: 16px;
  font-weight: 600;
  line-height: 24px;
}
.i-popup__close {
  position: absolute;
  z-index: 2;
  width: 34px;
  height: 34px;
  border-radius: 34px;
  background-color: rgba(245, 247, 250, 0.92);
  align-items: center;
  justify-content: center;
}
.i-popup__close--top-right {
  right: 12px;
  top: 10px;
}
.i-popup__close--top-left {
  left: 12px;
  top: 10px;
}
.i-popup__close--bottom-left {
  left: 12px;
  bottom: 10px;
}
.i-popup__close--bottom-right {
  right: 12px;
  bottom: 10px;
}
.i-popup__close-text {
  color: #606266;
  font-size: 22px;
  line-height: 34px;
  text-align: center;
}
.i-popup__body {
  position: relative;
  flex: 1;
}
.i-popup__body--scroll {
  flex: 1;
}
.i-popup__footer {
  min-height: 58px;
  padding: 10px 14px;
  border-top-width: 1px;
  border-top-style: solid;
  border-top-color: #f2f3f5;
  background-color: #ffffff;
  flex-direction: row;
}
.i-popup__footer-button {
  flex: 1;
  height: 40px;
  border-radius: 8px;
  align-items: center;
  justify-content: center;
}
.i-popup__footer-button--cancel {
  margin-right: 8px;
  background-color: #f5f7fb;
}
.i-popup__footer-button--confirm {
  background-color: #eef6ff;
}
.i-popup__footer-button--disabled {
  opacity: 0.45;
}
.i-popup__footer-cancel,
.i-popup__footer-confirm {
  font-size: 15px;
  font-weight: 600;
  line-height: 22px;
}
.i-popup__footer-cancel {
  color: #606266;
}