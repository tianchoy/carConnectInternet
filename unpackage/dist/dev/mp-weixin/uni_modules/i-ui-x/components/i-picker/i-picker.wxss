:host{display:flex;flex-direction:column}

.i-picker {
  width: 100%;
}
.i-picker__trigger {
  width: 100%;
}
.i-picker__input {
  height: 44px;
  padding: 0 12px;
  border-radius: 8px;
  background-color: #ffffff;
  flex-direction: row;
  align-items: center;
}
.i-picker__input-text {
  flex: 1;
  color: #303133;
  font-size: 14px;
  line-height: 22px;
}
.i-picker__input-text--placeholder {
  color: #909193;
}
.i-picker__arrow {
  width: 20px;
  color: #909193;
  font-size: 20px;
  line-height: 24px;
  text-align: right;
  transform: rotate(90deg);
}
.i-picker__mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 150;
  background-color: rgba(0, 0, 0, 0.42);
  justify-content: flex-end;
}
.i-picker__panel {
  overflow: hidden;
  background-color: #ffffff;
}
.i-picker__toolbar {
  height: 48px;
  padding: 0 16px;
  border-bottom-width: 1px;
  border-bottom-style: solid;
  border-bottom-color: #eef0f4;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.i-picker__cancel,
.i-picker__confirm {
  width: 64px;
  font-size: 14px;
  line-height: 22px;
}
.i-picker__confirm {
  text-align: right;
}
.i-picker__title {
  flex: 1;
  color: #111827;
  font-size: 16px;
  font-weight: 700;
  line-height: 24px;
  text-align: center;
}
.i-picker__loading {
  position: absolute;
  left: 0;
  right: 0;
  top: 48px;
  bottom: 0;
  z-index: 2;
  background-color: rgba(255, 255, 255, 0.78);
  align-items: center;
  justify-content: center;
}
.i-picker__loading-text {
  color: #606266;
  font-size: 14px;
  line-height: 22px;
}
.i-picker__columns {
  width: 100%;
}
.i-picker__column {
  flex: 1;
  height: 100%;
}
.i-picker__item {
  width: 100%;
  padding: 0 8px;
  align-items: center;
  justify-content: center;
}
.i-picker__item--active {
  background-color: transparent;
}
.i-picker__item--disabled {
  opacity: 0.42;
}
.i-picker__item-text {
  color: #303133;
  font-size: 15px;
  line-height: 22px;
  text-align: center;
}
.i-picker__item-text--active {
  color: #111827;
  font-weight: 700;
}