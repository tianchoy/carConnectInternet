:host{display:flex;flex-direction:column}

.i-button {
  display: flex;
  height: 44px;
  min-width: 86px;
  padding: 0 18px;
  border-width: 1px;
  border-style: solid;
  border-color: transparent;
  background-color: #f4f4f5;
  align-items: center;
  justify-content: center;
  flex-direction: row;
  margin: 0;
  overflow: hidden;
}
.i-button__inner {
  flex-direction: row;
  align-items: center;
  justify-content: center;
}
.i-button--block {
  width: 100%;
}
.i-button--large {
  height: 50px;
  min-width: 108px;
  padding: 0 22px;
}
.i-button--normal {
  height: 44px;
}
.i-button--small {
  height: 36px;
  min-width: 72px;
  padding: 0 14px;
}
.i-button--mini {
  height: 30px;
  min-width: 58px;
  padding: 0 10px;
}
.i-button--circle {
  border-radius: 999px;
}
.i-button--primary {
  background-color: #3c9cff;
}
.i-button--success {
  background-color: #5ac725;
}
.i-button--warning {
  background-color: #f9ae3d;
}
.i-button--error {
  background-color: #f56c6c;
}
.i-button--info {
  background-color: #909399;
}
.i-button--default {
  background-color: #f4f4f5;
  border-color: #dadbde;
}
.i-button--plain {
  background-color: #ffffff;
  border-color: #dadbde;
}
.i-button--plain-primary {
  border-color: #3c9cff;
  background-color: #ffffff;
}
.i-button--plain-success {
  border-color: #5ac725;
  background-color: #ffffff;
}
.i-button--plain-warning {
  border-color: #f9ae3d;
  background-color: #ffffff;
}
.i-button--plain-error {
  border-color: #f56c6c;
  background-color: #ffffff;
}
.i-button--plain-info {
  border-color: #909399;
  background-color: #ffffff;
}
.i-button--hairline {
  border-width: 0.5px;
}
.i-button--disabled {
  opacity: 0.6;
}
.i-button--loading {
  opacity: 0.9;
}
.i-button--hover {
  opacity: 0.86;
}
.i-button__text {
  color: #ffffff;
  font-size: 15px;
  font-weight: 500;
  line-height: 22px;
}
.i-button__text--small {
  font-size: 13px;
  line-height: 20px;
}
.i-button__text--default {
  color: #303133;
}
.i-button__text--plain-primary {
  color: #3c9cff;
}
.i-button__text--plain-success {
  color: #5ac725;
}
.i-button__text--plain-warning {
  color: #f9ae3d;
}
.i-button__text--plain-error {
  color: #f56c6c;
}
.i-button__text--plain-info {
  color: #909399;
}
.i-button__text--plain-default {
  color: #303133;
}
.i-button__text--disabled {
  opacity: 0.9;
}
.i-button__icon {
  margin-right: 6px;
  color: #ffffff;
  font-size: 15px;
  line-height: 22px;
}
.i-button__icon--right {
  margin-right: 0;
  margin-left: 6px;
}
.i-button__loading {
  margin-right: 6px;
  border-radius: 999px;
  border-width: 2px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.45);
  border-top-color: #ffffff;
  box-sizing: border-box;
}
.i-button__loading--circle {
  border-radius: 999px;
}
.i-button__text--loading {
  opacity: 0.96;
}
.i-button__loading--muted {
  border-color: rgba(48, 49, 51, 0.18);
  border-top-color: #606266;
}
.i-button__loading--plain-primary {
  border-top-color: #3c9cff;
}
.i-button__loading--plain-success {
  border-top-color: #5ac725;
}
.i-button__loading--plain-warning {
  border-top-color: #f9ae3d;
}
.i-button__loading--plain-error {
  border-top-color: #f56c6c;
}
.i-button__loading--plain-info {
  border-top-color: #909399;
}