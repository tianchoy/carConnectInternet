:host{display:flex;flex-direction:column}

.i-tag {
  height: 28px;
  padding: 0 10px;
  border-radius: 4px;
  border-width: 1px;
  border-style: solid;
  border-color: transparent;
  align-items: center;
  justify-content: center;
  flex-direction: row;
  background-color: #3c9cff;
  overflow: hidden;
}
.i-tag--round {
  border-radius: 999px;
}
.i-tag--xs {
  height: 20px;
  padding: 0 7px;
}
.i-tag--small {
  height: 22px;
  padding: 0 8px;
}
.i-tag--large {
  height: 34px;
  padding: 0 12px;
}
.i-tag--disabled {
  opacity: 0.5;
}
.i-tag--primary {
  background-color: #3c9cff;
  border-color: #3c9cff;
}
.i-tag--success {
  background-color: #5ac725;
  border-color: #5ac725;
}
.i-tag--warning {
  background-color: #f9ae3d;
  border-color: #f9ae3d;
}
.i-tag--error {
  background-color: #f56c6c;
  border-color: #f56c6c;
}
.i-tag--info {
  background-color: #909399;
  border-color: #909399;
}
.i-tag--thin {
  background-color: #ecf5ff;
  border-color: #ecf5ff;
}
.i-tag--thin-success {
  background-color: #f0f9eb;
  border-color: #f0f9eb;
}
.i-tag--thin-warning {
  background-color: #fdf6ec;
  border-color: #fdf6ec;
}
.i-tag--thin-error {
  background-color: #fef0f0;
  border-color: #fef0f0;
}
.i-tag--thin-info {
  background-color: #f4f4f5;
  border-color: #f4f4f5;
}
.i-tag--outlined,
.i-tag--dashed,
.i-tag--text {
  background-color: #ffffff;
}
.i-tag--outlined-primary,
.i-tag--dashed-primary {
  border-color: #3c9cff;
}
.i-tag--outlined-success,
.i-tag--dashed-success {
  border-color: #5ac725;
}
.i-tag--outlined-warning,
.i-tag--dashed-warning {
  border-color: #f9ae3d;
}
.i-tag--outlined-error,
.i-tag--dashed-error {
  border-color: #f56c6c;
}
.i-tag--outlined-info,
.i-tag--dashed-info {
  border-color: #909399;
}
.i-tag--dashed {
  border-style: dashed;
}
.i-tag--text {
  border-color: transparent;
}
.i-tag__text {
  color: #ffffff;
  font-size: 12px;
  line-height: 18px;
}
.i-tag__text--xs {
  font-size: 11px;
  line-height: 16px;
}
.i-tag__text--large {
  font-size: 14px;
  line-height: 20px;
}
.i-tag__icon {
  margin-right: 4px;
}
.i-tag__close {
  margin-left: 5px;
  color: #ffffff;
  font-size: 14px;
  line-height: 18px;
}
.i-tag__close--xs {
  font-size: 12px;
  line-height: 16px;
}