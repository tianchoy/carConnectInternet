.l-action-sheet {
  color: var(--l-action-sheet-color, var(--l-text-color-1, rgba(0, 0, 0, 0.88)));
  border-top-left-radius: var(--l-action-sheet-border-radius, var(--l-border-radius-lg, 18rpx));
  border-top-right-radius: var(--l-action-sheet-border-radius, var(--l-border-radius-lg, 18rpx));
  background-color: var(--l-bg-color-container, #fff);
}
.l-action-sheet__item {
  height: var(--l-action-sheet-item-height, 112rpx);
  justify-content: center;
  align-items: center;
  flex-direction: row;
  padding: 0 32rpx;
}
.l-action-sheet__item-text {
  color: var(--l-action-sheet-color, var(--l-text-color-1, rgba(0, 0, 0, 0.88)));
  font-size: var(--l-action-sheet-font-size, var(--l-font-size-md, 16px));
}
.l-action-sheet__item-icon {
  color: var(--l-action-sheet-color, var(--l-text-color-1, rgba(0, 0, 0, 0.88)));
  margin-right: 16rpx;
  font-size: var(--l-action-sheet-font-size, var(--l-font-size-md, 16px));
}
.l-action-sheet__item--hover {
  background-color: var(--l-action-sheet-hover-color, var(--l-fill-3, rgba(0, 0, 0, 0.04)));
}
.l-action-sheet__item--left {
  justify-content: flex-start;
}
.l-action-sheet__item--disabled {
  opacity: 0.5;
}
.l-action-sheet__item--bordered:before {
  position: absolute;
  box-sizing: border-box;
  content: " ";
  pointer-events: none;
  transform-origin: center;
  /* cover wechat button:after default transforn-origin */
  right: 0;
  bottom: 0;
  left: 0;
  border-bottom: 1px solid var(--l-action-sheet-gap-color, var(--l-bg-color-page, #f5f5f5));
  transform: scaleY(0.5);
  transform: scaleY(0.8);
}
.l-action-sheet__gap {
  height: var(--l-action-sheet-gap-height, 16rpx);
  background-color: var(--l-action-sheet-gap-color, var(--l-bg-color-page, #f5f5f5));
}
.l-action-sheet__cancel {
  display: flex;
  background-color: var(--l-bg-color-container, #fff);
  height: var(--l-action-sheet-cancel-height, 96rpx);
  justify-content: center;
  align-items: center;
  box-sizing: content-box;
}
.l-action-sheet__cancel--hover {
  background-color: var(--l-action-sheet-hover-color, var(--l-fill-3, rgba(0, 0, 0, 0.04)));
}
.l-action-sheet__cancel-text {
  color: var(--l-action-sheet-cancel-color, var(--l-text-color-1, rgba(0, 0, 0, 0.88)));
  font-size: var(--l-action-sheet-font-size, var(--l-font-size-md, 16px));
}
.l-action-sheet__description {
  color: var(--l-action-sheet-description-color, var(--l-text-color-3, rgba(0, 0, 0, 0.45)));
  line-height: 44rpx;
  font-size: var(--l-action-sheet-description-font-size, var(--l-font-size, 14px));
  text-align: var(--l-action-sheet-text-align, center);
  padding: 24rpx 32rpx;
  border-bottom: 0.8px solid var(--l-action-sheet-gap-color, var(--l-bg-color-page, #f5f5f5));
}
.l-action-sheet__description--left {
  text-align: left;
}
.l-action-sheet__wrap {
  display: flex;
  padding-top: 32rpx;
  padding-bottom: 32rpx;
  white-space: nowrap;
  flex-direction: row;
  flex-wrap: nowrap;
  width: -webkit-fit-content;
  width: fit-content;
  min-width: 100%;
}
.l-action-sheet__row--border {
  position: relative;
}
.l-action-sheet__row--border:before {
  position: absolute;
  content: "";
  left: 0;
  right: 0;
  height: 1px;
  background: var(--l-action-sheet-gap-color, var(--l-bg-color-page, #f5f5f5));
}
.l-action-sheet__col {
  justify-content: center;
  align-items: center;
}
.l-action-sheet__col--evenly {
  flex: 1;
}
.l-action-sheet__col-text {
  color: var(--l-action-sheet-color, var(--l-text-color-1, rgba(0, 0, 0, 0.88)));
  padding-top: var(--l-action-sheet-col-text-padding, 24rpx);
  font-size: var(--l-action-sheet-font-size, 24rpx);
}
.l-action-sheet__col-icon {
  font-size: var(--l-action-sheet-icon-size, 48rpx);
}
.l-action-sheet__image {
  width: var(--l-action-sheet-image-size, 96rpx);
  height: var(--l-action-sheet-image-size, 96rpx);
  margin: 0 16px;
  background-color: var(--l-action-sheet-image-bg-color, var(--l-fill-3, rgba(0, 0, 0, 0.04)));
  border-radius: 99px;
}
.l-action-sheet__image--center {
  justify-content: center;
  align-items: center;
}