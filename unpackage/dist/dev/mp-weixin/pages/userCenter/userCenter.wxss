.container {
  width: 100%;
  height: 100%;
  background-color: #fff;
  position: relative;
}
.container .user-info-box {
  width: 100%;
  padding: 40rpx 60rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}
.container .user-info-box .userinfo {
  display: flex;
  flex-direction: row;
  justify-content: left;
  align-items: center;
  flex: 1;
}
.container .user-info-box .user-info {
  margin-left: 20rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
}
.container .list {
  background-color: #f5f5f5;
  padding: 30rpx;
  border-radius: 20rpx;
  margin: 15rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  font-size: 25rpx;
}
.container .list .left {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}
.container .list .left .badge {
  margin-left: 20rpx;
}
.container .version {
  position: fixed;
  bottom: 50rpx;
  left: 20rpx;
  right: 20rpx;
  text-align: center;
  font-size: 25rpx;
  color: #c3c2c2ff;
  margin: 20rpx 40rpx 0;
}
.container .movable-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 999;
}
.container .movable-area .movable-view {
  width: 120px;
  height: 200px;
  pointer-events: auto;
}
.container .movable-area .movable-view .contact-button-movable {
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  line-height: 1;
}
.container .movable-area .movable-view .contact-button-movable:active {
  transform: scale(0.95);
}
.container .movable-area .movable-view .contact-button-movable::after {
  border: 0 !important;
}
.container .movable-area .movable-view .contact-button-movable .contact-text {
  font-size: 20rpx;
  color: #666;
  margin-top: 8rpx;
}
.container .movable-area .movable-view .contact-button-movable .contact-text:first-of-type {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-top: 12rpx;
}