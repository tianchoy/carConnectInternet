.container {
  height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 20rpx;
}
.container .tools-panel {
  background-color: #fff;
  border: 1rpx solid #69c2f1;
  padding: 20rpx;
  margin: 20rpx;
  border-radius: 20rpx;
}
.container .tools-panel .Datetime-box {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
}
.container .tools-panel .Datetime-box .date-box {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
}
.container .tools-panel .Datetime-box .date-box .Date {
  font-size: 25rpx;
  border-radius: 5rpx;
  color: #333;
}
.container .summary-panel {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  background-color: #fff;
  margin: 20rpx;
  padding: 20rpx;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.container .summary-panel .summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.container .summary-panel .summary-item .label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}
.container .summary-panel .summary-item .value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}
.container .content {
  margin: 0 20rpx;
  max-height: calc(80vh - 200rpx);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  background-color: #fff;
  border-radius: 20rpx;
}
.container .content .trip-list {
  width: 100%;
}
.container .content .trip-list .trip-group {
  padding: 20rpx;
  background-color: #fff;
  border-radius: 15rpx;
}
.container .content .trip-list .trip-group .group-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
}
.container .content .trip-list .trip-group .group-header .group-header-title {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}
.container .content .trip-list .trip-group .group-header .group-date {
  font-size: 30rpx;
  color: #333;
  margin-right: 30rpx;
}
.container .content .trip-list .trip-group .group-separator {
  height: 1rpx;
  background-color: #eee;
  margin: 10rpx 0;
}
.container .content .trip-list .trip-group .trip-item {
  display: flex;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.container .content .trip-list .trip-group .trip-item .trip-index {
  display: flex;
  flex-direction: row;
  justify-content: start;
  align-items: center;
  padding-top: 5rpx;
}
.container .content .trip-list .trip-group .trip-item .trip-index .icon {
  width: 40rpx;
  height: 40rpx;
  background-color: #1296db;
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  margin-right: 20rpx;
}
.container .content .trip-list .trip-group .trip-item .trip-index .trip-distance-time {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  flex: 1;
}
.container .content .trip-list .trip-group .trip-item .trip-index .trip-distance-time text {
  font-size: 28rpx;
  color: #333;
  margin: 0 10rpx;
}
.container .content .trip-list .trip-group .trip-item .trip-content {
  flex: 1;
}
.container .content .trip-list .trip-group .trip-item .trip-content .trip-locations .icons {
  width: 50rpx;
  height: 50rpx;
}