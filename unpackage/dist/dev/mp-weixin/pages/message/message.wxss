.container {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
  margin-top: 170rpx;
  position: relative;
}
.container .scroll-container {
  height: 100%;
  width: 100%;
}
.container .list-box {
  width: 100%;
  padding: 20rpx;
  position: relative;
}
.container .list-box .message-item {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background-color: #fff;
}
.container .list-box .message-header,
.container .list-box .message-content-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.container .list-box .message-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}
.container .list-box .message-content-row {
  margin-top: 16rpx;
}
.container .list-box .message-content {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}
.container .list-box .unread-badge {
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  background-color: #f56c6c;
  color: #fff;
  font-size: 22rpx;
}
.container .list-box .empty-state {
  text-align: center;
  padding: 50rpx 0;
  color: #999;
  font-size: 28rpx;
}
.container .list-box .new-message-tip {
  background: linear-gradient(135deg, #2979ff, #07c160);
  color: white;
  padding: 20rpx;
  text-align: center;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
}
.container .list-box .load-more {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
  text-align: center;
}
.container .list-box .load-more .tips-text {
  color: #999;
  font-size: 26rpx;
  text-align: center;
}