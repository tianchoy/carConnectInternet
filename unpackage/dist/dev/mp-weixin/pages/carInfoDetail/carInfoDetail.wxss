.container {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f7fa;
}
.container .map-container {
  flex: 1;
  width: 100%;
  position: relative;
}
.container .map-container .drag-hint {
  position: absolute;
  top: 20rpx;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 16rpx;
  text-align: center;
  font-size: 28rpx;
  color: #00aa00;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  animation: pulse 1.5s infinite;
}
@keyframes pulse {
0% {
    opacity: 0.7;
}
50% {
    opacity: 1;
}
100% {
    opacity: 0.7;
}
}
.container .map-container .navTo {
  width: 60rpx;
  height: 60rpx;
  background-color: #fff;
  border-radius: 10rpx;
  position: absolute;
  z-index: 100;
  bottom: 10%;
  right: 30rpx;
  padding: 5rpx;
}
.container .map-container .navTo image {
  width: 100%;
  height: 100%;
}
.container .tool-nav {
  position: absolute;
  top: 200rpx;
  right: 20rpx;
  z-index: 100;
}
.container .tool-nav .btn-map-list {
  width: 60rpx;
  height: 60rpx;
}
.container .tool-nav .btn-map-list-icon {
  width: 100%;
  height: 100%;
  padding: 8rpx;
  border-radius: 10rpx;
  background-color: #69c2f1;
}
.container .tool-more {
  position: absolute;
  top: 30%;
  right: 20rpx;
  z-index: 100;
  width: 60rpx;
  height: 60rpx;
}
.container .tool-more .btn-tool-more-icon {
  width: 100%;
  height: 100%;
}
.container .tools-panel {
  width: 100%;
  background-color: #fff;
  padding-bottom: 70rpx;
}
.container .tools-panel .refresh-status {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #f8f9fa;
  border-bottom: 1rpx solid #e8e8e8;
}
.container .tools-panel .refresh-status .refresh-text {
  font-size: 26rpx;
  color: #666;
}
.container .tools-panel .refresh-status .refresh-text.refreshing {
  color: #1890ff;
  animation: rotating 2s linear infinite;
}
.container .tools-panel .refresh-status .refresh-btn {
  margin-left: auto;
  color: #1890ff;
  font-size: 26rpx;
}
@keyframes rotating {
0% {
    transform: rotate(0deg);
}
100% {
    transform: rotate(360deg);
}
}
.container .tools-panel .Imei-box {
  padding: 20rpx 30rpx 0;
  font-size: 32rpx;
}
.container .tools-panel .Imei-box .imei-info {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}
.container .tools-panel .Imei-box .imei-info .imeis {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  align-items: center;
}
.container .tools-panel .Imei-box .imei-info .imeis .battery {
  display: inline-block;
  font-size: 25rpx;
  margin-left: 50rpx;
}
.container .tools-panel .Imei-box .imei-info .imeis .power {
  display: inline-block;
  font-size: 25rpx;
  margin-left: 30rpx;
  color: #69c2f1;
}
.container .tools-panel .Imei-box .pos-time {
  font-size: 25rpx;
  color: #999;
}
.container .tools-panel .Imei-box .signal-container {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  align-items: center;
  padding: 20rpx 0;
}
.container .tools-panel .Imei-box .signal-container .signal-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-right: 40rpx;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-bars-horizontal {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  height: 40rpx;
  gap: 3rpx;
  margin-right: 10rpx;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-bars-horizontal .signal-bar-h {
  width: 8rpx;
  border-radius: 2rpx 2rpx 0 0;
  transition: all 0.3s ease;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-bars-horizontal .signal-bar-h:nth-child(1) {
  height: 12rpx;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-bars-horizontal .signal-bar-h:nth-child(2) {
  height: 16rpx;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-bars-horizontal .signal-bar-h:nth-child(3) {
  height: 20rpx;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-bars-horizontal .signal-bar-h:nth-child(4) {
  height: 24rpx;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-bars-horizontal .signal-bar-h:nth-child(5) {
  height: 28rpx;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-bars-horizontal .signal-bar-h.bar-active {
  background: #52c41a;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-bars-horizontal .signal-bar-h.bar-off {
  background: #e8e8e8;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-info-h {
  display: flex;
  flex-direction: column;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-info-h .signal-value {
  font-size: 20rpx;
  color: #333;
  margin-bottom: 4rpx;
}
.container .tools-panel .Imei-box .signal-container .signal-item .mobile-signal .signal-info-h .experience {
  font-size: 20rpx;
  font-weight: normal;
}
.container .tools-panel .Imei-box .signal-container .satellite-item-h {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #f0f8ff;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
}
.container .tools-panel .Imei-box .signal-container .satellite-item-h .satellite-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.container .tools-panel .Imei-box .signal-container .satellite-item-h .satellite-text {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: bold;
}
.container .tools-panel .h-line {
  width: 90%;
  height: 2rpx;
  background-color: #f1f1f1;
  margin: 50rpx auto 0;
}
.container .tools-panel .tool-tag-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 50rpx 20rpx;
}
.container .tools-panel .speed-control {
  padding: 20rpx;
}
.container .tools-panel .speed-control .slider {
  width: 90%;
  margin: 0 auto;
}
.container .tools-panel .grid-text {
  padding: 20rpx 0 0;
  box-sizing: border-box;
  font-size: 24rpx;
}