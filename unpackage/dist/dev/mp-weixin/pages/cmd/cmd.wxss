.container.data-v-c4271740 {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
.device-info.data-v-c4271740 {
  display: flex;
  align-items: center;
  background: white;
  padding: 20rpx;
  border-radius: 10rpx;
  margin: 30rpx 0;
}
.device-label.data-v-c4271740 {
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
}
.device-input.data-v-c4271740 {
