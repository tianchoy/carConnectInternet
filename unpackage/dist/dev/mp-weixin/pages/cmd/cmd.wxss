  padding: 20rpx;
  margin-bottom: 30rpx;
}
.section-title.data-v-c4271740 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}
.record-list.data-v-c4271740 {
  font-size: 26rpx;
  color: #666;
}
.type-container.data-v-c4271740 {
  width: 100%;
}
.type-list.data-v-c4271740 {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-items: center;
  gap: 20rpx;
}
.type-item.data-v-c4271740 {
